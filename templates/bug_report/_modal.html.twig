{% form_theme form 'communs/form_theme_v2.html.twig' %}

{{ form_start(form, {'attr': {'class': 'space-y-5', 'id': 'modal_form'}}) }}

{# Champs cachés pour le contexte #}
{{ form_widget(form.formation) }}
{{ form_widget(form.parcours) }}
{{ form_widget(form.page) }}

{# Affichage des informations contextuelles (lecture seule) #}
<div class="grid gap-4 md:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm">
        <label class="text-xs font-semibold uppercase tracking-wide text-slate-500">Personne connectée</label>
        <input type="text"
               class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 shadow-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100"
               readonly
               value="{{ user.display }}{% if user.email is not empty %} ({{ user.email }}){% endif %}">
    </div>

    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm">
        <label class="text-xs font-semibold uppercase tracking-wide text-slate-500">Formation</label>
        <input type="text"
               class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 shadow-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100"
               readonly
               value="{{ context.formationLabel }}">
    </div>

    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm">
        <label class="text-xs font-semibold uppercase tracking-wide text-slate-500">Parcours</label>
        <input type="text"
               class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 shadow-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100"
               readonly
               value="{{ context.parcoursLabel }}">
    </div>

    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm">
        <label class="text-xs font-semibold uppercase tracking-wide text-slate-500">Page</label>
        <input type="text"
               class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 shadow-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100"
               readonly
               value="{{ context.page is not empty ? context.page : 'Non définie' }}">
    </div>
</div>

{# Affichage des champs du formulaire avec le thème #}
{{ form_row(form.title) }}
{{ form_row(form.message) }}

{{ form_end(form) }}

