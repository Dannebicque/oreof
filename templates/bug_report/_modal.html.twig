<form method="post" action="{{ path('app_bug_report_modal') }}" class="space-y-5">
    <input type="hidden" name="_token" value="{{ csrf_token('bug_report') }}">
    <input type="hidden" name="formation" value="{{ context.formationId ?? '' }}">
    <input type="hidden" name="parcours" value="{{ context.parcoursId ?? '' }}">
    <input type="hidden" name="page" value="{{ context.page ?? '' }}">

    <div class="grid gap-4 md:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm">
            <label for="bug_report_user" class="text-xs font-semibold uppercase tracking-wide text-slate-500">Personne connectée</label>
            <input id="bug_report_user" type="text"
                   class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 shadow-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100"
                   readonly
                   value="{{ user.display }}{% if user.email is not empty %} ({{ user.email }}){% endif %}">
        </div>

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm">
            <label for="bug_report_formation" class="text-xs font-semibold uppercase tracking-wide text-slate-500">Formation</label>
            <input id="bug_report_formation" type="text"
                   class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 shadow-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100"
                   readonly
                   value="{{ context.formationLabel }}">
        </div>

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm">
            <label for="bug_report_parcours" class="text-xs font-semibold uppercase tracking-wide text-slate-500">Parcours</label>
            <input id="bug_report_parcours" type="text"
                   class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 shadow-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100"
                   readonly
                   value="{{ context.parcoursLabel }}">
        </div>

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm">
            <label for="bug_report_page" class="text-xs font-semibold uppercase tracking-wide text-slate-500">Page</label>
            <input id="bug_report_page" type="text"
                   class="mt-2 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 shadow-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100"
                   readonly
                   value="{{ context.page is not empty ? context.page : 'Non définie' }}">
        </div>
    </div>

    <div class="space-y-2">
        <label for="bug_report_title" class="text-sm font-semibold text-slate-700 dark:text-slate-200 required">Titre</label>
        <input id="bug_report_title" type="text" name="title" maxlength="200" required
               class="w-full rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm text-slate-800 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:focus:border-cyan-400 dark:focus:ring-cyan-900/40">
    </div>

    <div class="space-y-2">
        <label for="bug_report_message" class="text-sm font-semibold text-slate-700 dark:text-slate-200 required">Message</label>
        <textarea id="bug_report_message" name="message" rows="8" required
                  placeholder="Décrivez le problème, les étapes pour le reproduire et le résultat attendu."
                  class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:focus:border-cyan-400 dark:focus:ring-cyan-900/40"></textarea>
    </div>

    <div class="flex justify-end gap-2 border-t border-slate-100 pt-4 dark:border-slate-700/80">
        <button type="submit"
                class="app-btn app-btn-warning h-10 px-4"
                {{ stimulus_action('base','sauvegardeFormModal', 'click') }}>
            <twig:UX:Icon name="icon:bug" class="h-4 w-4" />
            Envoyer le signalement
        </button>
    </div>
</form>

