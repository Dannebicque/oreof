<table class="w-full border-collapse rounded-lg overflow-hidden border border-slate-200">
    <thead>
    <tr class="bg-slate-100 border-b border-slate-200">
        <th class="px-4 py-3 text-left text-sm font-semibold text-slate-700"
            {% if constant('SOURCE', typeDiplome) == 'meef' %}colspan="2"{% endif %}>Libellé du parcours
        </th>
        <th class="px-4 py-3 text-left text-sm font-semibold text-slate-700">Responsable du parcours</th>
        <th class="px-4 py-3 text-left text-sm font-semibold text-slate-700">Co Responsable du parcours</th>
        <th class="px-4 py-3 text-left text-sm font-semibold text-slate-700">Remplissage</th>
        <th class="px-4 py-3 text-left text-sm font-semibold text-slate-700">Etat</th>
        <th class="px-4 py-3 text-right text-sm font-semibold text-slate-700">Actions</th>
    </tr>
    </thead>
    <tbody>
    {% for parcour in parcours|filter(parcour => parcour.parcoursParent == null) %}
        <tr class="hover:bg-slate-50 border-b border-slate-200 transition-colors">
            <td class="px-4 py-3 text-sm" {% if constant('SOURCE', typeDiplome) == 'meef' %}colspan="2"{% endif %}>
                <div class="font-medium text-gray-900">{{ parcour.libelle }}</div>
                <div class="text-xs text-gray-500 mt-0.5">{{ parcour.typeParcours|badgeTypeParcours }}</div>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600">
                {{ parcour.respParcours != null ? parcour.respParcours.display : '<span class="text-gray-400">Non défini</span>' }}
            </td>
            <td class="px-4 py-3 text-sm text-gray-600">
                {{ parcour.coResponsable != null ? parcour.coResponsable.display : '<span class="text-gray-400">Non défini</span>' }}
            </td>
            <td class="px-4 py-3 text-sm" style="width:15%">
                {{ component('remplissage_progress', { value: parcour.remplissage }) }}
            </td>
            <td class="px-4 py-3 text-sm">
                <div class="flex items-center gap-2">
                    {{ parcour.etatDpeParcours|badgeDpe }}
                    {% if parcours.withCfvu is defined and parcours.withCfvu == true %}
                        <twig:Badge label="CFVU" variant="warning" :soft="true" size="sm"/>
                    {% endif %}
                </div>
            </td>
            <td class="px-4 py-3 text-right space-y-2">
                {% if not('non_ouverture' in parcour.etatDpeParcours|keys or 'non_ouverture_cfvu' in parcour.etatDpeParcours|keys or 'non_ouverture_ses' in parcour.etatDpeParcours|keys) %}
                    <div class="flex flex-col sm:flex-row gap-2 justify-end flex-wrap">
                        {% if constant('SOURCE', typeDiplome) != 'meef' %}
                            <twig:Button
                                    label="Modifier"
                                    variant="warning"
                                    icon="icon:edit"
                                    href="{{ path('parcours_v2_modifier', {parcours:parcour.id}) }}"
                                    target="_blank"
                                    tooltip="Modifier la fiche du parcours"
                                    size="sm"
                            />
                        {% endif %}
                        <twig:Button
                                label="Vérifier"
                                variant="success"
                                icon="icon:info"
                                tooltip="Vérifier la saisie"
                                size="sm"
                                dataAction="click->modalturbo#open"
                                href="{{ path('app_parcours_state', {parcours:parcour.id}) }}"
                        />

                        {% if is_granted('ROLE_ADMIN') %}
                            <twig:Button
                                    label="Supprimer"
                                    variant="danger"
                                    icon="icon:delete"
                                    href="{{ path('app_parcours_delete',{id: parcour.id,
                                        csrf: csrf_token('delete' ~ parcour.id)
                                    }) }}"
                                    tooltip="Supprimer le parcours"
                                    size="sm"
                            />
                        {% endif %}

                        <twig:Button
                                label="Non ouverture"
                                variant="secondary"
                                icon="icon:close"
                                tooltip="Demande de non ouverture"
                                size="sm"
                                href="{{ path('app_validation_demande_non_ouverture', {parcours: parcour.id}) }}"
                                dataAction="click->modalturbo#open"
                        />
                    </div>
                {% else %}
                    {% if 'non_ouverture' in parcour.etatDpeParcours|keys %}
                        <span class="text-sm text-blue-600">Parcours non ouvert pour {{ user_data.campagneCollecte.libelle }}</span>
                    {% else %}
                        <span class="text-sm text-amber-600">Demande de non ouverture en cours</span>
                    {% endif %}
                {% endif %}
            </td>
        </tr>
        {% if constant('SOURCE', typeDiplome) == 'meef' %}
            {% for parc in parcour.parcoursEnfants %}
                <tr class="hover:bg-slate-50 border-b border-slate-200 transition-colors border-l-2 border-l-blue-500">
                    <td class="px-4 py-3 text-sm text-gray-500"></td>
                    <td class="px-4 py-3 text-sm">
                        <div class="font-medium text-gray-900">{{ parc.libelle }}</div>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-600">
                        {{ parc.respParcours != null ? parc.respParcours.display : '<span class="text-gray-400">Non défini</span>' }}
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-600">
                        {{ parc.coResponsable != null ? parc.coResponsable.display : '<span class="text-gray-400">Non défini</span>' }}
                    </td>
                    <td class="px-4 py-3 text-sm" style="width:15%">
                        {{ component('remplissage_progress', { value: parc.remplissage }) }}
                    </td>
                    <td class="px-4 py-3 text-right space-y-2">
                        <div class="flex flex-col sm:flex-row gap-2 justify-end flex-wrap">
                            <twig:Button
                                    label="Modifier"
                                    variant="warning"
                                    icon="icon:pencil"
                                    tooltip="Modifier une option"
                                    size="sm"
                                    href="{{ path('app_parcours_edit_modal', {parcours:parc.id}) }}"
                                    dataAction="click->modalturbo#open"
                            />
                            <twig:Button
                                    label="Fiche"
                                    variant="secondary"
                                    icon="icon:document"
                                    href="{{ path('parcours_v2_modifier', {parcours:parc.id}) }}"
                                    tooltip="Editer la fiche de l'option"
                                    size="sm"
                            />
                            {% if is_granted('ROLE_ADMIN') %}
                                <twig:Button
                                        label="Dupliquer"
                                        variant="primary"
                                        icon="icon:document-copy"
                                        tooltip="Dupliquer l'option"
                                        size="sm"

                                />
                                {#                                    {{ stimulus_action('formation--step3', 'dupliquerParcours', 'click', { #}
                                {#                                        url:path('app_parcours_dupliquer',{'id': parc.id}), #}
                                {#                                        id: parc.id}) }} #}

                                <twig:Button
                                        label="Supprimer"
                                        variant="danger"
                                        icon="icon:delete"
                                        tooltip="Supprimer l'option"
                                        size="sm"

                                />
                                {#                                    {{ stimulus_action('formation--step3', 'deleteParcours', 'click', { #}
                                {#                                        url:path('app_parcours_delete',{'id': parc.id}), #}
                                {#                                        id: parc.id, #}
                                {#                                        csrf: csrf_token('delete' ~ parc.id) #}
                                {#                                    }) }} #}
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr class="bg-amber-50 border-b border-slate-200 border-l-2 border-l-blue-500">
                    <td class="px-4 py-3 text-sm text-gray-500"></td>
                    <td colspan="5" class="px-4 py-3 text-center text-sm text-amber-800 font-medium">Aucune option pour
                        ce parcours.
                    </td>
                </tr>
            {% endfor %}
            <tr class="hover:bg-slate-50 border-b border-slate-200 border-l-2 border-l-blue-500">
                <td class="px-4 py-3 text-sm text-gray-500"></td>
                <td colspan="5" class="px-4 py-3">
                    <twig:Button
                            label="Ajouter une option"
                            variant="success"
                            icon="icon:add"
                            tooltip="Ajouter une option au parcours {{ parcour.display }}"
                            href="{{ path('app_parcours_new', {formation:formation.id, parent:parcour.id}) }}"
                            dataAction="click->modalturbo#open"
                    />
                </td>
            </tr>
        {% endif %}
    {% else %}
        <tr>
            <td colspan="{% if constant('SOURCE', typeDiplome) == 'meef' %}7{% else %}6{% endif %}"
                class="px-4 py-6 text-center bg-amber-50 border-b border-slate-200">
                <p class="text-sm text-amber-800 font-medium">Aucun parcours, veuillez en ajouter au moins un.</p>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
