{{ component('alerte', {
    type: 'info',
    message: (process.label~'.valide.alerte')|trans({}, 'process')|nl2br|raw
}) }}

<form action="{{ path('app_historique_edit', {historique: historique.id}) }}" method="post"
      enctype="multipart/form-data"
      class="space-y-4">

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">

    {% if process.hasDate is defined and process.hasDate %}
        <div class="space-y-2">
            <label for="date"
                   class="block text-sm font-medium text-slate-700">{{ ('valide.'~process.label~'.date.label')|trans({}, 'process') }}
                <span class="required"></span> <i
                        class="fal fa-question-circle ml-1"
                        data-controller="tooltip"
                        data-tooltip-placement-value="bottom"
                        aria-label="{{ ('valide.'~process.label~'.helps.date.help')|trans({}, 'process') }}"
                        data-bs-original-title="{{ ('valide.'~process.label~'.helps.date.help')|trans({}, 'process') }}"></i></label>
            <input type="date" name="date"
                   class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
                   id="date"
                   value="{{ historique.date|date('Y-m-d') }}"
            >
        </div>
    {% endif %}

    {% if etape == 'soumis_cfvu' or etape == 'cfvu' %}
        {# regarder si dans l'historique on à un laissez-passer sur le conseil  #}
        {% if laisserPasser is defined and laisserPasser != false %}
            <div class="md:col-span-2">
            {% if laisserPasser.etat == 'laisserPasser' %}
                {{ component('alerte', {type:'warning', message: 'Un laissez-passer a été demandé le '~laisserPasser.created|date('d/m/Y')~'.'}) }}
            {% else %}
                <a
                        href="{{ path('app_upload_download', {context: 'conseils', filename: laisserPasser.complements.fichier, originalName: laisserPasser.complements.fichier_original|default(laisserPasser.complements.fichier)}) }}"
                        target="_blank"
                        class="inline-flex items-center gap-2 rounded-md border border-cyan-300 bg-cyan-50 px-3 py-2 text-sm font-medium text-cyan-700 hover:bg-cyan-100"
                        data-bs-toggle="tooltip"
                        data-bs-placement="bottom"
                        title="{{ 'voir.le.pv.infobulle'|trans({}, 'process') }}"
                >
                    <i class="{{ iconDownload }}"></i>
                    <span> {{ 'voir.le.pv'|trans({}, 'process') }}</span>
                </a>
            {% endif %}
            </div>
        {% endif %}
    {% endif %}

    {% if process.hasUpload is defined and process.hasUpload %}
        <div class="space-y-2">
            <label for="file"
                   class="block text-sm font-medium text-slate-700">{{ ('valide.'~process.label~'.fichier.label')|trans({}, 'process') }}
                <i class="fal fa-question-circle ml-1"
                   data-controller="tooltip"
                   data-tooltip-placement-value="bottom"
                   aria-label="{{ ('valide.'~process.label~'.helps.fichier.help')|trans({}, 'process') }}"
                   data-bs-original-title="{{ ('valide.'~process.label~'.helps.fichier.help')|trans({}, 'process') }}"></i></label>
            <input type="file" name="file" id="file" accept="application/pdf"
                   class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 file:mr-3 file:rounded file:border-0 file:bg-slate-100 file:px-3 file:py-1 file:text-sm file:font-medium hover:file:bg-slate-200">
        </div>

        <div class="space-y-2">
            {% if historique.complements is defined and historique.complements.fichier is defined %}
                <a
                        href="{{ path('app_upload_download', {context: 'conseils', filename: historique.complements.fichier, originalName: historique.complements.fichier_original|default(historique.complements.fichier)}) }}"
                        target="_blank"
                        class="inline-flex items-center gap-2 rounded-md border border-cyan-300 bg-cyan-50 px-3 py-2 text-sm font-medium text-cyan-700 hover:bg-cyan-100"
                        data-bs-toggle="tooltip"
                        data-bs-placement="bottom"
                        title="{{ 'voir.le.pv.infobulle'|trans({}, 'process') }}"
                >
                    <i class="{{ iconDownload }}"></i>
                    <span> {{ 'voir.le.pv'|trans({}, 'process') }}</span>
                </a>
            {% else %}
                <span class="inline-flex items-center rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm font-medium text-amber-700">Pas de PV déposé</span>
            {% endif %}
        </div>

        <div class="md:col-span-2 flex items-start gap-2 rounded-md border border-slate-200 bg-slate-50 p-3">
            <input class="mt-0.5 h-4 w-4 rounded border-slate-300 text-amber-600 focus:ring-amber-500" type="checkbox"
                   value="laisserPasser" id="laisserPasser"
                   name="laisserPasser">
            <label class="text-sm text-slate-700" for="laisserPasser">
                {{ ('valide.'~process.label~'.helps.laisserPasser.texte')|trans({}, 'process') }}
                <i
                        class="fal fa-question-circle ml-1"
                        data-controller="tooltip"
                        data-tooltip-placement-value="bottom"
                        aria-label="{{ ('valide.'~process.label~'.helps.laisserPasser.help')|trans({}, 'process') }}"
                        data-bs-original-title="{{ ('valide.'~process.label~'.helps.laisserPasser.help')|trans({}, 'process') }}"></i>
            </label>
        </div>
    {% endif %}

    </div>


    <div class="pt-1">
        <button type="submit"
                class="inline-flex items-center gap-2 rounded-md border border-emerald-600 bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700"
                {{ stimulus_action('base','sauvegardeFormModal', 'click') }}
{#                data-action="live#emit"#}
{#                data-event="valide"#}
        >
            <i class="fal fa-floppy-disk"></i>
            {{ ('btn.'~process.label~'.valide')|trans({}, 'process') }}
        </button>
    </div>
</form>
