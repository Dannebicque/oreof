<h2 class="text-2xl font-bold mb-6">
    {% if formation is defined %}
        {{ formation.display }}
    {% elseif ficheMatiere is defined %}
        {{ ficheMatiere.libelle }}
    {% else %}
        -Erreur-
    {% endif %}
</h2>

{% for histo in historiques %}
    {#    {% if #}
    {#        histo.etape == 'laisserPasser' or #}
    {#        histo.complements.sousReserveModifications is defined or #}
    {#        histo.complements.sousReserveConseil is defined %} #}
    {#        {% set color='amber' %} #}
    {#        {% set borderColor='border-amber-500' %} #}
    {#        {% set textColor='text-amber-600' %} #}
    {#        {% set bgColor='bg-amber-100' %} #}
    {#    {% endif %} #}

    <div class="flex items-start gap-3 mb-4 p-4 rounded-lg border {{ borderColor|default('border-slate-200') }}"
            {{ stimulus_controller('historique') }}
            {{ stimulus_target('historique', 'entreeHistorique') }}
    >
        <div class="shrink-0">
            <twig:IconBox
                    :icon="histo.etape|etapeIcone(type)"
                    :variant="histo|etapeVariant"
            />
        </div>

        <div class="grow min-w-0">
            <div class="flex flex-col lg:flex-row lg:items-start gap-4">
                <div class="grow">
                    {% if histo|isParcours and type=='formation' %}
                        <span class="font-bold block mb-2">Parcours : {{ histo.parcours.libelle }}</span>
                    {% endif %}

                    <div class="flex items-center leading-relaxed mb-3">
                        {% if histo.etape == 'change_rf' %}
                            Changement du responsable de formation : {{ histo.complements.ancien }} &rarr; {{ histo.complements.nouveau }}
                        {% elseif histo.etape == 'change_rf_co' %}
                            Changement du co-responsable de formation : {{ histo.complements.ancien }} &rarr; {{ histo.complements.nouveau }}
                        {% elseif histo.etape == 'laisserPasser' %}
                            {{ ('historique.laisserPasser.conseil')|trans(histo|etapeParams(type), 'process') }}
                        {% else %}
                            {{ ('historique.'~histo.etape|etapeLabel(type))|trans(histo|etapeParams(type), 'process') }}
                        {% endif %}
                    </div>

                    <div class="flex flex-wrap gap-2 mb-2">
                        {% if histo.complements.sousReserveModifications is defined %}
                            <span class="inline-block px-2.5 py-1 rounded-full text-xs font-medium bg-amber-200 text-amber-800">Sous réserve de modifications</span>
                        {% endif %}
                        {% if histo.complements.sousReserveConseil is defined %}
                            <span class="inline-block px-2.5 py-1 rounded-full text-xs font-medium bg-amber-200 text-amber-800">Sous réserve de validation du conseil</span>
                        {% endif %}
                        {% if histo.etat == 'laisserPasser' %}
                            <span class="inline-block px-2.5 py-1 rounded-full text-xs font-medium bg-amber-200 text-amber-800">Laissez-passer demandé</span>
                        {% endif %}
                        {% if histo.etat == 'force_admin' %}
                            <span class="inline-block px-2.5 py-1 rounded-full text-xs font-medium bg-amber-200 text-amber-800">{{ 'historique.force_admin.badge'|trans({}, 'process') }}</span>
                        {% endif %}
                    </div>

                    <p class="text-sm text-gray-600">par : {{ histo.user.display }}</p>
                </div>

                {% if is_granted('ROLE_ADMIN') %}
                    <div class="flex gap-2 shrink-0">
                        {% if histo.etape == 'cfvu' or histo.etape == 'conseil' or histo.etape == 'soumis_cfvu' or histo.etape == 'soumis_conseil' %}
                            <twig:Button
                                    variant="warning"
                                    size="sm"
                                    tooltip="Modifier l'historique"
                                    extraClass="px-2"
                                    dataAction="click->modalturbo#open"
                                    href="{{ path('app_historique_edit', {
                                        historique: histo.id
                                    }) }}"
                                    icon="icon:edit"
                            >
                            </twig:Button>
                        {% endif %}
                        {#                        {{ stimulus_action('historique', 'delete', 'click', { #}
                        {#                            url: path('app_historique_delete', {historique: histo.id}), #}
                        {#                            csrf: csrf_token('delete' ~ histo.id) #}
                        {#                        }) }} #}
                        <twig:Button
                                variant="danger"
                                href="{{ path('app_historique_delete', {historique: histo.id}) }}"
                                size="sm"
                                tooltip="{{ 'supprimer.historique'|trans({}, 'process') }}"
                                extraClass="px-2"
                                icon="icon:delete"
                                dataAction="click->historique#delete"
                        ></twig:Button>
                    </div>
                {% endif %}

                <div class="text-sm text-gray-500 shrink-0 whitespace-nowrap">{{ histo.created|date('d/m/Y H:i') }}</div>
            </div>

            {% if histo.commentaire is defined or histo.complements.fichier is defined or (histo.changeRf is defined and histo.changeRf != null) %}
                <div class="mt-3 pt-3 border-t border-gray-200 space-y-2">
                    {% if histo.changeRf is defined and histo.changeRf != null %}
                        <p class="text-xs text-gray-600">
                            {% if histo.changeRf.typeRf.value == 'RF' %}
                                Changement du responsable de formation : {{ histo.changeRf.ancienResponsable != null ? histo.changeRf.ancienResponsable.display : 'Pas de responsable' }} &rarr; {{ histo.changeRf.nouveauResponsable != null ? histo.changeRf.nouveauResponsable.display : 'Pas de responsable' }}
                            {% elseif histo.changeRf.typeRf.value == 'CORF' %}
                                Changement du co-responsable de formation : {{ histo.changeRf.ancienResponsable != null ? histo.changeRf.ancienResponsable.display : 'Pas de co-responsable' }} &rarr; {{ histo.changeRf.nouveauResponsable != null ? histo.changeRf.nouveauResponsable.display : 'Pas de co-responsable' }}
                            {% else %}
                                -
                            {% endif %}
                        </p>
                    {% endif %}
                    {% if histo.commentaire is defined %}
                        <div class="text-sm text-gray-700">
                            {{ histo.commentaire|raw }}
                        </div>
                    {% endif %}
                    {% if histo.complements.fichier is defined %}
                        {% if histo.etape == 'change_rf' or histo.etape == 'change_co_rf' %}
                            <p>
                                <twig:Button
                                        href="{{ asset('uploads/change_rf/pv/'~histo.complements.fichier) }}"
                                        variant="info"
                                        size="sm"
                                        icon="icon:download"
                                        label="Voir le PV du conseil"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        :centered="false"
                                />
                            </p>
                        {% else %}
                            <p>
                                <twig:Button
                                        href="{{ path('app_upload_download', {context: 'conseils', filename: histo.complements.fichier, originalName: histo.complements.fichier_original|default(histo.complements.fichier)}) }}"
                                        variant="info"
                                        size="sm"
                                        icon="icon:download"
                                        label="Voir le PV du conseil"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        :centered="false"
                                />
                            </p>
                        {% endif %}
                    {% endif %}
                </div>
            {% endif %}

        </div>
    </div>
{% else %}
    {{ component('alerte', {
        'type': 'warning',
        'message': 'Aucune validation pour cette formation.'
    }) }}
{% endfor %}
