<div class="space-y-6" {{ stimulus_controller('accessibility') }}>
    <p class="text-sm text-slate-600 dark:text-slate-300">
        Ces reglages sont appliques immediatement et memorises sur cet appareil.
    </p>

    <section class="space-y-2">
        <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Theme</h3>
        <div class="grid grid-cols-1 gap-2 sm:grid-cols-3">
            <button type="button"
                    class="app-modal-footer-btn app-modal-footer-btn--secondary justify-center"
                    data-action="click->accessibility#setTheme"
                    data-accessibility-theme-param="system">
                Systeme
            </button>
            <button type="button"
                    class="app-modal-footer-btn app-modal-footer-btn--secondary justify-center"
                    data-action="click->accessibility#setTheme"
                    data-accessibility-theme-param="light">
                Clair
            </button>
            <button type="button"
                    class="app-modal-footer-btn app-modal-footer-btn--secondary justify-center"
                    data-action="click->accessibility#setTheme"
                    data-accessibility-theme-param="dark">
                Sombre
            </button>
        </div>
    </section>

    <section class="space-y-2">
        <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Police</h3>
        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
            <button type="button"
                    class="app-modal-footer-btn app-modal-footer-btn--secondary justify-center"
                    data-action="click->accessibility#setFont"
                    data-accessibility-font-param="default">
                Police standard
            </button>
            <button type="button"
                    class="app-modal-footer-btn app-modal-footer-btn--secondary justify-center"
                    data-action="click->accessibility#setFont"
                    data-accessibility-font-param="dys">
                Police dyslexie
            </button>
        </div>
    </section>

    <section class="space-y-2">
        <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Taille du texte</h3>
        <div class="grid grid-cols-1 gap-2 sm:grid-cols-3">
            <button type="button"
                    class="app-modal-footer-btn app-modal-footer-btn--secondary justify-center"
                    data-action="click->accessibility#setSize"
                    data-accessibility-size-param="normal">
                Standard
            </button>
            <button type="button"
                    class="app-modal-footer-btn app-modal-footer-btn--secondary justify-center"
                    data-action="click->accessibility#setSize"
                    data-accessibility-size-param="large">
                Grande
            </button>
            <button type="button"
                    class="app-modal-footer-btn app-modal-footer-btn--secondary justify-center"
                    data-action="click->accessibility#setSize"
                    data-accessibility-size-param="xlarge">
                Tres grande
            </button>
        </div>
    </section>

    <section class="space-y-3">
        <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Lisibilite</h3>
        <label class="flex items-center justify-between gap-3 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-800/60">
            <span class="font-medium text-slate-700 dark:text-slate-200">Mode haut contraste</span>
            <input type="checkbox"
                   class="h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500"
                   data-accessibility-target="contrast"
                   data-action="change->accessibility#toggleContrast">
        </label>
        <label class="flex items-center justify-between gap-3 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-800/60">
            <span class="font-medium text-slate-700 dark:text-slate-200">Reduire les animations</span>
            <input type="checkbox"
                   class="h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500"
                   data-accessibility-target="motion"
                   data-action="change->accessibility#toggleMotion">
        </label>
    </section>

    <div class="flex items-center justify-between gap-3 border-t border-slate-200 pt-4 dark:border-slate-700">
        <p class="text-xs text-slate-500 dark:text-slate-400">Vous pouvez revenir aux reglages par defaut a tout
            moment.</p>
        <button type="button"
                class="app-modal-footer-btn app-modal-footer-btn--secondary"
                data-action="click->accessibility#reset">
            Reinitialiser
        </button>
    </div>
</div>

