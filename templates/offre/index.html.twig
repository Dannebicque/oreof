{% extends 'base.html.twig' %}

{% set header_title %}
    Configuration de l'offre {{ user_data.campagneCollecte.libelle }}
{% endset %}

{% block content %}
    <section
            class="space-y-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900 sm:p-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div class="space-y-1">
                <h2 class="text-sm font-black uppercase tracking-widest text-slate-500 dark:text-slate-400">
                    Pilotage de l'offre
                </h2>
                <p class="max-w-3xl text-sm text-slate-600 dark:text-slate-300">
                    Ajustez les etats de reconduction et les capacites d'accueil pour la campagne en cours.
                </p>
            </div>

            <div class="inline-flex items-center rounded-full border border-cyan-200 bg-cyan-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-cyan-800 dark:border-cyan-800 dark:bg-cyan-950/30 dark:text-cyan-200">
                {{ user_data.campagneCollecte.libelle }}
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-slate-50/60 p-3 dark:border-slate-700 dark:bg-slate-950/30 sm:p-4">
            <turbo-frame id="offre_table">
                {% include 'offre/_table.html.twig' %}
            </turbo-frame>
        </div>
    </section>
{% endblock %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        { title: 'Pilotage' }
    ]}) }}
{% endblock %}
