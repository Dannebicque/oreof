<div class="space-y-4" {{ stimulus_controller('structure--formation', {
    url: path('app_parcours_formation_detail'),
}) }}>
    {% set sort = params.sort is defined ? params.sort : 'typeDiplome' %}
    {% set direction = params.direction is defined ? params.direction : 'asc' %}
    {% set isGranted = is_granted('ROLE_ADMIN') or is_granted('SHOW', {route: 'app_etablissement', subject: 'etablissement'}) or isCfvu %}

    {# Compter les filtres actifs #}
    {% set activeFilters = 0 %}
    {% if is_granted('ROLE_ADMIN') %}
        {% if params['composantePorteuse'] is defined and params['composantePorteuse'] %}
            {% set activeFilters = activeFilters + 1 %}
        {% endif %}
        {% if params['typeDiplome'] is defined and params['typeDiplome'] %}
            {% set activeFilters = activeFilters + 1 %}
        {% endif %}
        {% if params['mention'] is defined and params['mention'] %}
            {% set activeFilters = activeFilters + 1 %}
        {% endif %}
        {% if params['responsable'] is defined and params['responsable'] %}
            {% set activeFilters = activeFilters + 1 %}
        {% endif %}
        {% if params['remplissage'] is defined and params['remplissage'] and params['remplissage'] != 'all' %}
            {% set activeFilters = activeFilters + 1 %}
        {% endif %}
    {% endif %}

    {# En-tête avec résumé #}
    <div class="space-y-3">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="rounded-2xl border border-cyan-200 bg-cyan-50 px-4 py-3 text-sm text-cyan-900 dark:border-cyan-800 dark:bg-cyan-950/30 dark:text-cyan-100">
                <div class="flex flex-wrap items-center gap-2">
                    <span><strong>{{ nbFormations }}</strong> formation{{ nbFormations > 1 ? 's' : '' }} trouvée{{ nbFormations > 1 ? 's' : '' }}</span>
                    <span class="text-xs opacity-75">•</span>
                    <span><strong>{{ nbParcours }}</strong> parcours</span>

                    {% if activeFilters > 0 %}
                        <span class="text-xs opacity-75">•</span>
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-cyan-200 px-2.5 py-1 text-xs font-semibold dark:bg-cyan-900">
                            {{ ux_icon('icon:filter', {class: 'h-3.5 w-3.5'}) }}
                            {{ activeFilters }} filtre{{ activeFilters > 1 ? 's' : '' }} actif{{ activeFilters > 1 ? 's' : '' }}
                        </span>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {% if is_granted('ROLE_ADMIN') %}
        {% embed 'components/filter_panel.html.twig' with {
            title: 'Filtres',
            activeFilters: activeFilters,
            fieldsTitle: 'Filtres avancés',
            collapsible: true,
            collapsedByDefault: true
        } %}
            {% block search %}
                <label for="filter-quick-search" class="sr-only">Recherche rapide</label>
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-slate-400">
                        {{ ux_icon('icon:search', {class: 'h-4 w-4'}) }}
                    </span>
                    <input type="text"
                           id="filter-quick-search"
                           class="w-full rounded-lg border border-slate-300 bg-white py-2 pl-9 pr-3 text-sm text-slate-700 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 dark:placeholder:text-slate-400"
                           placeholder="Rechercher une formation, mention, sigle..."
                           value="{{ params.q|default('') }}"
                            {{ stimulus_action('crud', 'rechercher', 'keyup') }}>
                </div>
            {% endblock %}

            {% block actions %}
                <button type="button"
                        class="inline-flex items-center gap-2 rounded-lg border border-red-200 bg-white px-3 py-2 text-xs font-semibold text-red-600 shadow-sm transition hover:border-red-400 hover:text-red-900 dark:border-red-600 dark:bg-red-900/30 dark:text-red-200 dark:hover:border-red-500"
                        {{ stimulus_action('crud', 'effaceFiltre', 'click', {}) }}>
                    {{ ux_icon('icon:sync', {class: 'h-4 w-4'}) }}
                    Reinitialiser
                </button>

                {% if collapsible|default(false) %}
                    <label for="{{ toggleId }}"
                           class="inline-flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 shadow-sm transition hover:border-slate-300 hover:text-slate-900 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white"
                           title="Afficher/masquer les filtres"
                           aria-label="Afficher ou masquer les filtres">
                        {{ ux_icon('icon:filter', {class: 'h-4 w-4'}) }}
                        Filtres
                        {% if activeFilters > 0 %}
                            <span class="inline-flex min-w-5 items-center justify-center rounded-full bg-indigo-600 px-1.5 py-0.5 text-[10px] font-bold text-white dark:bg-indigo-500">
                                {{ activeFilters }}
                            </span>
                        {% endif %}
                    </label>
                {% else %}
                    <span class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 shadow-sm dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200">
                        {{ ux_icon('icon:filter', {class: 'h-4 w-4'}) }}
                        Filtres
                        {% if activeFilters > 0 %}
                            <span class="inline-flex min-w-5 items-center justify-center rounded-full bg-indigo-600 px-1.5 py-0.5 text-[10px] font-bold text-white dark:bg-indigo-500">
                                {{ activeFilters }}
                            </span>
                        {% endif %}
                    </span>
                {% endif %}
            {% endblock %}

            {% block fields %}
                <div>
                    <label for="filter-mention"
                           class="mb-1 block text-xs font-semibold text-slate-600 dark:text-slate-300">Mention</label>
                    <select id="filter-mention"
                            class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                            {{ stimulus_action('crud', 'filter', 'change', {'field': 'mention'}) }}
                            {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}>
                        <option value="">Toutes les mentions</option>
                        {% for mention in mentions %}
                            <option value="{{ mention.id }}"
                                    {% if params['mention'] is defined and params['mention'] == mention.id %}selected{% endif %}>{{ mention.libelle }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label for="filter-composante"
                           class="mb-1 block text-xs font-semibold text-slate-600 dark:text-slate-300">Composante</label>
                    <select id="filter-composante"
                            class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                            {{ stimulus_action('crud', 'filter', 'change', {'field': 'composantePorteuse'}) }}
                            {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}>
                        <option value="">Toutes les composantes</option>
                        {% for composante in composantes %}
                            <option value="{{ composante.id }}"
                                    {% if params['composantePorteuse'] is defined and params['composantePorteuse'] == composante.id %}selected{% endif %}>{{ composante.libelle }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label for="filter-type_formation"
                           class="mb-1 block text-xs font-semibold text-slate-600 dark:text-slate-300">Type de
                        diplome</label>
                    <select id="filter-type_formation"
                            class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                            {{ stimulus_action('crud', 'filter', 'change', {'field': 'typeDiplome'}) }}
                            {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}>
                        <option value="">Tous les types</option>
                        {% for type in typeDiplomes %}
                            <option value="{{ type.id }}"
                                    {% if params['typeDiplome'] is defined and params['typeDiplome'] == type.id %}selected{% endif %}>{{ type.libelle }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label for="filter-responsable"
                           class="mb-1 block text-xs font-semibold text-slate-600 dark:text-slate-300">Responsable</label>
                    <select id="filter-responsable"
                            class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                            {{ stimulus_action('crud', 'filter', 'change', {'field': 'responsable'}) }}
                            {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}>
                        <option value="">Tous les responsables</option>
                        {% for responsable in responsables %}
                            <option value="{{ responsable.id }}"
                                    {% if params['responsable'] is defined and params['responsable'] == responsable.id %}selected{% endif %}>{{ responsable.display }}</option>
                        {% endfor %}
                    </select>
                </div>

                {% if not isCfvu %}
                    <div>
                        <label for="filter-remplissage"
                               class="mb-1 block text-xs font-semibold text-slate-600 dark:text-slate-300">Remplissage</label>
                        <select id="filter-remplissage"
                                class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                                {{ stimulus_action('crud', 'filter', 'change', {'field': 'remplissage'}) }}>
                            <option value="all">Tous</option>
                            <option value="0"
                                    {% if params['remplissage'] is defined and params['remplissage'] == 0 %}selected{% endif %}>
                                Non complete
                            </option>
                            <option value="100"
                                    {% if params['remplissage'] is defined and params['remplissage'] == 100 %}selected{% endif %}>
                                Complet
                            </option>
                        </select>
                    </div>
                {% endif %}
            {% endblock %}
        {% endembed %}
    {% endif %}

    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
        <div class="overflow-x-auto">
            <table class="min-w-full text-sm text-slate-700 dark:text-slate-200">
                <thead class="bg-slate-50 text-left text-xs font-black uppercase tracking-wider text-slate-500 dark:bg-slate-800/70 dark:text-slate-300">
                <tr>
                    <th class="px-4 py-3 w-1/4">
                        <a href="#" class="inline-flex items-center gap-1 hover:text-slate-900 dark:hover:text-white"
                                {{ stimulus_action('crud', 'sort', 'click', {
                                    'sort': 'mention',
                                    'direction': getDirection('mention', sort, direction)
                                }) }}>
                            Formation {{ displaySort('mention', sort, direction) }}
                        </a>
                    </th>
                    <th class="px-4 py-3 w-1/5">
                        <a href="#" class="inline-flex items-center gap-1 hover:text-slate-900 dark:hover:text-white"
                                {{ stimulus_action('crud', 'sort', 'click', {
                                    'sort': 'composantePorteuse',
                                    'direction': getDirection('composantePorteuse', sort, direction)
                                }) }}>
                            Composante {{ displaySort('composantePorteuse', sort, direction) }}
                        </a>
                    </th>
                    <th class="px-4 py-3 text-center w-1/6">Etat</th>
                    <th class="px-4 py-3 w-1/5">Remplissage</th>
                    <th class="px-4 py-3 text-right w-1/6">Actions</th>
                </tr>
                </thead>

                <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                {% for formation in formations %}
                    {% set remplissage = params['remplissage']|default('all') %}
                    {% if remplissage == '100' and formation.remplissage.calcul == 100 or remplissage == '0' and formation.remplissage.calcul < 100 or remplissage == 'all' %}
                        <tr class="align-top hover:bg-slate-50/70 dark:hover:bg-slate-800/40">
                            {# Colonne Formation (cliquable = action rapide pour voir détails) #}
                            <td class="px-4 py-3">
                                <div class="space-y-1">
                                    <button type="button"
                                            class="group inline-flex w-full items-center justify-between gap-2 text-left"
                                            aria-expanded="false"
                                            data-formation-toggle-id="{{ formation.id }}"
                                            {{ stimulus_action('structure--formation', 'afficherParcours', 'click', {formation:formation.id}) }}>
                                        <span class="font-semibold text-slate-900 group-hover:text-indigo-600 dark:text-white dark:group-hover:text-indigo-400">
                                            {% if formation.mention != null or formation.mentionTexte != null %}
                                                {{ formation.display }}
                                            {% else %}
                                                <span class="inline-flex rounded-full border border-rose-300 bg-rose-50 px-2 py-0.5 text-xs font-semibold text-rose-700 dark:border-rose-700 dark:bg-rose-950/30 dark:text-rose-300">Non définie</span>
                                            {% endif %}
                                        </span>
                                        <span data-formation-toggle-icon
                                              class="text-slate-400 transition-transform duration-200">
                                            {{ ux_icon('icon:chevron-right', {class: 'h-3 w-3'}) }}
                                        </span>
                                    </button>

                                    <div class="text-xs text-slate-500 dark:text-slate-400">
                                        <span class="inline-flex rounded-full border border-cyan-300 bg-cyan-50 px-2.5 py-0.5 font-semibold text-cyan-700 dark:border-cyan-700 dark:bg-cyan-950/30 dark:text-cyan-300">
                                            {{ formation.typeDiplome|typeDiplome }}
                                        </span>
                                        {% if formation.parcours|length > 0 %}
                                            <span class="ml-2 text-xs">{{ formation.parcours|length }} parcours</span>
                                        {% endif %}
                                    </div>

                                    <button type="button"
                                            class="inline-flex items-center gap-1 pt-1 text-xs text-indigo-600 hover:text-indigo-700 dark:text-indigo-300 dark:hover:text-indigo-200"
                                            aria-expanded="false"
                                            data-formation-toggle-id="{{ formation.id }}"
                                            data-open-label="Masquer les parcours"
                                            data-closed-label="Voir les parcours"
                                            {{ stimulus_action('structure--formation', 'afficherParcours', 'click', {formation:formation.id}) }}>
                                        <span data-formation-toggle-icon class="transition-transform duration-200">
                                            {{ ux_icon('icon:chevron-right', {class: 'h-3 w-3'}) }}
                                        </span>
                                        <span data-formation-toggle-label>Voir les parcours</span>
                                    </button>
                                </div>
                            </td>

                            {# Colonne Composante #}
                            <td class="px-4 py-3">
                                {% if formation.composantePorteuse != null %}
                                    <div class="text-sm">{{ formation.composantePorteuse.libelle }}</div>
                                    {% if formation.responsableMention != null %}
                                        <div class="text-xs text-slate-500 dark:text-slate-400 mt-1">{{ formation.responsableMention.display }}</div>
                                    {% endif %}
                                {% else %}
                                    <span class="inline-flex rounded-full border border-rose-300 bg-rose-50 px-2 py-0.5 text-xs font-semibold text-rose-700 dark:border-rose-700 dark:bg-rose-950/30 dark:text-rose-300">Non définie</span>
                                {% endif %}
                            </td>

                            {# Colonne État (mise en avant) #}
                            <td class="px-4 py-3 text-center">
                                <div class="flex items-center justify-center">
                                    {{ component('formation_state', {
                                        process: process,
                                        formation: formation,
                                        class: 'flex items-center justify-center'}) }}
                                </div>
                            </td>

                            {# Colonne Remplissage #}
                            <td class="px-4 py-3">{{ component('remplissage_progress', { value: formation.remplissage }) }}</td>

                            {# Colonne Actions - Menu contextuel #}
                            <td class="px-4 py-3 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    {% set canAccess = (is_granted('EDIT', {route: 'app_formation', subject: formation})
                                        or is_granted('EDIT', {route: 'app_composante', subject: formation})
                                        or is_granted('EDIT', {route: 'app_etablissement', subject: formation})
                                        or is_granted('ROLE_ADMIN')) %}

                                    {% set canEdit = (formation.hasParcours == true and isOuvert(formation)) or (formation.hasParcours == false and formation.parcours[0] and isOuvert(formation.parcours[0].dpeParcours[0])) %}
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="{{ path('formation_v2_voir',{'slug': formation.slug}) }}"
                                           class="app-btn app-btn-info text-xs"
                                           target="_blank"
                                           title="Voir la formation">
                                            {{ ux_icon('icon:info', {class: 'h-4 w-4'}) }}
                                            <span>Voir</span>
                                        </a>

                                        {{ component('dropdown_actions', {
                                            label: 'Actions',
                                            help: 'Actions disponibles pour cette formation',
                                            icon: 'icon:ellipsis-vertical',
                                            items: [
                                                { label: 'Vérifier la saisie',
                                                    icon: 'icon:check',
                                                    help: 'Vérifie que la formation est complète et prête à être publiée.',
                                                    modal: true,
                                                    url:path('app_formation_state', {slug:formation.slug}) },
                                                {
                                                    label: 'Modifier',
                                                    icon: 'icon:edit',
                                                    color: 'primary',
                                                    url: path('formation_v2_modifier', {slug:formation.slug}),
                                                    disabled: not (canEdit and canAccess),
                                                    help: not (canEdit and canAccess) ? 'Modification non autorisée : la formation doit être ouverte et avoir au moins un parcours avec un DPE ouvert.' : null
                                                },
                                                { label: 'Supprimer',
                                                    icon: 'icon:delete',
                                                    color: 'danger',
                                                    modal: true,
                                                    url:path('app_formation_delete',{'id': formation.id}),
                                                    csrf: csrf_token('delete' ~ formation.id),
                                                    disabled: not is_granted('ROLE_ADMIN'),
                                                    help: not is_granted('ROLE_ADMIN') ? 'Suppression réservée aux administrateurs.' : null}
                                            ]
                                        }) }}
                                </div>
                                </div>
                            </td>
                        </tr>
                        <template id="detailParcours_{{ formation.id }}"></template>
                    {% endif %}
                {% else %}
                    <tr>
                        <td colspan="5"
                            class="px-4 py-16 text-center">
                            {{ include('_ui/_empty_table.html.twig', {
                                message: 'Aucune donnée à afficher'
                            }) }}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
