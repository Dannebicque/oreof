<div class="space-y-4" {{ stimulus_controller('structure--formation', {
    url: path('app_parcours_formation_detail'),
}) }}>
    {% set sort = params.sort is defined ? params.sort : 'typeDiplome' %}
    {% set direction = params.direction is defined ? params.direction : 'asc' %}
    {% set isGranted = is_granted('ROLE_ADMIN') or is_granted('SHOW', {route: 'app_etablissement', subject: 'etablissement'}) or isCfvu %}

    <div class="rounded-2xl border border-cyan-200 bg-cyan-50 px-4 py-3 text-sm text-cyan-900 dark:border-cyan-800 dark:bg-cyan-950/30 dark:text-cyan-100">
        <strong>{{ nbFormations }}</strong> formation{{ nbFormations > 1 ? 's' : '' }}
        trouvée{{ nbFormations > 1 ? 's' : '' }}, et <strong>{{ nbParcours }}</strong> parcours.
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
        <div class="overflow-x-auto">
            <table class="min-w-full text-sm text-slate-700 dark:text-slate-200">
                <thead class="bg-slate-50 text-left text-xs font-black uppercase tracking-wider text-slate-500 dark:bg-slate-800/70 dark:text-slate-300">
                <tr>
                    <th class="px-4 py-3">
                        <a href="#" class="inline-flex items-center gap-1 hover:text-slate-900 dark:hover:text-white"
                                {{ stimulus_action('crud', 'sort', 'click', {
                                    'sort': 'composantePorteuse',
                                    'direction': getDirection('composantePorteuse', sort, direction)
                                }) }}>
                            Composante {{ displaySort('composantePorteuse', sort, direction) }}
                        </a>
                    </th>
                    <th class="px-4 py-3">
                        <a href="#" class="inline-flex items-center gap-1 hover:text-slate-900 dark:hover:text-white"
                                {{ stimulus_action('crud', 'sort', 'click', {
                                    'sort': 'typeDiplome',
                                    'direction': getDirection('typeDiplome', sort, direction)
                                }) }}>
                            Type de formation {{ displaySort('typeDiplome', sort, direction) }}
                        </a>
                    </th>
                    <th class="px-4 py-3">
                        <a href="#" class="inline-flex items-center gap-1 hover:text-slate-900 dark:hover:text-white"
                                {{ stimulus_action('crud', 'sort', 'click', {
                                    'sort': 'mention',
                                    'direction': getDirection('mention', sort, direction)
                                }) }}>
                            Mention/spécialité {{ displaySort('mention', sort, direction) }}
                        </a>
                    </th>
                    <th class="px-4 py-3">Resp. Mention</th>
                    <th class="px-4 py-3">Nb. Parcours</th>
                    <th class="px-4 py-3">Etat</th>
                    <th class="px-4 py-3">Remplissage</th>
                    <th class="px-4 py-3 text-right">Actions</th>
                </tr>
                {% if is_granted('ROLE_ADMIN') %}
                    <tr class="border-t border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-900">
                        <th class="px-4 py-3">
                            <label for="filter-composante" class="sr-only">Composante</label>
                            <select id="filter-composante"
                                    class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                                    {{ stimulus_action('crud', 'filter', 'change', {'field': 'composantePorteuse'}) }}
                                    {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}>
                                <option value="">Toutes les composantes</option>
                                {% for composante in composantes %}
                                    <option value="{{ composante.id }}"
                                            {% if params['composantePorteuse'] is defined and params['composantePorteuse'] == composante.id %}selected{% endif %}>{{ composante.libelle }}</option>
                                {% endfor %}
                            </select>
                        </th>
                        <th class="px-4 py-3">
                            <label for="filter-type_formation" class="sr-only">Type formation</label>
                            <select id="filter-type_formation"
                                    class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                                    {{ stimulus_action('crud', 'filter', 'change', {'field': 'typeDiplome'}) }}
                                    {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}>
                                <option value="">Tous les types de formation</option>
                                {% for type in typeDiplomes %}
                                    <option value="{{ type.id }}"
                                            {% if params['typeDiplome'] is defined and params['typeDiplome'] == type.id %}selected{% endif %}>{{ type.libelle }}</option>
                                {% endfor %}
                            </select>
                        </th>
                        <th class="px-4 py-3">
                            <label for="filter-mention" class="sr-only">Mention</label>
                            <select id="filter-mention"
                                    class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                                    {{ stimulus_action('crud', 'filter', 'change', {'field': 'mention'}) }}
                                    {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}>
                                <option value="">Toutes les mentions</option>
                                {% for mention in mentions %}
                                    <option value="{{ mention.id }}"
                                            {% if params['mention'] is defined and params['mention'] == mention.id %}selected{% endif %}>{{ mention.libelle }}</option>
                                {% endfor %}
                            </select>
                        </th>
                        <th class="px-4 py-3">
                            <label for="filter-responsable" class="sr-only">Responsable</label>
                            <select id="filter-responsable"
                                    class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                                    {{ stimulus_action('crud', 'filter', 'change', {'field': 'responsable'}) }}
                                    {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}>
                                <option value="">Tous les responsables</option>
                                {% for responsable in responsables %}
                                    <option value="{{ responsable.id }}"
                                            {% if params['responsable'] is defined and params['responsable'] == responsable.id %}selected{% endif %}>{{ responsable.display }}</option>
                                {% endfor %}
                            </select>
                        </th>
                        <th class="px-4 py-3"></th>
                        <th class="px-4 py-3"></th>
                        <th class="px-4 py-3">
                            {% if not isCfvu %}
                                <label for="filter-remplissage" class="sr-only">Remplissage</label>
                                <select id="filter-remplissage"
                                        class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                                        {{ stimulus_action('crud', 'filter', 'change', {'field': 'remplissage'}) }}>
                                    <option value="all">Tous</option>
                                    <option value="0"
                                            {% if params['remplissage'] is defined and params['remplissage'] == 0 %}selected{% endif %}>
                                        Non complété
                                    </option>
                                    <option value="100"
                                            {% if params['remplissage'] is defined and params['remplissage'] == 100 %}selected{% endif %}>
                                        Complet
                                    </option>
                                </select>
                            {% endif %}
                        </th>
                        <th class="px-4 py-3 text-right">
                            <button class="app-btn app-btn-danger" {{ stimulus_action('crud', 'effaceFiltre', 'click', {}) }}>
                                Effacer les filtres
                            </button>
                        </th>
                    </tr>
                {% endif %}
                </thead>

                <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                {% for formation in formations %}
                    {% set remplissage = params['remplissage']|default('all') %}
                    {% if remplissage == '100' and formation.remplissage.calcul == 100 or remplissage == '0' and formation.remplissage.calcul < 100 or remplissage == 'all' %}
                        <tr class="align-top hover:bg-slate-50/70 dark:hover:bg-slate-800/40">
                            <td class="px-4 py-3">
                                {% if formation.composantePorteuse != null %}
                                    {{ formation.composantePorteuse.libelle }}
                                {% else %}
                                    <span class="inline-flex rounded-full border border-rose-300 bg-rose-50 px-2 py-0.5 text-xs font-semibold text-rose-700 dark:border-rose-700 dark:bg-rose-950/30 dark:text-rose-300">Non définie</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">{{ formation.typeDiplome|typeDiplome }}</td>
                            <td class="px-4 py-3">
                                {% if formation.mention != null or formation.mentionTexte != null %}
                                    {{ formation.display }}
                                {% else %}
                                    <span class="inline-flex rounded-full border border-rose-300 bg-rose-50 px-2 py-0.5 text-xs font-semibold text-rose-700 dark:border-rose-700 dark:bg-rose-950/30 dark:text-rose-300">Non définie</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                {% if formation.responsableMention != null %}
                                    {{ formation.responsableMention.display }}
                                {% else %}
                                    <span class="inline-flex rounded-full border border-rose-300 bg-rose-50 px-2 py-0.5 text-xs font-semibold text-rose-700 dark:border-rose-700 dark:bg-rose-950/30 dark:text-rose-300">Non définie</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                {% if formation.hasParcours %}
                                    <span class="inline-flex rounded-full border border-cyan-300 bg-cyan-50 px-2 py-0.5 text-xs font-semibold text-cyan-700 dark:border-cyan-700 dark:bg-cyan-950/30 dark:text-cyan-300">{{ formation.parcours|length }}</span>
                                {% else %}
                                    <span class="inline-flex rounded-full border border-cyan-300 bg-cyan-50 px-2 py-0.5 text-xs font-semibold text-cyan-700 dark:border-cyan-700 dark:bg-cyan-950/30 dark:text-cyan-300">N.C.</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-center">
                                    {{ component('formation_state', {
                                        process: process,
                                        formation: formation,
                                        class: 'flex items-center justify-center'}) }}
                                </div>
                            </td>
                            <td class="px-4 py-3">{{ component('remplissage_progress', { value: formation.remplissage }) }}</td>
                            <td class="px-4 py-3 text-right">
                                <div class="flex flex-wrap justify-end gap-2">
                                    <button class="app-btn app-btn-primary"
                                            {{ stimulus_action('structure--formation', 'afficherParcours', 'click', {formation:formation.id}) }}>
                                        <i class="fal fa-caret-right"></i>
                                        <span>Voir les détails</span>
                                    </button>

                                    <a href="{{ path('formation_v2_voir',{'slug': formation.slug}) }}"
                                       class="app-btn app-btn-info"
                                       title="Voir une formation"
                                       target="_blank">
                                        <i class="{{ iconShow }}"></i>
                                        <span>Voir</span>
                                    </a>

                                    <a href="#"
                                       class="app-btn app-btn-success"
                                            {{ stimulus_controller('modal', {
                                                size: 'lg',
                                                modalTitle: 'Vérifier la saisie',
                                                modalUrl: path('app_formation_state', {formation:formation.id}) }) }}
                                       data-action="click->modal#openModal"
                                       data-size="lg"
                                       title="Vérifier la saisie">
                                        <i class="fal fa-binoculars"></i>
                                        <span>Vérifier</span>
                                    </a>

                                    {% if formation.hasParcours == true %}
                                        {% if (is_granted('EDIT', {route: 'app_formation', subject: formation})
                                            or is_granted('EDIT', {route: 'app_composante', subject: formation})
                                            or is_granted('EDIT', {route: 'app_etablissement', subject: formation})
                                            or is_granted('ROLE_ADMIN')) and isOuvert(formation) %}
                                            <a href="{{ path('formation_v2_modifier', {slug:formation.slug}) }}"
                                               class="app-btn app-btn-warning"
                                               title="Modifier le DPE">
                                                <i class="{{ iconEdit }}"></i>
                                                <span>Modifier</span>
                                            </a>
                                        {% endif %}
                                    {% else %}
                                        {% if (is_granted('EDIT', {route: 'app_formation', subject: formation})
                                            or is_granted('EDIT', {route: 'app_composante', subject: formation})
                                            or is_granted('EDIT', {route: 'app_etablissement', subject: formation})
                                            or is_granted('ROLE_ADMIN')) and isOuvert(formation.parcours[0].dpeParcours[0]) %}
                                            <a href="{{ path('formation_v2_modifier', {slug:formation.slug}) }}"
                                               class="app-btn app-btn-warning"
                                               title="Modifier le DPE">
                                                <i class="{{ iconEdit }}"></i>
                                                <span>Modifier</span>
                                            </a>
                                        {% endif %}
                                    {% endif %}

                                    {% if is_granted('ROLE_ADMIN') %}
                                        <a href="#" class="app-btn app-btn-danger"
                                                {{ stimulus_action('crud', 'delete', 'click', {
                                                    url:path('app_formation_delete',{'id': formation.id}),
                                                    csrf: csrf_token('delete' ~ formation.id)
                                                }) }}>
                                            <i class="{{ iconDelete }}"></i>
                                            <span>Supprimer</span>
                                        </a>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        <template id="detailParcours_{{ formation.id }}"></template>
                    {% endif %}
                {% else %}
                    <tr>
                        <td colspan="8"
                            class="px-4 py-6 text-center text-sm font-medium text-amber-700 dark:text-amber-300">
                            Aucun enregistrement trouvé
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
