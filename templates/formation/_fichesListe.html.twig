{# todo: reprendre cette page comme le bilan des formations pour le SES, DPE ou Admin avec état, remplissage et
bouton pour valider/invalide les étapes successives #}
<div class="space-y-4" {{ stimulus_controller('structure--formation') }}>
    {% set sort = params.sort is defined ? params.sort : 'typeDiplome' %}
    {% set direction = params.direction is defined ? params.direction : 'asc' %}

    <div class="rounded-2xl border border-cyan-200 bg-cyan-50 px-4 py-3 text-sm text-cyan-900 dark:border-cyan-800 dark:bg-cyan-950/30 dark:text-cyan-100">
        <strong>{{ formations|length }}</strong> formation{{ formations|length > 1 ? 's' : '' }}
        trouvée{{ formations|length > 1 ? 's' : '' }}.
        Utilisez les filtres ci-dessous pour limiter le volume affiché.
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
        <div class="overflow-x-auto">
            <table class="min-w-full text-sm text-slate-700 dark:text-slate-200">
                <thead class="bg-slate-50 text-left text-xs font-black uppercase tracking-wider text-slate-500 dark:bg-slate-800/70 dark:text-slate-300">
                <tr>
                    <th class="px-4 py-3">
                        <a href="#" class="inline-flex items-center gap-1 hover:text-slate-900 dark:hover:text-white"
                                {{ stimulus_action('crud', 'sort', 'click', {
                                    'sort': 'composantePorteuse',
                                    'direction': getDirection('composantePorteuse', sort, direction)
                                }) }}
                        >
                            Composante {{ displaySort('composantePorteuse', sort, direction) }}
                        </a>
                    </th>
                    <th class="px-4 py-3">
                        <a href="#" class="inline-flex items-center gap-1 hover:text-slate-900 dark:hover:text-white"
                                {{ stimulus_action('crud', 'sort', 'click', {
                                    'sort': 'typeDiplome',
                                    'direction': getDirection('typeDiplome', sort, direction)
                                }) }}
                        >
                            Type de formation {{ displaySort('typeDiplome', sort, direction) }}
                        </a>
                    </th>
                    <th class="px-4 py-3">
                        <a href="#" class="inline-flex items-center gap-1 hover:text-slate-900 dark:hover:text-white"
                                {{ stimulus_action('crud', 'sort', 'click', {
                                    'sort': 'mention',
                                    'direction': getDirection('mention', sort, direction)
                                }) }}
                        >
                            Mention / spécialité {{ displaySort('mention', sort, direction) }}
                        </a>
                    </th>
                    <th class="px-4 py-3 text-center">En cours<br>rédaction</th>
                    <th class="px-4 py-3 text-center">État de remplissage<br><span class="normal-case tracking-normal">(complètes / total)</span>
                    </th>
                    <th class="px-4 py-3 text-center">En attente<br>validation RP / RF / DPE</th>
                    <th class="px-4 py-3 text-center">En attente<br>validation SES</th>
                    <th class="px-4 py-3 text-center">Fiches validées</th>
                    <th class="px-4 py-3 text-center">Publiées</th>
                    <th class="px-4 py-3 text-right">Actions</th>
                </tr>
                {% if is_granted('ROLE_ADMIN') or is_granted('SHOW', {route: 'app_etablissement', subject: 'etablissement'}) %}
                    <tr class="border-t border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-900">
                        <th class="px-4 py-3 align-top">
                            <label for="filter-composante" class="sr-only">Composante</label>
                            <select
                                    id="filter-composante"
                                    class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                                    {{ stimulus_action('crud', 'filter', 'change', {'field': 'composantePorteuse'}) }}
                                    {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}>
                                <option value="">Toutes les composantes</option>
                                {% for composante in composantes %}
                                    <option value="{{ composante.id }}"
                                            {% if params['composantePorteuse'] is defined and params['composantePorteuse'] == composante.id %}selected{% endif %}>{{ composante.libelle }}</option>
                                {% endfor %}
                            </select>
                        </th>
                        <th class="px-4 py-3 align-top">
                            <label for="filter-type_formation" class="sr-only">Type de formation</label>
                            <select
                                    id="filter-type_formation"
                                    class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                                    {{ stimulus_action('crud', 'filter', 'change', {'field': 'typeDiplome'}) }}
                                    {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}>
                                <option value="">Tous les types de formation</option>
                                {% for type in typeDiplomes %}
                                    <option value="{{ type.id }}"
                                            {% if params['typeDiplome'] is defined and params['typeDiplome'] == type.id %}selected{% endif %}>{{ type.libelle }}</option>
                                {% endfor %}
                            </select>
                        </th>
                        <th class="px-4 py-3 align-top">
                            <label for="filter-mention" class="sr-only">Mention</label>
                            <select
                                    id="filter-mention"
                                    class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                                    {{ stimulus_action('crud', 'filter', 'change', {'field': 'mention'}) }}
                                    {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}>
                                <option value="">Toutes les mentions</option>
                                {% for mention in mentions %}
                                    <option value="{{ mention.id }}"
                                            {% if params['mention'] is defined and params['mention'] == mention.id %}selected{% endif %}>{{ mention.libelle }}</option>
                                {% endfor %}
                            </select>
                        </th>
                        <th class="px-4 py-3"></th>
                        <th class="px-4 py-3"></th>
                        <th class="px-4 py-3"></th>
                        <th class="px-4 py-3"></th>
                        <th class="px-4 py-3"></th>
                        <th class="px-4 py-3"></th>
                        <th class="px-4 py-3 text-right align-top">
                            <button class="app-btn app-btn-danger" {{ stimulus_action('crud', 'effaceFiltre', 'click') }}>
                                Effacer les filtres
                            </button>
                        </th>
                    </tr>
                {% endif %}
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                {% for formation in formations %}
                    {% if (params['remplissage'] is defined and formation.remplissage.calcul == params['remplissage']) or params['remplissage'] is not defined %}
                        <tr class="align-top hover:bg-slate-50/70 dark:hover:bg-slate-800/40">
                            <td class="px-4 py-3">
                                {% if formation.composantePorteuse != null %}
                                    {{ formation.composantePorteuse.libelle }}
                                {% else %}
                                    <span class="inline-flex rounded-full border border-rose-300 bg-rose-50 px-2 py-0.5 text-xs font-semibold text-rose-700 dark:border-rose-700 dark:bg-rose-950/30 dark:text-rose-300">Non définie</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">{{ formation.typeDiplome|typeDiplome }}</td>
                            <td class="px-4 py-3">
                                {% if formation.mention != null or formation.mentionTexte != null %}
                                    {{ formation.display }}
                                {% else %}
                                    <span class="inline-flex rounded-full border border-rose-300 bg-rose-50 px-2 py-0.5 text-xs font-semibold text-rose-700 dark:border-rose-700 dark:bg-rose-950/30 dark:text-rose-300">Non définie</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-flex min-w-10 justify-center rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-xs font-semibold text-slate-700 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200">{{ stats[formation.id].stats.nbEnCoursRedaction }}</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-flex min-w-16 justify-center rounded-full border border-cyan-300 bg-cyan-50 px-2 py-0.5 text-xs font-semibold text-cyan-700 dark:border-cyan-700 dark:bg-cyan-950/30 dark:text-cyan-300">{{ stats[formation.id].stats.nbFichesCompletes }} / {{ stats[formation.id].stats.nbFiches }}</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-flex min-w-10 justify-center rounded-full border border-amber-300 bg-amber-50 px-2 py-0.5 text-xs font-semibold text-amber-700 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-300">{{ stats[formation.id].stats.nbFichesNonValidees }}</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-flex min-w-10 justify-center rounded-full border border-orange-300 bg-orange-50 px-2 py-0.5 text-xs font-semibold text-orange-700 dark:border-orange-700 dark:bg-orange-950/30 dark:text-orange-300">{{ stats[formation.id].stats.nbFichesNonValideesSes }}</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-flex min-w-10 justify-center rounded-full border border-emerald-300 bg-emerald-50 px-2 py-0.5 text-xs font-semibold text-emerald-700 dark:border-emerald-700 dark:bg-emerald-950/30 dark:text-emerald-300">{{ stats[formation.id].stats.nbFichesValidees }}</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-flex min-w-10 justify-center rounded-full border border-indigo-300 bg-indigo-50 px-2 py-0.5 text-xs font-semibold text-indigo-700 dark:border-indigo-700 dark:bg-indigo-950/30 dark:text-indigo-300">{{ stats[formation.id].stats.nbFichesPubliees }}</span>
                            </td>
                            <td class="px-4 py-3 text-right">
                                <a
                                        href="{{ path('fiche_matiere_valide_formation', {formation: formation.id}) }}"
                                        class="app-btn app-btn-success"
                                        title="Voir les fiches"
                                >
                                    <i class="fas fa-check"></i>
                                    <span>Voir les fiches</span>
                                </a>
                            </td>
                        </tr>
                    {% endif %}
                {% else %}
                    <tr>
                        <td colspan="10"
                            class="px-4 py-6 text-center text-sm font-medium text-amber-700 dark:text-amber-300">
                            Aucun enregistrement trouvé
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
