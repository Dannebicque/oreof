<tr id="parcours_{{ formation.id }}" class="bg-slate-50/60 dark:bg-slate-900/40">
    <td colspan="5" class="p-0">
        <div class="border-l-4 border-cyan-500/70 bg-slate-50/80 p-4 dark:border-cyan-600/70 dark:bg-slate-900/60">
            {% set nbParcoursTotal = formation.hasParcours ? formation.parcours|filter(parcours => parcours.formation.hasParcours)|length : (formation.parcours|length > 0 ? 1 : 0) %}
            {% set nbParcoursNonOuverts = 0 %}
            {% if formation.hasParcours %}
                {% for parcours in formation.parcours|filter(parcours => parcours.formation.hasParcours) %}
                    {% if dpesParcours[parcours.id].isNonOuvert %}
                        {% set nbParcoursNonOuverts = nbParcoursNonOuverts + 1 %}
                    {% endif %}
                {% endfor %}
            {% elseif formation.parcours|length > 0 %}
                {% set parcours = formation.parcours[0] %}
                {% if dpesParcours[parcours.id].isNonOuvert or formation.isNonOuvert %}
                    {% set nbParcoursNonOuverts = 1 %}
                {% endif %}
            {% endif %}
            {% set nbParcoursOuverts = nbParcoursTotal - nbParcoursNonOuverts %}

            <div class="mb-3 rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-sm dark:border-slate-700 dark:bg-slate-900">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                    <p class="text-sm font-semibold text-slate-800 dark:text-slate-100">
                        Parcours de <span class="text-indigo-700 dark:text-indigo-300">{{ formation.display }}</span>
                    </p>
                    <div class="flex flex-wrap items-center gap-2 text-xs">
                        <span class="inline-flex items-center rounded-full border border-slate-300 bg-slate-100 px-2.5 py-1 font-semibold text-slate-700 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200">
                            {{ nbParcoursTotal }} parcours
                        </span>
                        <span class="inline-flex items-center rounded-full border border-emerald-300 bg-emerald-50 px-2.5 py-1 font-semibold text-emerald-700 dark:border-emerald-700 dark:bg-emerald-950/30 dark:text-emerald-300">
                            {{ nbParcoursOuverts }} ouvert{{ nbParcoursOuverts > 1 ? 's' : '' }}
                        </span>
                        <span class="inline-flex items-center rounded-full border border-amber-300 bg-amber-50 px-2.5 py-1 font-semibold text-amber-700 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-300">
                            {{ nbParcoursNonOuverts }} non ouvert{{ nbParcoursNonOuverts > 1 ? 's' : '' }}
                        </span>
                    </div>
                </div>
            </div>

            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
                <div class="overflow-x-auto">
                    <table class="min-w-full text-sm text-slate-700 dark:text-slate-200">
                        <thead class="bg-slate-50 text-left text-xs font-black uppercase tracking-wider text-slate-500 dark:bg-slate-800/70 dark:text-slate-300">
                        <tr>
                            <th class="sticky top-0 z-10 bg-slate-50 px-4 py-3 dark:bg-slate-800">Parcours</th>
                            <th class="sticky top-0 z-10 bg-slate-50 px-4 py-3 dark:bg-slate-800">Lieu</th>
                            <th class="sticky top-0 z-10 bg-slate-50 px-4 py-3 dark:bg-slate-800">Etat</th>
                            <th class="sticky top-0 z-10 bg-slate-50 px-4 py-3 dark:bg-slate-800">BCC</th>
                            <th class="sticky top-0 z-10 bg-slate-50 px-4 py-3 dark:bg-slate-800">MCCC</th>
                            <th class="sticky top-0 z-10 bg-slate-50 px-4 py-3 dark:bg-slate-800">Conseil</th>
                            <th class="sticky top-0 z-10 bg-slate-50 px-4 py-3 dark:bg-slate-800">Remplissage</th>
                            <th class="sticky top-0 z-10 bg-slate-50 px-4 py-3 text-right dark:bg-slate-800">Actions
                            </th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                        {% if formation.hasParcours %}
                            {% for parcours in formation.parcours|filter(parcours => parcours.formation.hasParcours) %}
                                <tr class="align-top hover:bg-slate-50/70 dark:hover:bg-slate-800/40">
                                    <td class="px-4 py-3">
                                        <div>
                                            <span>{{ parcours.libelle }}</span>
                                            {{ parcours.typeParcours|badgeTypeParcours }}
                                        </div>
                                        <div class="mt-1 text-xs text-slate-500 dark:text-slate-400">
                                            RP: {{ parcours.respParcours != null ? parcours.respParcours.display : 'Non défini' }}
                                        </div>
                                    </td>
                                    <td class="px-4 py-3">{{ parcours.localisation != null ? parcours.localisation.libelle : 'Non défini' }}</td>
                                    {% if dpesParcours[parcours.id].isNonOuvert %}
                                        <td colspan="5" class="px-4 py-3">
                                            <span class="inline-flex w-full items-center justify-center rounded-lg border border-amber-300 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-300">Parcours non ouvert</span>
                                        </td>
                                    {% else %}
                                        <td class="px-4 py-3">{{ dpesParcours[parcours.id].etatValidation|badgeDpe }}</td>
                                        <td class="px-4 py-3">{{ parcours.etatStep(3)|badgeStep }}</td>
                                        <td class="px-4 py-3">{{ parcours.etatStep(4)|badgeStep }}</td>
                                        <td class="px-4 py-3">{{ component('historique_pv', {parcours:parcours}) }}</td>
                                        <td class="px-4 py-3">{{ component('remplissage_progress', { value: parcours.remplissage }) }}</td>
                                    {% endif %}
                                    <td class="px-4 py-3 text-right">
                                        <div class="flex items-center justify-end gap-2">
                                            <a href="{{ path('parcours_v2_voir',{'parcours': parcours.id}) }}"
                                               class="app-btn app-btn-info text-xs"
                                               target="_blank"
                                               title="Voir le parcours">
                                                {{ ux_icon('icon:info', {class: 'h-4 w-4'}) }}
                                                <span>Voir</span>
                                            </a>

                                            {{ component('dropdown_actions', {
                                                label: 'Actions',
                                                help: 'Actions disponibles pour ce parcours',
                                                icon: 'icon:ellipsis-vertical',
                                                items: [
                                                    {
                                                        label: 'Vérifier la saisie',
                                                        icon: 'icon:check',
                                                        modal: true,
                                                        url: path('app_parcours_state', {parcours: parcours.id})
                                                    },
                                                    {
                                                        label: 'Modifier',
                                                        icon: 'icon:edit',
                                                        color: 'primary',
                                                        url: path('parcours_v2_modifier', {'parcours': parcours.id}),
                                                        disabled: not is_granted('EDIT', {route: 'app_parcours', subject:  dpesParcours[parcours.id]})
                                                    },
                                                    {
                                                        label: 'Supprimer',
                                                        icon: 'icon:delete',
                                                        color: 'danger',
                                                        url: path('app_parcours_delete', {'id': parcours.id, csrf: csrf_token('delete' ~ parcours.id)}),
                                                        disabled: not is_granted('ROLE_ADMIN')
                                                    }
                                                ]
                                            }) }}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            {% if formation.parcours|length == 0 %}
                                <tr>
                                    <td colspan="8" class="px-4 py-4">
                                        <span class="inline-flex w-full items-center justify-center rounded-lg border border-amber-300 bg-amber-50 px-3 py-2 text-sm font-semibold text-amber-800 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-300">
                                            Formation non initialisée, pas de parcours ou de parcours par défaut.
                                        </span>
                                    </td>
                                </tr>
                            {% else %}
                                {% set parcours = formation.parcours[0] %}
                                <tr class="align-top hover:bg-slate-50/70 dark:hover:bg-slate-800/40">
                                    <td class="px-4 py-3">
                                        <div>{{ formation.display }}</div>
                                        <div class="mt-1 text-xs text-slate-500 dark:text-slate-400">
                                            RP: {{ formation.responsableMention != null ? formation.responsableMention.display : 'Non défini' }}
                                        </div>
                                    </td>
                                    <td class="px-4 py-3">{{ formation.localisationMention != null and formation.localisationMention|length >= 1 ? formation.localisationMention[0].libelle : 'Non défini' }}</td>
                                    {% if dpesParcours[parcours.id].isNonOuvert or formation.isNonOuvert %}
                                        <td colspan="5" class="px-4 py-3">
                                            <span class="inline-flex w-full items-center justify-center rounded-lg border border-amber-300 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-300">Parcours non ouvert</span>
                                        </td>
                                    {% else %}
                                        <td class="px-4 py-3">{{ dpesParcours[parcours.id].etatValidation|badgeDpe }}</td>
                                        <td class="px-4 py-3">{{ parcours.etatStep(3)|badgeStep }}</td>
                                        <td class="px-4 py-3">{{ parcours.etatStep(4)|badgeStep }}</td>
                                        <td class="px-4 py-3">{{ component('historique_pv', {parcours:parcours}) }}</td>
                                        <td class="px-4 py-3">{{ component('remplissage_progress', { value: parcours.remplissage }) }}</td>
                                    {% endif %}
                                    <td class="px-4 py-3 text-right">
                                        <div class="flex items-center justify-end gap-2">
                                            <a href="{{ path('formation_v2_voir',{'slug': formation.slug}) }}"
                                               class="app-btn app-btn-info text-xs"
                                               title="Voir la formation"
                                               target="_blank">
                                                {{ ux_icon('icon:info', {class: 'h-4 w-4'}) }}
                                                <span>Voir</span>
                                            </a>

                                            {{ component('dropdown_actions', {
                                                label: 'Actions',
                                                help: 'Actions disponibles pour cette formation',
                                                icon: 'icon:ellipsis-vertical',
                                                items: [
                                                    {
                                                        label: 'Vérifier la saisie',
                                                        icon: 'icon:check',
                                                        modal: true,
                                                        url: path('app_formation_state', {formation: formation.id})
                                                    },
                                                    {
                                                        label: 'Modifier',
                                                        icon: 'icon:edit',
                                                        color: 'primary',
                                                        url: path('formation_v2_modifier', {'slug': formation.slug}),
                                                        disabled: not (is_granted('EDIT', {route: 'app_formation', subject: formation}) or is_granted('EDIT', {route: 'app_parcours', subject: formation.parcours[0]}))
                                                    }
                                                ]
                                            }) }}

                                            {% if is_granted('CAN_FORMATION_DELETE_MY') or is_granted('ROLE_ADMIN') %}
                                                <button class="app-btn app-btn-danger text-xs"
                                                        {{ stimulus_action('crud', 'delete', 'click', {
                                                            url:path('app_formation_delete',{'id': formation.id}),
                                                            csrf: csrf_token('delete' ~ formation.id)
                                                        }) }}>
                                                    {{ ux_icon('icon:delete', {class: 'h-4 w-4'}) }}
                                                    <span>Supprimer</span>
                                                </button>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endif %}
                        {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </td>
</tr>
