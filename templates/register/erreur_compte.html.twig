{% extends 'base-speciale.html.twig' %}

{% block title %}Compte non autorise | {{ product_name }}{% endblock %}

{% block content %}
    {% set contactMail = mail_contact|default('oreof@univ-reims.fr') %}
    {% set emailValue = user and user.email ? user.email : 'email inconnu' %}

    <div class="space-y-6">
        <div class="space-y-2">
            <p class="inline-flex items-center rounded-full bg-red-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-red-700">
                Demande d'acces
            </p>
            <h2 class="text-3xl font-black leading-tight text-slate-900">Domaine interdit</h2>
            <p class="text-sm text-slate-500">La demande ne peut etre traitee que pour les adresses institutionnelles
                URCA.</p>
        </div>

        {{ component('alerte', {
            type: 'danger',
            message: 'Votre demande n\'a pas pu aboutir. L\'adresse <strong>' ~ emailValue ~ '</strong> n\'est pas un email URCA (@univ-reims.fr).'
        }) }}

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700 dark:border-slate-700 dark:bg-slate-900/50 dark:text-slate-300">
            <p>En cas de besoin, merci de contacter l'administrateur : {{ contactMail|mailto }}.</p>
        </div>

        <twig:Button
                href="{{ path('app_login') }}"
                variant="primary"
                :soft="false"
                :outline="false"
                icon="icon:login"
                label="Connectez-vous"
                extraClass="w-full justify-center"
        />
    </div>
{% endblock %}
