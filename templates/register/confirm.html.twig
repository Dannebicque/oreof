{% extends 'base-speciale.html.twig' %}

{% block title %}Confirmation de demande | {{ product_name }}{% endblock %}

{% block content %}
    <div class="space-y-6">
        <div class="space-y-2">
            <p class="inline-flex items-center rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-emerald-700">
                Demande d'acces
            </p>
            <h2 class="text-3xl font-black leading-tight text-slate-900">Demande prise en compte</h2>
            <p class="text-sm text-slate-500">Votre demande a ete enregistree et transmise aux personnes
                responsables.</p>
        </div>

        {{ component('alerte', {
            type: 'success',
            message: '<strong>' ~ user.display ~ '</strong>, votre demande est en cours de validation. Vous recevrez un email de confirmation quand vos acces seront ouverts.'
        }) }}

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700 dark:border-slate-700 dark:bg-slate-900/50 dark:text-slate-300">
            <p>La demande a ete transmise au responsable DPE de votre composante ainsi qu'a l'administrateur du
                site.</p>
            <p class="mt-2">Le traitement est effectue dans les plus brefs delais.</p>
        </div>

        <twig:Button
                href="{{ path('app_login') }}"
                variant="primary"
                :soft="false"
                :outline="false"
                icon="icon:login"
                label="Retour a la connexion"
                extraClass="w-full justify-center"
        />
    </div>
{% endblock %}
