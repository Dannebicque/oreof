{% extends 'base-speciale.html.twig' %}

{% block title %}Compte deja existant | {{ product_name }}{% endblock %}

{% block content %}
    {% set contactMail = mail_contact|default('oreof@univ-reims.fr') %}

    <div class="space-y-6">
        <div class="space-y-2">
            <p class="inline-flex items-center rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-amber-700">
                Demande d'acces
            </p>
            <h2 class="text-3xl font-black leading-tight text-slate-900">Un compte existe deja</h2>
            <p class="text-sm text-slate-500">Nous avons detecte un compte associe a cet email, ou un email inconnu dans
                l'annuaire.</p>
        </div>

        {% if user != null %}
            {{ component('alerte', {
                type: 'warning',
                message: '<strong>' ~ user.display ~ '</strong>, un compte semble deja present pour cet email : <strong>' ~ user.email ~ '</strong>.'
            }) }}
        {% else %}
            {{ component('alerte', {
                type: 'warning',
                message: 'Aucun compte ne correspond a cet email : <strong>' ~ email ~ '</strong>.'
            }) }}
        {% endif %}

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700 dark:border-slate-700 dark:bg-slate-900/50 dark:text-slate-300">
            <p>Si vous n'etes pas a l'origine de cette demande, merci de contacter l'administrateur
                : {{ contactMail|mailto }}.</p>
        </div>

        <twig:Button
                href="{{ path('app_login') }}"
                variant="primary"
                :soft="false"
                :outline="false"
                icon="icon:login"
                label="Connectez-vous"
                extraClass="w-full justify-center"
        />
    </div>
{% endblock %}
