{% extends 'base.html.twig' %}

{% set header_title %}
    Gestion des validations DPE
{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        {title: 'Pilotage'},
        {title: 'Gestion des validations DPE'},
    ]}) }}
{% endblock %}

{% block content %}
    {% set toneMap = {
        'info': {
            'badge': 'border-cyan-200 bg-cyan-50 text-cyan-700 dark:border-cyan-700 dark:bg-cyan-950/30 dark:text-cyan-200',
        },
        'success': {
            'badge': 'border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-700 dark:bg-emerald-950/30 dark:text-emerald-200',
        },
        'warning': {
            'badge': 'border-amber-200 bg-amber-50 text-amber-700 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-200',
        },
        'danger': {
            'badge': 'border-rose-200 bg-rose-50 text-rose-700 dark:border-rose-700 dark:bg-rose-950/30 dark:text-rose-200',
        },
        'secondary': {
            'badge': 'border-slate-200 bg-slate-50 text-slate-700 dark:border-slate-700 dark:bg-slate-950/30 dark:text-slate-200',
        },
    } %}

    <section
            class="space-y-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900 sm:p-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div class="space-y-1">
                <h2 class="text-sm font-black uppercase tracking-widest text-slate-500 dark:text-slate-400">
                    Gestion des validations DPE
                </h2>
                <p class="max-w-3xl text-sm text-slate-600 dark:text-slate-300">
                    Ouvrez une étape pour charger dynamiquement la liste des parcours concernés.
                </p>
            </div>

            <div class="inline-flex items-center rounded-full border border-cyan-200 bg-cyan-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-cyan-800 dark:border-cyan-800 dark:bg-cyan-950/30 dark:text-cyan-200">
                {{ steps|length }} étapes
            </div>
        </div>

        <div class="space-y-3">
            {% for value, step in steps %}
                {% set tone = toneMap[step.color] ?? toneMap['secondary'] %}
                {% set statistiquesStep = statistiques[value] is defined ? statistiques[value] : null %}
                {% set hasData = statistiquesStep is not null and (statistiquesStep.formations|length > 0 or statistiquesStep.nbParcours > 0) %}

                <div {{ stimulus_controller('load_content', {url: path('app_validation_dpe_liste', {
                    typeValidation: value,
                    composante: 'all'
                })}) }}>
                    <div class="rounded-xl border border-slate-200 bg-slate-50/80 p-4 shadow-sm transition hover:border-slate-300 dark:border-slate-700 dark:bg-slate-950/30 dark:hover:border-slate-600 sm:p-5">
                        <div class="grid grid-cols-1 gap-4 lg:grid-cols-12 lg:items-center">
                            <div class="lg:col-span-4">
                                <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500">
                                    Étape</p>
                                <p class="mt-1 text-base font-semibold text-slate-800 dark:text-slate-100">
                                    {{ value|trans({}, 'process') }}
                                </p>
                            </div>

                            <div class="lg:col-span-4">
                                <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500">
                                    Nb formations / parcours</p>
                                <div class="mt-1">
                                    {% if hasData %}
                                        <div class="flex flex-wrap items-center gap-2 text-sm text-slate-700 dark:text-slate-200">
                                            <span class="inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold {{ tone.badge }}">
                                                Formations : {{ statistiquesStep.formations|length }}
                                            </span>
                                            <span class="inline-flex rounded-full border px-2.5 py-1 text-xs font-semibold {{ tone.badge }}">
                                                Parcours : {{ statistiquesStep.nbParcours }}
                                            </span>
                                        </div>
                                    {% else %}
                                        <span class="inline-flex rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700 dark:border-emerald-700 dark:bg-emerald-950/30 dark:text-emerald-200">
                                            Aucun
                                        </span>
                                    {% endif %}
                                </div>
                            </div>

                            <div class="lg:col-span-4 lg:flex lg:justify-end">
                                <twig:Button
                                        label="Détails"
                                        variant="primary"
                                        size="sm"
                                        icon="icon:chevron-right"
                                        :disabled="not hasData"
                                        dataAction="click->load-content#change"
                                        data-load-content-value-param="{{ value }}"
                                />
                            </div>
                        </div>
                    </div>

                    <div {{ stimulus_target('load_content', 'content') }} class="mt-3"></div>
                </div>
            {% endfor %}
        </div>
    </section>

{% endblock %}

