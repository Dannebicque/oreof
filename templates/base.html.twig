<!-- modal delete -->
<div class="modal fade"
     tabindex="-1"
     aria-hidden="true"
     id="modal-delete"
>
    <div class="modal-dialog">
        <div class="modal-content app-modal-content app-surface">
            <div class="modal-header app-modal-header">
                <h5 class="modal-title">Confirmer la suppression</h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Close">
                    <twig:UX:Icon name="icon:close" class="w-5 h-5"/>
                </button>
            </div>
            <div class="modal-body">
                Confirmer la suppression de l'élément sélectionné.
            </div>
            <div class="modal-footer app-modal-footer">
                <button type="button" class="btn btn-info app-btn app-btn-neutral"
                        data-bs-dismiss="modal">
                    Annuler
                </button>
                <button type="button" class="btn btn-danger app-btn app-btn-danger"
                        id="btn-confirm-supprimer"
                        data-bs-dismiss="modal">
                    Confirmer la suppression définitive
                </button>
            </div>
        </div>
    </div>
</div>

<!-- modal confirm -->
<div class="modal fade"
     tabindex="-1"
     aria-hidden="true"
     id="modal-confirm"
>
    <div class="modal-dialog">
        <div class="modal-content app-modal-content app-surface">
            <div class="modal-header app-modal-header">
                <h5 class="modal-title" id="modal-confirm-title">Confirmer la suppression</h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Close">
                    <twig:UX:Icon name="icon:close" class="w-5 h-5"/>
                </button>
            </div>
            <div class="modal-body" id="modal-confirm-body">
                Confirmer la suppression de l'élément sélectionné.
            </div>
            <div class="modal-footer app-modal-footer">
                <button type="button" class="btn btn-info app-btn app-btn-neutral"
                        data-bs-dismiss="modal">
                    Annuler
                </button>
                <button type="button" class="btn btn-danger app-btn app-btn-danger"
                        id="btn-confirm-valide"
                        data-bs-dismiss="modal">
                    Confirmer
                </button>
            </div>
        </div>
    </div>
</div>

