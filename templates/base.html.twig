<!DOCTYPE html>
<html lang="fr" data-footer="true" data-placement="horizontal" data-behaviour="pinned" data-theme="light">
<head>
    <meta charset="UTF-8">
    <title> {{ header_title|default('Titre par défaut') }} - {{ product_name }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1"/>
    <script>
      (function () {
        const savedTheme = localStorage.getItem('oreof-theme')
        let accessibility = null

        try {
          accessibility = JSON.parse(localStorage.getItem('oreof-a11y') || 'null')
        } catch (e) {
          accessibility = null
        }

        const preferredTheme = accessibility && accessibility.theme ? accessibility.theme : null
        const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches
        const themeFromPref = preferredTheme === 'system' ? null : preferredTheme
        const theme = (themeFromPref === 'dark' || themeFromPref === 'light')
          ? themeFromPref
          : ((savedTheme === 'dark' || savedTheme === 'light') ? savedTheme : (prefersDark ? 'dark' : 'light'))

        document.documentElement.setAttribute('data-theme', theme)

        if (accessibility) {
          document.documentElement.setAttribute('data-a11y-font', accessibility.font || 'default')
          document.documentElement.setAttribute('data-a11y-size', accessibility.size || 'normal')
          document.documentElement.setAttribute('data-a11y-contrast', accessibility.contrast ? 'high' : 'normal')
          document.documentElement.setAttribute('data-a11y-motion', accessibility.motion ? 'reduced' : 'normal')
        }
      })()
    </script>
    <link rel="preconnect" href="https://fonts.gstatic.com"/>
    <style>
        .markdown-body img, .markdown-body .ratio {
            max-width: 100%;
            height: auto;
            border-radius: 4px;
        }

        @media (min-width: 992px) {
            .markdown-body img, .markdown-body .ratio {
                max-width: 60%;
            }

            .offcanvas .markdown-body img, .offcanvas .markdown-body .ratio {
                max-width: 100%;
            }
        }

        .markdown-body iframe {
            border-radius: 4px;
        }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap"
          rel="stylesheet"/>
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        {% block legacy_stylesheets %}
            {#                        {{ encore_entry_link_tags('legacy') }} #}
        {% endblock %}
    {% endblock %}

    {% block javascripts %}
        {#            {% block importmap %}{{ importmap('app') }}{% endblock %} #}
        <script>
          window.toasts = {{ app.session.flashbag.get('toast')|json_encode|raw }};
        </script>
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>
<body
        data-controller="modalturbo"
>
