                        {#                        <button type="button" #}
                        {#                                class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-600 transition hover:border-slate-300 hover:text-slate-900 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-slate-500" #}
                        {#                                data-bs-toggle="modal" #}
                        {#                                data-bs-target="#modalUsageDonnees"> #}
                        {#                           #}
                        {#                        </button> #}
                        <a href="{{ path('app_document') }}"
