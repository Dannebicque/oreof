                   aria-expanded="false">
                    <div class="name d-md-none">
                        {{ app.user.display }}
                    </div>
                    {{ include('communs/_avatar.html.twig', {user:app.user, size:'sm'}) }}
                </a>
                <div class="dropdown-menu dropdown-menu-end user-menu wide">
                    <div class="row mb-3 ms-0 me-0">
