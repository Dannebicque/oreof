<!DOCTYPE html>
<html lang="fr" data-footer="true" data-placement="horizontal" data-behaviour="pinned" data-theme="light">
<head>
    <meta charset="UTF-8">
    <title>{{ block('header')|striptags }} - {{ product_name }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1"/>
    <script>
      (function () {
        const savedTheme = localStorage.getItem('oreof-theme')
        const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches
        const theme = (savedTheme === 'dark' || savedTheme === 'light') ? savedTheme : (prefersDark ? 'dark' : 'light')
        document.documentElement.setAttribute('data-theme', theme)
      })()
    </script>
    <link rel="preconnect" href="https://fonts.gstatic.com"/>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap"
          rel="stylesheet"/>
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        {% block legacy_stylesheets %}
            {#                        {{ encore_entry_link_tags('legacy') }} #}
        {% endblock %}
    {% endblock %}

    {% block javascripts %}
        {#            {% block importmap %}{{ importmap('app') }}{% endblock %} #}
        <script>
          window.toasts = {{ app.session.flashbag.get('toast')|json_encode|raw }};
        </script>
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>
