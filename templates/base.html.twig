                                        <a href="{{ path('i18n_toggle_keys') }}">
                                            {{ app.session.get('i18n_keys') ? '🔤 Mode clés: ON' : '🔤 Mode clés: OFF' }}
                                        </a>
                                    </li>
                                {% endif %}
                                <li>
                                    <a href="{{ path('app_user_mes_informations') }}">Mes informations</a>
                                </li>
                                <li>
                                    <a href="{{ path('app_user_mes_notifications') }}">Mes notifications</a>
                                </li>
                                <li>
                                    <a href="#"
