{# templates/help/index.html.twig #}
{# Debug template vidé #}
{% extends 'base.html.twig' %}
{% block header %}Centre d'aide{% endblock %}
{% block breadcrumb %}
    <ul class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_homepage') }}">Accueil</a></li>
        <li class="breadcrumb-item active" aria-current="page">Aide</li>
    </ul>
{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <div class="mb-4 input-group">
                        <span class="input-group-text bg-white"><i class="fal fa-search text-muted"></i></span>
                        <input type="text" id="helpSearch" class="form-control form-control-lg" placeholder="Rechercher un tutoriel ou une aide..." onkeyup="filterHelps()">
                    </div>

                    <div class="helps-container d-flex flex-column" id="helpsList">
                        {% for help in helps %}
                            <details class="help-item mb-3 bg-light border rounded" data-title="{{ help.title|default('')|lower }} {{ help.routeSlug|lower }}" style="transition: all 0.2s ease;">
                                <summary class="h5 mb-0 p-3" style="cursor: pointer; list-style: none;">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div>
                                            <i class="fal fa-info-circle text-info me-2"></i>
                                            <strong>{{ help.title|default(help.routeSlug) }}</strong>
                                        </div>
                                        <i class="fal fa-chevron-down text-muted chevron-icon"></i>
                                    </div>
                                </summary>
                                <div class="p-4 bg-white border-top markdown-body">
                                    {{ help.content|markdown_to_html|parse_embeds }}
                                </div>
                            </details>
                        {% else %}
                            <div class="alert alert-info border-0 shadow-sm text-center">
                                <i class="fal fa-sad-tear fa-3x mb-3 text-muted"></i><br>
                                Aucune aide enregistrée pour le moment.
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function filterHelps() {
    const query = document.getElementById('helpSearch').value.toLowerCase().trim();
    const items = document.querySelectorAll('.help-item');
    items.forEach(item => {
        if (!query) {
            item.style.display = 'block';
            item.style.order = '0';
            return;
        }

        const title = item.getAttribute('data-title');
        const bodyContent = item.querySelector('.markdown-body').textContent.toLowerCase();

        if (title.includes(query)) {
            item.style.display = 'block';
            item.style.order = '1';
        } else if (bodyContent.includes(query)) {
            item.style.display = 'block';
            item.style.order = '2';
        } else {
            item.style.display = 'none';
        }
    });
}
</script>

<style>
/* Animation custom pour les details */
details.help-item summary::-webkit-details-marker {
    display:none; /* Masquer la flèche native sur Safari */
}
details.help-item[open] summary .chevron-icon {
    transform: rotate(180deg);
}
details.help-item .chevron-icon {
    transition: transform 0.3s ease;
}
</style>
{% endblock %}
