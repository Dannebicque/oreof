{# Badge d'impersonation à afficher quand un admin impersonne un user #}
{% if is_granted('IS_IMPERSONATOR') %}
    <div class="alert alert-danger mb-0" role="alert" style="border-radius: 0; margin-bottom: 0 !important; border: 0;">
        <div class="d-flex align-items-center justify-content-between gap-3">
            <div>
                <strong>⚠️ Vous êtes en mode IMPERSONATION</strong>
                <br>
                <span>
                    Vous visualisez l'application comme <strong>{{ app.user.display }}</strong> ({{ app.user.username }}).
                    Les droits affichés ne sont pas vos droits Admin.
                </span>
            </div>
            <a href="{{ path('app_homepage', {'_switch_user': '_exit'}) }}" class="btn btn-light btn-sm fw-bold"
               title="Revenir à mon rôle Admin">
                <i class="bi bi-arrow-counterclockwise"></i> Revenir à mon rôle Admin
            </a>
        </div>
    </div>
{% endif %}

