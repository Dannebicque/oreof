<div {{ attributes }}>
    {% if this.elementConstitutif.natureUeEc != null and this.elementConstitutif.natureUeEc.isLibre ==  true %}
        <span class="inline-flex w-full items-center justify-center rounded-md bg-cyan-100 px-2 py-1 text-xs font-semibold text-cyan-800">EC libre</span>
    {% else %}
        <button
                {% if isAccessible(this.dpeParcours, 'cfvu') and this.editable %}{# todo: isGranted #}
                    {% if deplacer is defined and deplacer == true and this.editable == true %}
                        {{ stimulus_controller('modal', {
                            size: 'lg',
                            modalTitle: 'Volumes Horaires',
                            nomEvenement: 'refreshListeEc' ,
                            details: {ue: ue.id, parcours: parcours.id},
                            modalUrl: path('app_element_constitutif_structure',{
                                'id': this.elementConstitutif.id,
                                'editable': this.editable,
                                parcours: this.parcours.id}) }) }}
                    {% else %}
                        {{ stimulus_controller('modal', {
                            size: 'lg',
                            modalTitle: 'Volumes Horaires',
                            modalUrl: path('app_element_constitutif_structure',{
                                'id': this.elementConstitutif.id,
                                'editable': this.editable,
                                parcours: this.parcours.id}) }) }}
                    {% endif %}
                {% else %}
                    {{ stimulus_controller('modal', {
                        size: 'lg',
                        modalTitle: 'Volumes Horaires',
                        modalUrl: path('app_element_constitutif_structure_non_editable',{'id': this.elementConstitutif.id}) }) }}
                {% endif %}
                data-action="click->modal#openModal"
                class="inline-flex w-full items-center justify-center gap-1 rounded-md border border-slate-300 bg-white px-2 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50 transition-colors"
                data-size="lg"
                data-bs-toggle="tooltip"
                data-bs-placement="bottom"
                title="Volumes Horaires"
        >
            {% if this.texte == true %}<i class="fal fa-clock"></i>{% endif %}
            <span class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[11px] font-semibold {% if this.ecDesEnfants == true %}bg-violet-100 text-violet-800{% elseif this.etatHeuresComplet == true %}bg-emerald-100 text-emerald-800{% else %}bg-amber-100 text-amber-800{% endif %}">

                {% if this.texte == true %}
                    {% if this.ecDesEnfants == true %}
                        EC des enfants
                    {% else %}
                        {% if this.etatHeuresComplet == true %}Complet{% else %}A saisir{% endif %}
                    {% endif %}
                {% else %}Heures{% endif %}

                    {% if this.isParcoursProprietaire == false and this.isHeuresSpecifiques == false %}
                    <i class="fal fa-link" title="Heures reprises de la fiche matière"></i>
                    {% endif %}

            </span>
        </button>
    {% endif %}
</div>
