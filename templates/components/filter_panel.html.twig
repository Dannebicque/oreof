{% set panelTitle = title|default('Filtres') %}
{% set filtersCount = activeFilters|default(0) %}
{% set fieldsTitle = fieldsTitle|default('Filtres avancés') %}
{% set searchContent = block('search')|trim %}
{% set isCollapsible = collapsible|default(false) %}
{% set collapsedByDefault = collapsedByDefault|default(false) %}
{% set isOpen = (not collapsedByDefault) or filtersCount > 0 %}
{% set toggleId = 'filter-panel-toggle-' ~ random() %}

<div class="rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
    {% if isCollapsible %}
        <input id="{{ toggleId }}" type="checkbox" class="peer sr-only" {% if isOpen %}checked{% endif %}>
    {% endif %}

    <div class="flex flex-col gap-3 p-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="w-full sm:max-w-sm">
            {% if searchContent != '' %}
                {{ searchContent|raw }}
            {% endif %}
        </div>

        <div class="flex shrink-0 items-center gap-2 self-end sm:self-auto">
            {% block actions %}
                {% if isCollapsible %}
                    <label for="{{ toggleId }}"
                           class="inline-flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 transition hover:border-slate-300 hover:text-slate-900 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white"
                           title="Afficher/masquer les filtres"
                           aria-label="Afficher ou masquer les filtres">
                        {{ ux_icon('icon:filter', {class: 'h-4 w-4'}) }}
                        {{ panelTitle }}
                        {% if filtersCount > 0 %}
                            <span class="inline-flex min-w-5 items-center justify-center rounded-full bg-indigo-600 px-1.5 py-0.5 text-[10px] font-bold text-white dark:bg-indigo-500">
                                {{ filtersCount }}
                            </span>
                        {% endif %}
                    </label>
                {% else %}
                    <span class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200">
                        {{ ux_icon('icon:filter', {class: 'h-4 w-4'}) }}
                        {{ panelTitle }}
                        {% if filtersCount > 0 %}
                            <span class="inline-flex min-w-5 items-center justify-center rounded-full bg-indigo-600 px-1.5 py-0.5 text-[10px] font-bold text-white dark:bg-indigo-500">
                                {{ filtersCount }}
                            </span>
                        {% endif %}
                    </span>
                {% endif %}
            {% endblock %}
        </div>
    </div>

    <div class="border-t border-slate-100 bg-slate-50/60 p-4 dark:border-slate-700 dark:bg-slate-800/40{% if isCollapsible %} hidden peer-checked:block{% endif %}">
        <p class="mb-3 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">{{ fieldsTitle }}</p>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-6">
            {% block fields %}{% endblock %}
        </div>
    </div>
</div>

