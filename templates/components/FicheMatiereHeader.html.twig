{# templates/components/FicheMatiereHeader.html.twig #}
{% set prefix = 'fiche_matiere' %}
{% set formation = ficheMatiere.parcours?.formation %}

{% set metaLabelClass = 'mb-1 text-[11px] font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500' %}
{% set metaValueClass = 'text-sm font-medium text-slate-700 dark:text-slate-200' %}
{% set emptyBadgeClass = 'inline-flex items-center rounded-full bg-rose-100 px-2 py-1 text-xs font-semibold text-rose-700 dark:bg-rose-500/15 dark:text-rose-300' %}
{% set quickBtnBase = 'inline-flex items-center justify-center gap-2 rounded-xl border px-3 py-2 text-sm font-semibold shadow-sm transition focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2' %}
{% set quickBtnSecondary = quickBtnBase ~ ' border-slate-300 bg-white text-slate-700 hover:border-slate-400 hover:bg-slate-50 hover:text-slate-900 focus-visible:ring-slate-400 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:bg-slate-700 dark:hover:text-white dark:focus-visible:ring-slate-500 dark:focus-visible:ring-offset-slate-900' %}
{% set quickBtnInfo = quickBtnBase ~ ' border-cyan-300 bg-cyan-50 text-cyan-700 hover:border-cyan-400 hover:bg-cyan-100 focus-visible:ring-cyan-400 dark:border-cyan-700 dark:bg-cyan-500/10 dark:text-cyan-300 dark:hover:border-cyan-600 dark:hover:bg-cyan-500/20 dark:focus-visible:ring-cyan-500 dark:focus-visible:ring-offset-slate-900' %}
{% set quickBtnWarning = quickBtnBase ~ ' border-amber-300 bg-amber-50 text-amber-700 hover:border-amber-400 hover:bg-amber-100 focus-visible:ring-amber-400 dark:border-amber-700 dark:bg-amber-500/10 dark:text-amber-300 dark:hover:border-amber-600 dark:hover:bg-amber-500/20 dark:focus-visible:ring-amber-500 dark:focus-visible:ring-offset-slate-900' %}
{% set quickBtnPrimary = quickBtnBase ~ ' border-indigo-300 bg-indigo-50 text-indigo-700 hover:border-indigo-400 hover:bg-indigo-100 focus-visible:ring-indigo-400 dark:border-indigo-700 dark:bg-indigo-500/10 dark:text-indigo-300 dark:hover:border-indigo-600 dark:hover:bg-indigo-500/20 dark:focus-visible:ring-indigo-500 dark:focus-visible:ring-offset-slate-900' %}
{% set quickBtnSuccess = quickBtnBase ~ ' border-emerald-300 bg-emerald-50 text-emerald-700 hover:border-emerald-400 hover:bg-emerald-100 focus-visible:ring-emerald-400 dark:border-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300 dark:hover:border-emerald-600 dark:hover:bg-emerald-500/20 dark:focus-visible:ring-emerald-500 dark:focus-visible:ring-offset-slate-900' %}
{% set panelClass = 'mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm hidden dark:border-slate-700 dark:bg-slate-900' %}
{% set panelGridClass = 'grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-4' %}

{% set dpeItemStyles = {
    'success': {
        badge: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300',
        title: 'text-emerald-800 dark:text-emerald-200',
        hover: 'hover:bg-emerald-50 dark:hover:bg-emerald-500/10'
    },
    'warning': {
        badge: 'bg-amber-100 text-amber-700 dark:bg-amber-500/15 dark:text-amber-300',
        title: 'text-amber-800 dark:text-amber-200',
        hover: 'hover:bg-amber-50 dark:hover:bg-amber-500/10'
    },
    'danger': {
        badge: 'bg-rose-100 text-rose-700 dark:bg-rose-500/15 dark:text-rose-300',
        title: 'text-rose-800 dark:text-rose-200',
        hover: 'hover:bg-rose-50 dark:hover:bg-rose-500/10'
    },
    'info': {
        badge: 'bg-cyan-100 text-cyan-700 dark:bg-cyan-500/15 dark:text-cyan-300',
        title: 'text-cyan-800 dark:text-cyan-200',
        hover: 'hover:bg-cyan-50 dark:hover:bg-cyan-500/10'
    },
    'secondary': {
        badge: 'bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-200',
        title: 'text-slate-800 dark:text-slate-100',
        hover: 'hover:bg-slate-50 dark:hover:bg-slate-800'
    }
} %}

{% set statusBadgeMap = {
    'completed': {
        bubble: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300',
        line: 'bg-emerald-200 dark:bg-emerald-500/30'
    },
    'active': {
        bubble: 'bg-cyan-100 text-cyan-700 dark:bg-cyan-500/15 dark:text-cyan-300',
        line: 'bg-cyan-200 dark:bg-cyan-500/30'
    },
    'reserved': {
        bubble: 'bg-amber-100 text-amber-700 dark:bg-amber-500/15 dark:text-amber-300',
        line: 'bg-amber-200 dark:bg-amber-500/30'
    },
    'refused': {
        bubble: 'bg-rose-100 text-rose-700 dark:bg-rose-500/15 dark:text-rose-300',
        line: 'bg-rose-200 dark:bg-rose-500/30'
    },
    'pending': {
        bubble: 'bg-slate-100 text-slate-400 dark:bg-slate-800 dark:text-slate-500',
        line: 'bg-slate-200 dark:bg-slate-700'
    }
} %}

<div {{ attributes }}
        class="mb-4 rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
    <div class="space-y-4 p-4 sm:p-5">

        {# ── Bloc métadonnées ── #}
        <section
                class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800/50">
            <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-6">
                <div>
                    <dt class="{{ metaLabelClass }}">Type de fiche matière</dt>
                    <dd class="{{ metaValueClass }}">
                        {% if ficheMatiere.horsDiplome == true %}
                            <span class="inline-flex items-center rounded-full bg-amber-100 px-2 py-1 text-xs font-semibold text-amber-700 dark:bg-amber-500/15 dark:text-amber-300">
                                Hors Diplôme
                            </span>
                        {% else %}
                            <span class="inline-flex items-center rounded-full bg-cyan-100 px-2 py-1 text-xs font-semibold text-cyan-700 dark:bg-cyan-500/15 dark:text-cyan-300">
                                Classique
                            </span>
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="{{ metaLabelClass }}">Type diplôme</dt>
                    <dd class="{{ metaValueClass }}">
                        {% if ficheMatiere.horsDiplome == true %}
                            <span class="inline-flex items-center rounded-full bg-amber-100 px-2 py-1 text-xs font-semibold text-amber-700 dark:bg-amber-500/15 dark:text-amber-300">
                                Hors Diplôme
                            </span>
                        {% else %}
                            {{ formation.typeDiplome|typeDiplome }}
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="{{ metaLabelClass }}">Mention porteuse</dt>
                    <dd class="{{ metaValueClass }}">
                        {% if formation != null %}
                            {{ formation.display }}
                        {% else %}
                            <span class="{{ emptyBadgeClass }}">Non définie</span>
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="{{ metaLabelClass }}">Parcours porteur</dt>
                    <dd class="{{ metaValueClass }}">
                        {% if ficheMatiere.horsDiplome == false %}
                            {% if ficheMatiere.parcours != null %}
                                {% if ficheMatiere.parcours.parcoursDefaut == false %}
                                    {{ ficheMatiere.parcours.libelle }}
                                {% else %}
                                    Mention sans parcours
                                {% endif %}
                            {% else %}
                                <span class="{{ emptyBadgeClass }}">Pas de parcours précisé</span>
                            {% endif %}
                        {% else %}
                            —
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="{{ metaLabelClass }}">Composante porteuse</dt>
                    <dd class="{{ metaValueClass }}">
                        {% if ficheMatiere.horsDiplome == false %}
                            {% if formation != null and formation.composantePorteuse != null %}
                                {{ formation.composantePorteuse.libelle }}
                            {% else %}
                                <span class="{{ emptyBadgeClass }}">Non définie</span>
                            {% endif %}
                        {% else %}
                            —
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="{{ metaLabelClass }}">Responsable fiche</dt>
                    <dd class="{{ metaValueClass }}">
                        {{ ficheMatiere.responsableFicheMatiere != null ? ficheMatiere.responsableFicheMatiere.display : 'Non défini' }}
                    </dd>
                </div>
            </dl>
        </section>

        {# ── État (verrouillée / en modification) + Avancement process ── #}
        <section class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
            <div class="flex items-center gap-3 rounded-2xl border px-4 py-3 shadow-sm {{ hasDemande ? 'border-emerald-200 bg-emerald-50 text-emerald-800 dark:border-emerald-800/70 dark:bg-emerald-500/10 dark:text-emerald-300' : 'border-amber-200 bg-amber-50 text-amber-800 dark:border-amber-800/70 dark:bg-amber-500/10 dark:text-amber-300' }}">
                <div class="flex h-10 w-10 items-center justify-center rounded-full {{ hasDemande ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300' : 'bg-amber-100 text-amber-700 dark:bg-amber-500/15 dark:text-amber-300' }}"
                     data-controller="tooltip" data-tooltip-placement-value="bottom"
                     data-bs-original-title="{{ hasDemande ? 'Fiche matière en cours de modification.' : 'Fiche matière verrouillée.' }}">
                    {{ ux_icon(hasDemande ? 'icon:unlock' : 'icon:lock', {class: 'h-4 w-4'}) }}
                </div>
                <div>
                    <p class="text-sm font-semibold">{{ hasDemande ? 'Fiche matière en cours de modification.' : 'Fiche matière verrouillée.' }}</p>
                    <p class="text-xs opacity-80">Suivez l'avancement et les actions disponibles pour cette fiche.</p>
                </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm dark:border-slate-700 dark:bg-slate-800/70">
                <p class="mb-2 text-[11px] font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">
                    Avancement du process</p>
                <div class="flex flex-wrap items-center justify-center gap-2">
                    {% for key, step in processSteps %}
                        {% if validationSteps[key] is defined and validationSteps[key].status == 'completed' %}
                            {% set state = 'completed' %}
                        {% elseif validationSteps[key] is defined and validationSteps[key].status == 'active' %}
                            {% set state = 'active' %}
                        {% elseif validationSteps[key] is defined and validationSteps[key].status == 'reserved' %}
                            {% set state = 'reserved' %}
                        {% elseif validationSteps[key] is defined and validationSteps[key].status == 'refused' %}
                            {% set state = 'refused' %}
                        {% else %}
                            {% set state = 'pending' %}
                        {% endif %}
                        {% set stateConfig = statusBadgeMap[state] %}
                        <div class="flex items-center">
                            <div class="flex h-10 w-10 items-center justify-center rounded-full ring-2 ring-white {{ stateConfig.bubble }} dark:ring-slate-900"
                                 data-controller="tooltip" data-tooltip-placement-value="bottom"
                                 aria-label="{{ (prefix~'.'~step.label~'.btn-'~state)|trans({}, 'process') }}"
                                 data-bs-original-title="{{ (prefix~'.'~step.label~'.btn-'~state)|trans({}, 'process') }}">
                                <i class="fas {{ step.icon }} text-xs"></i>
                            </div>
                            {% if not loop.last %}
                                <div class="mx-1 h-0.5 w-5 rounded-full {{ stateConfig.line }}"></div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>

        {# ── Actions rapides ── #}
        <section class="flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
            <div class="text-[11px] font-black uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">
                Actions rapides
            </div>

            <div class="flex flex-wrap items-center gap-2">
                {# Dropdown Gestion fiche matière #}
                <div class="relative" data-controller="navbar-dropdown"
                     data-action="click@window->navbar-dropdown#close">
                    <button class="{{ quickBtnSuccess }}"
                            type="button"
                            data-action="click->navbar-dropdown#toggle"
                            aria-expanded="false">
                        {{ ux_icon('icon:check', {class: 'h-4 w-4'}) }}
                        <span>Gestion fiche matière</span>
                        {{ ux_icon('icon:chevron-down', {class: 'h-4 w-4'}) }}
                    </button>
                    <ul data-navbar-dropdown-target="content"
                        class="hidden absolute right-0 top-full z-30 mt-2 min-w-[22rem] rounded-2xl border border-slate-200 bg-white p-2 shadow-2xl dark:border-slate-700 dark:bg-slate-900">
                        {% for key, option in validationOptions %}
                            {% set itemStyle = dpeItemStyles[option.metadata.button_class]|default(dpeItemStyles['secondary']) %}
                            <li>
                                <a class="flex items-start gap-3 rounded-xl px-3 py-3 text-sm text-slate-700 transition {{ itemStyle.hover }} dark:text-slate-200"
                                   data-action="click->modalturbo#open"
                                   data-turbo="true"
                                   href="{{ path('fiche_matiere_process_apply', {type: option.metadata.type, ficheMatiere: ficheMatiere.id, transition: key }) }}">
                                    <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full {{ itemStyle.badge }}">
                                        <i class="fas {{ option.metadata.button_icon }} text-xs"></i>
                                    </span>
                                    <span class="min-w-0">
                                        <span class="block font-semibold {{ itemStyle.title }}">{{ ('workflow.'~key~'.menu.label')|trans({}, 'process') }}</span>
                                        <span class="block text-xs text-slate-500 dark:text-slate-400">{{ ('workflow.'~key~'.menu.description')|trans({}, 'process') }}</span>
                                    </span>
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>

                <button class="{{ quickBtnSecondary }}"
                        data-toggle-group="accordion-1"
                        data-toggle="actions" data-target="#actions-panel"
                        data-toggle-icon-open="rotate-0"
                        data-toggle-icon-close="rotate-180">
                    {{ ux_icon('icon:gear', {class: 'h-4 w-4'}) }}
                    <span>Actions complémentaires</span>
                    {{ ux_icon('icon:chevron-up', {class: 'h-4 w-4 data-toggle-icon rotate-180 transition-transform duration-200'}) }}
                </button>

                <button class="{{ quickBtnInfo }}"
                        data-toggle-group="accordion-1"
                        data-toggle="actions" data-target="#exports-panel"
                        data-toggle-icon-open="rotate-0"
                        data-toggle-icon-close="rotate-180">
                    {{ ux_icon('icon:download', {class: 'h-4 w-4'}) }}
                    <span>Exports</span>
                    {{ ux_icon('icon:chevron-up', {class: 'h-4 w-4 data-toggle-icon rotate-180 transition-transform duration-200'}) }}
                </button>

                {% if is_granted('ROLE_ADMIN') %}
                    <button class="{{ quickBtnSecondary }}"
                            data-toggle-group="accordion-1"
                            data-toggle="actions"
                            data-target="#actions-panel-admin"
                            data-toggle-icon-open="rotate-0"
                            data-toggle-icon-close="rotate-180">
                        {{ ux_icon('icon:wrench', {class: 'h-4 w-4'}) }}
                        <span>Gestion SES</span>
                        {{ ux_icon('icon:chevron-up', {class: 'h-4 w-4 data-toggle-icon rotate-180 transition-transform duration-200'}) }}
                    </button>
                {% endif %}
            </div>
        </section>

        {# ── Panneau Actions complémentaires ── #}
        <div class="{{ panelClass }}" id="actions-panel">
            <div class="{{ panelGridClass }}">
                <div>
                    <button
                            data-action="click->modal#openModal"
                            class="{{ quickBtnSuccess }} w-full"
                            data-size="lg"
                            data-bs-toggle="tooltip"
                            data-bs-placement="bottom"
                            title="{{ 'verifier.la.saisie.fiche_matiere.infobulle'|trans({}, 'process') }}">
                        {{ ux_icon('icon:check', {class: 'h-4 w-4'}) }}
                        <span>Vérifier la saisie</span>
                    </button>
                </div>
                <div>
                    <button class="{{ quickBtnPrimary }} w-full" type="button"
                            {{ stimulus_controller('modal', {
                                size: 'large',
                                modalTitle: 'historique.de.validation.fiche_matiere.title'|trans({}, 'process'),
                                right: true,
                                modalUrl: path('app_historique_fiche_matiere', {ficheMatiere:ficheMatiere.id}) }) }}
                            data-action="click->modal#openModal"
                            data-bs-toggle="tooltip"
                            data-bs-placement="bottom"
                            title="{{ 'historique.de.validation.fiche_matiere.infobulle'|trans({}, 'process') }}">
                        {{ ux_icon('icon:timeline', {class: 'h-4 w-4'}) }}
                        <span>Historique</span>
                    </button>
                </div>
                <div>
                    {% if is_granted('ROLE_ADMIN') and hasLastVersion is defined and hasLastVersion == true %}
                        <a class="{{ quickBtnWarning }} w-full"
                           data-bs-toggle="collapse" data-bs-target="#diffGlobalParcours">
                            {{ ux_icon('icon:wrench', {class: 'h-4 w-4'}) }}
                            <span>Comparer les descriptifs</span>
                        </a>
                    {% endif %}
                </div>
                <div></div>
            </div>
        </div>

        {# ── Panneau Exports ── #}
        <div class="{{ panelClass }}" id="exports-panel">
            <div class="{{ panelGridClass }}">
                <div>
                    <a href="{{ path('app_fiche_matiere_export', {id:ficheMatiere.id}) }}"
                       class="{{ quickBtnPrimary }} w-full"
                       data-bs-toggle="tooltip"
                       data-bs-placement="bottom"
                       title="Télécharger en PDF">
                        {{ ux_icon('icon:download', {class: 'h-4 w-4'}) }}
                        <span>Fiche descriptive (PDF)</span>
                    </a>
                </div>
            </div>
        </div>

        {# ── Panneau Admin ── #}
        {% if is_granted('ROLE_ADMIN') %}
            <div class="{{ panelClass }}" id="actions-panel-admin">
                <div class="{{ panelGridClass }}">
                    <div>
                        <button class="{{ quickBtnSecondary }} w-full">
                            {{ ux_icon('icon:gear', {class: 'h-4 w-4'}) }}
                            <span>Gérer codification</span>
                        </button>
                    </div>
                    <div>
                        <button class="{{ quickBtnSecondary }} w-full">
                            {{ ux_icon('icon:gear', {class: 'h-4 w-4'}) }}
                            <span>Gérer la version</span>
                        </button>
                    </div>
                </div>
            </div>
        {% endif %}

    </div>
</div>
