<div class="flex flex-wrap gap-2 p-2 bg-slate-100 border border-slate-300 rounded-t-lg dark:bg-slate-800 dark:border-slate-600">
    <!-- Undo/Redo -->
    <button type="button" class="inline-flex items-center justify-center h-9 px-2 text-sm font-medium rounded border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 dark:hover:bg-slate-600 transition" onclick="editorHistoryUndo()" title="Retour arrière">
        <twig:UX:Icon name="material-symbols:undo" class="h-4 w-4" />
    </button>
    <button type="button" class="inline-flex items-center justify-center h-9 px-2 text-sm font-medium rounded border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 dark:hover:bg-slate-600 transition" onclick="editorHistoryRedo()" title="Retour avant">
        <twig:UX:Icon name="material-symbols:redo" class="h-4 w-4" />
    </button>

    <div class="w-px bg-slate-300 dark:bg-slate-600"></div>

    <!-- Texte -->
    <button type="button" class="inline-flex items-center justify-center h-9 px-2 text-sm font-medium rounded border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 dark:hover:bg-slate-600 transition" onclick="insertMarkdown('**', '**')" title="Gras">
        <twig:UX:Icon name="glyphs:b-bold" class="h-4 w-4" />
    </button>
    <button type="button" class="inline-flex items-center justify-center h-9 px-2 text-sm font-medium rounded border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 dark:hover:bg-slate-600 transition" onclick="insertMarkdown('*', '*')" title="Italique">
        <twig:UX:Icon name="tabler:italic" class="h-4 w-4" />
    </button>

    <div class="w-px bg-slate-300 dark:bg-slate-600"></div>

    <!-- Structure -->
    <button type="button" class="inline-flex items-center justify-center h-9 px-2 text-sm font-medium rounded border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 dark:hover:bg-slate-600 transition" onclick="insertMarkdown('### ', '')" title="Titre">
        <twig:UX:Icon name="tabler:heading" class="h-4 w-4" />
    </button>
    <button type="button" class="inline-flex items-center justify-center h-9 px-2 text-sm font-medium rounded border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 dark:hover:bg-slate-600 transition" onclick="insertMarkdown('- ', '')" title="Liste à puces">
        <twig:UX:Icon name="material-symbols:list-rounded" class="h-4 w-4" />
    </button>
    <button type="button" class="inline-flex items-center justify-center h-9 px-2 text-sm font-medium rounded border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 dark:hover:bg-slate-600 transition" onclick="insertMarkdown('\n\n---\n\n', '')" title="Ligne horizontale">
        <twig:UX:Icon name="ic:round-minus" class="h-4 w-4" />
    </button>

    <div class="w-px bg-slate-300 dark:bg-slate-600"></div>

    <!-- Lien et Accordéon -->
    <button type="button" class="inline-flex items-center justify-center h-9 px-2 text-sm font-medium rounded border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 dark:hover:bg-slate-600 transition" onclick="insertLink()" title="Insérer un lien">
        <twig:UX:Icon name="material-symbols:link-rounded" class="h-4 w-4" />
    </button>
    <button type="button" class="inline-flex items-center gap-1 h-9 px-3 text-sm font-medium rounded border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-200 dark:hover:bg-slate-600 transition" onclick="insertAccordion()" title="Créer un sous-menu déroulant (accordéon)">
        <twig:UX:Icon name="gg:chevron-down-r" class="h-4 w-4" />
        Menu
    </button>

    <div class="w-px bg-slate-300 dark:bg-slate-600"></div>

    <!-- Média -->
    <button type="button" class="inline-flex items-center gap-1 h-9 px-3 text-sm font-medium rounded border border-blue-300 bg-blue-50 text-blue-700 hover:bg-blue-100 dark:border-blue-700 dark:bg-blue-900/30 dark:text-blue-300 dark:hover:bg-blue-900/50 transition" onclick="openImageModal()" title="Insérer une image">
        <twig:UX:Icon name="material-symbols:image-outline" class="h-4 w-4" />
        Image
    </button>
    <button type="button" class="inline-flex items-center gap-1 h-9 px-3 text-sm font-medium rounded border border-red-300 bg-red-50 text-red-700 hover:bg-red-100 dark:border-red-700 dark:bg-red-900/30 dark:text-red-300 dark:hover:bg-red-900/50 transition" onclick="insertVideo()" title="Insérer une vidéo YouTube/Vimeo">
        <twig:UX:Icon name="akar-icons:video" class="h-4 w-4" />
        Vidéo
    </button>
</div>
