<div {{ attributes }}>
    {% if this.elementConstitutif.natureUeEc != null and this.elementConstitutif.natureUeEc.isLibre ==  true %}
        <span class="inline-flex w-full items-center justify-center rounded-md bg-cyan-100 px-2 py-1 text-xs font-semibold text-cyan-800">EC libre</span>
    {% else %}
        <button
                {% if this.editable == false %}
                    {{ stimulus_controller('modal', {
                        size: 'lg',
                        nomEvenement: 'refreshListeEc',
                        details: {ue: this.ue.id, parcours: this.parcours.id},
                        modalTitle: 'Blocs de compétences',
                        modalUrl: path('app_element_constitutif_bcc_non_editable',{id: this.elementConstitutif.id, parcours: this.parcours.id}) }) }}
                {% else %}
                    {% if this.deplacer == true and this.editable == true %}
                        {{ stimulus_controller('modal', {
                            size: 'lg',
                            nomEvenement: 'refreshListeEc',
                            details: {ue: this.ue.id, parcours: this.parcours.id},
                            modalTitle: 'Blocs de compétences',
                            modalUrl: path('app_element_constitutif_bcc',{id: this.elementConstitutif.id, parcours: this.parcours.id}) }) }}
                    {% else %}
                        {{ stimulus_controller('modal', {
                            size: 'lg',
                            modalTitle: 'Blocs de compétences',
                            modalUrl: path('app_element_constitutif_bcc',{id: this.elementConstitutif.id,parcours: this.parcours.id}) }) }}
                    {% endif %}
                {% endif %}
                data-action="click->modal#openModal"
                class="inline-flex w-full items-center justify-center gap-1 rounded-md border border-slate-300 bg-white px-2 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50 transition-colors"
                data-size="lg"
                data-bs-toggle="tooltip"
                data-bs-placement="bottom"
                title="Blocs de compétences"
        >
            {% if this.texte == true %}<i class="fal fa-ballot-check"></i>{% endif %}
            <span class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[11px] font-semibold {% if this.etatBccComplet == true %}bg-emerald-100 text-emerald-800{% else %}bg-amber-100 text-amber-800{% endif %}">{% if this.texte == true %}{% if this.etatBccComplet == true %}Complet{% else %}A saisir{% endif %} {% else %}BCC{% endif %} {% if this.isParcoursProprietaire == false %}
                    <i class="fal fa-link" title="BCC repris du parcours porteur"></i>{% endif %}</span>
        </button>
    {% endif %}
</div>
