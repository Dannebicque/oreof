<ul class="flex items-center space-x-2">
    <li>
        <a href="{{ path('app_search') }}"
           title="Effectuer une recherche"
                {{ stimulus_controller('tooltip') }}
           aria-label="Rechercher"
           class="p-2 rounded-full text-gray-600 hover:bg-gray-100 transition inline-flex items-center justify-center"
        >
            <twig:UX:Icon name="icon:search" class="w-5 h-5"/>
        </a>
    </li>

    <li>
        <a href="{{ path('app_commentaire') }}"
           title="Mes commentaires"
                {{ stimulus_controller('tooltip') }}
           aria-label="Mes commentaires"
           class="p-2 rounded-full text-gray-600 hover:bg-gray-100 transition inline-flex items-center justify-center"
        >
            <twig:UX:Icon name="icon:comment" class="w-5 h-5"/>
        </a>
    </li>

    {% if is_granted('ROLE_ADMIN') %}
        {# bouton contacter supprimé #}
    {% endif %}

    <li>
        <a href="{{ path('app_bug_report_modal', {
                    formation: formation is defined and formation != null ? formation.id : '',
                    parcours: parcours is defined and parcours != null ? parcours.id : '',
                    page: app.request.uri
        }) }}"
           data-action="click->modalturbo#open"
           title="Signaler un bug"
                {{ stimulus_controller('tooltip') }}
           aria-label="Signaler un bug"
           class="p-2 rounded-full text-gray-600 hover:bg-gray-100 transition inline-flex items-center justify-center"
        >
            <twig:UX:Icon name="icon:bug" class="w-5 h-5"/>
        </a>
    </li>

    <li>
        <a href="{{ path('app_notification_liste_user') }}"
           class="relative p-2 rounded-full text-gray-600 hover:bg-gray-100 transition inline-flex items-center justify-center"
           data-action="click->modalturbo#open"
           aria-label="Notifications"
           title="Notifications"
                {{ stimulus_controller('tooltip') }}
        >
            <twig:UX:Icon name="icon:bell" class="w-5 h-5"/>
            {% if this.notifsNonLu is defined and this.notifsNonLu > 0 %}
                <span class="absolute -top-0.5 -right-0.5 inline-flex h-3 w-3 rounded-full bg-red-500 ring-2 ring-white"></span>
            {% endif %}
        </a>
    </li>
</ul>
