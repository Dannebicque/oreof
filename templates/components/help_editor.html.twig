<div {{ attributes }}>
    <div class="row mt-4">
        <!-- Zone d'édition (Formulaire) -->
        <div class="col-md-6 border-end pe-4">

            {{ form_start(form, { attr: { 'data-model': '*' } }) }}

            {{ form_row(form.title) }}
            {{ form_row(form.routeSlug) }}

            <div class="mb-4 mt-3">
                {{ form_label(form.content) }}

                <!-- Barre d'outils Markdown -->
                <div class="bg-light border border-bottom-0 rounded-top p-2 d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="insertMarkdown('**', '**')" data-bs-toggle="tooltip" title="Gras">
                        <i class="fal fa-bold"></i>
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="insertMarkdown('*', '*')" data-bs-toggle="tooltip" title="Italique">
                        <i class="fal fa-italic"></i>
                    </button>
                    <div class="vr mx-1"></div>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="insertMarkdown('### ', '')" data-bs-toggle="tooltip" title="Titre">
                        <i class="fal fa-heading"></i>
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="insertMarkdown('- ', '')" data-bs-toggle="tooltip" title="Liste à puces">
                        <i class="fal fa-list-ul"></i>
                    </button>
                    <div class="vr mx-1"></div>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="insertLink()" data-bs-toggle="tooltip" title="Insérer un lien">
                        <i class="fal fa-link"></i>
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="insertImage()" data-bs-toggle="tooltip" title="Insérer une image">
                        <i class="fal fa-image"></i> Image
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="insertVideo()" data-bs-toggle="tooltip" title="Insérer une vidéo YouTube/Vimeo">
                        <i class="fal fa-video"></i> Vidéo
                    </button>
                </div>

                <!-- Le champ textarea de Symfony -->
                {{ form_widget(form.content, { attr: { 'class': 'form-control rounded-bottom-only' } }) }}
            </div>

            <div class="form-check form-switch mb-3">
                {{ form_widget(form.isActive) }}
                {{ form_label(form.isActive) }}
            </div>

            <button type="submit" class="btn btn-success mt-3">
                <i class="fal fa-save"></i> Enregistrer
            </button>
            <a href="{{ path('app_help_index') }}" class="btn btn-secondary mt-3">Retour</a>
            {{ form_end(form) }}
        </div>

        <!-- Zone d'aperçu en direct -->
        <div class="col-md-6 ps-4">
            <h5 class="text-info mb-4"><i class="fal fa-eye"></i> Aperçu utilisateur</h5>

            <div class="bg-light p-4 rounded shadow-sm">
                <h3 class="mb-3">{{ form.title.vars.value ?: 'Titre de l\'aide...' }}</h3>

                <div class="markdown-body text-break">
                    {% if form.content.vars.value %}
                        {{ form.content.vars.value|markdown_to_html|parse_embeds }}
                    {% else %}
                        <p class="text-muted fst-italic">Commencez à rédiger pour voir l'aperçu...</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>