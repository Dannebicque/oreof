{#
Composant Button — exemples d'usage :
  <twig:Button label="Ajouter" variant="success" icon="icon:add" href="{{ path('...') }}" />
  <twig:Button label="Modifier" variant="warning" :soft="false" :outline="true" icon="icon:edit" href="{{ path('...') }}" />
  <twig:Button label="Enregistrer" variant="success" :soft="false" :outline="false" type="submit" icon="icon:save" />
  <twig:Button label="Supprimer" variant="danger" :soft="false" :outline="false" icon="icon:delete" />
#}

{# ── Taille ───────────────────────────────────────────────────── #}
{% set sizeClass = {
    'sm': 'px-3 py-1.5 text-sm h-8',
    'md': 'px-4 py-2 text-sm h-10',
    'lg': 'px-5 py-2.5 text-base h-11',
}[size] ?? 'px-3 py-1.5 text-sm h-8' %}

{% set iconSizeClass = {
    'sm': 'h-4 w-4',
    'md': 'h-4 w-4',
    'lg': 'h-4 w-4',
}[size] ?? 'h-4 w-4' %}

{# ── Couleurs soft (défaut) : fond teinté, bordure légère ─────── #}
{% set softColors = {
    'primary':   'border border-blue-300 bg-blue-50 text-blue-700 hover:bg-blue-100 hover:text-blue-800 dark:border-blue-700 dark:bg-blue-900/30 dark:text-blue-300 dark:hover:bg-blue-900/50',
    'success':   'border border-emerald-300 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 hover:text-emerald-800 dark:border-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300 dark:hover:bg-emerald-900/50',
    'warning':   'border border-amber-300 bg-amber-50 text-amber-700 hover:bg-amber-100 hover:text-amber-800 dark:border-amber-700 dark:bg-amber-900/30 dark:text-amber-300 dark:hover:bg-amber-900/50',
    'danger':    'border border-red-300 bg-red-50 text-red-700 hover:bg-red-100 hover:text-red-800 dark:border-red-700 dark:bg-red-900/30 dark:text-red-300 dark:hover:bg-red-900/50',
    'info':      'border border-cyan-300 bg-cyan-50 text-cyan-700 hover:bg-cyan-100 hover:text-cyan-800 dark:border-cyan-700 dark:bg-cyan-900/30 dark:text-cyan-300 dark:hover:bg-cyan-900/50',
    'secondary': 'border border-slate-300 bg-slate-50 text-slate-600 hover:bg-slate-100 hover:text-slate-800 dark:border-slate-600 dark:bg-slate-800/50 dark:text-slate-300 dark:hover:bg-slate-700',
} %}

{# ── Couleurs outline : bordure franche, fond transparent ─────── #}
{% set outlineColors = {
    'primary':   'border border-blue-600 text-blue-700 hover:bg-blue-600 hover:text-white focus:ring-blue-500 dark:border-blue-400 dark:text-blue-300 dark:hover:bg-blue-500',
    'success':   'border border-emerald-600 text-emerald-700 hover:bg-emerald-600 hover:text-white focus:ring-emerald-500 dark:border-emerald-400 dark:text-emerald-300 dark:hover:bg-emerald-500',
    'warning':   'border border-amber-500 text-amber-700 hover:bg-amber-500 hover:text-slate-900 focus:ring-amber-400 dark:border-amber-400 dark:text-amber-300 dark:hover:bg-amber-400 dark:hover:text-slate-900',
    'danger':    'border border-red-600 text-red-700 hover:bg-red-600 hover:text-white focus:ring-red-500 dark:border-red-400 dark:text-red-300 dark:hover:bg-red-500',
    'info':      'border border-cyan-600 text-cyan-700 hover:bg-cyan-600 hover:text-white focus:ring-cyan-500 dark:border-cyan-400 dark:text-cyan-300 dark:hover:bg-cyan-500',
    'secondary': 'border border-slate-400 text-slate-600 hover:bg-slate-500 hover:text-white focus:ring-slate-400 dark:border-slate-500 dark:text-slate-200 dark:hover:bg-slate-600',
} %}

{# ── Couleurs solid : fond plein ──────────────────────────────── #}
{% set solidColors = {
    'primary':   'bg-blue-600 text-white hover:bg-blue-700 focus:ring-blue-500 border border-transparent',
    'success':   'bg-emerald-600 text-white hover:bg-emerald-700 focus:ring-emerald-500 border border-transparent',
    'warning':   'bg-amber-500 text-slate-900 hover:bg-amber-600 focus:ring-amber-400 border border-transparent',
    'danger':    'bg-red-600 text-white hover:bg-red-700 focus:ring-red-500 border border-transparent',
    'info':      'bg-cyan-600 text-white hover:bg-cyan-700 focus:ring-cyan-500 border border-transparent',
    'secondary': 'bg-slate-500 text-white hover:bg-slate-600 focus:ring-slate-400 border border-transparent',
} %}

{% if soft %}
    {% set colorClass = softColors[variant] ?? softColors['secondary'] %}
{% elseif outline %}
    {% set colorClass = outlineColors[variant] ?? outlineColors['secondary'] %}
{% else %}
    {% set colorClass = solidColors[variant] ?? solidColors['secondary'] %}
{% endif %}

{# ── Classes de base ──────────────────────────────────────────── #}
{% set baseClass = 'inline-flex items-center gap-1.5 rounded-md font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-offset-1 disabled:opacity-50 disabled:cursor-not-allowed' %}
{% set disabledClass = disabled ? ' pointer-events-none opacity-50' : '' %}
{% set allClasses = baseClass ~ ' ' ~ sizeClass ~ ' ' ~ colorClass ~ disabledClass ~ (extraClass ? ' ' ~ extraClass : '') %}

{# ── Slot unique du composant ─────────────────────────────────── #}
{% set slotContent %}
    {% block content %}{% endblock %}
{% endset %}

{# ── Rendu ────────────────────────────────────────────────────── #}
{% if href != '' %}
    <a href="{{ href }}"
       class="{{ allClasses }}"
       {% if tooltip %}title="{{ tooltip }}"{% endif %}
            {% if disabled %}aria-disabled="true" tabindex="-1"{% endif %}
            {{- attributes -}}
    >
        {% if icon != '' and not iconEnd %}{{ ux_icon(icon, {class: iconSizeClass}) }}{% endif %}
        {% if label != '' %}<span>{{ label }}</span>{% endif %}
        {{ slotContent|trim }}
        {% if icon != '' and iconEnd %}{{ ux_icon(icon, {class: iconSizeClass}) }}{% endif %}
    </a>
{% else %}
    <button
            type="{{ type }}"
            class="{{ allClasses }}"
            {% if form != '' %}form="{{ form }}"{% endif %}
            {% if tooltip %}title="{{ tooltip }}"{% endif %}
            {% if disabled %}disabled{% endif %}
            {{- attributes -}}
    >
        {% if icon != '' and not iconEnd %}{{ ux_icon(icon, {class: iconSizeClass}) }}{% endif %}
        {% if label != '' %}<span>{{ label }}</span>{% endif %}
        {{ slotContent|trim }}
        {% if icon != '' and iconEnd %}{{ ux_icon(icon, {class: iconSizeClass}) }}{% endif %}
    </button>
{% endif %}
