<div class="overflow-x-auto">
    <table class="min-w-full text-sm text-slate-700 dark:text-slate-200">
        <thead class="bg-slate-50 text-left text-xs font-black uppercase tracking-wider text-slate-500 dark:bg-slate-800/70 dark:text-slate-300">
        <tr>
            {% if is_admin %}
                <th class="px-4 py-3">Composante</th>
            {% endif %}
            <th class="px-4 py-3">Mention</th>
            <th class="px-4 py-3">Parcours</th>
            <th class="px-4 py-3">Date demande</th>
            <th class="px-4 py-3">Niveau demande</th>
            <th class="px-4 py-3">Etat</th>
            <th class="px-4 py-3 text-right">Actions</th>
        </tr>
        <tr class="border-t border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-900">
            {% if is_admin %}
                <th class="px-4 py-3">
                    <label for="filter-composantePorteuse" class="sr-only">Composante</label>
                    <select
                            {{ stimulus_action('crud', 'filter', 'change', {
                                'field': 'composantePorteuse'
                            }) }}
                            id="filter-composantePorteuse"
                            {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}
                            class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100">
                        <option value="">Toutes les composantes</option>
                        {% for composante in composantes %}
                            <option value="{{ composante.id }}"
                                    {% if params['composantePorteuse'] is defined and params['composantePorteuse'] == composante.id %}selected{% endif %}
                            >{{ composante.libelle }}</option>
                        {% endfor %}
                    </select>
                </th>
            {% endif %}
            <th class="px-4 py-3">
                <label for="filter-mention" class="sr-only">Mention</label>
                <select
                        {{ stimulus_action('crud', 'filter', 'change', {
                            'field': 'mention'
                        }) }}
                        id="filter-mention"
                        {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}
                        class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                >
                    <option value="">Toutes les mentions</option>
                    {% for mention in mentions %}
                        <option value="{{ mention.id }}"
                                {% if params['mention'] is defined and params['mention'] == mention.id %}selected{% endif %}
                        >{{ mention.libelle }}</option>
                    {% endfor %}
                </select>
            </th>
            <th class="px-4 py-3"></th>
            <th class="px-4 py-3"></th>
            <th class="px-4 py-3">
                <label for="filter-niveauModification" class="sr-only">Niveau</label>
                <select
                        {{ stimulus_action('crud', 'filter', 'change', {
                            'field': 'niveauModification'
                        }) }}
                        id="filter-niveauModification"
                        {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}
                        class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                >
                    <option value="">Tous les niveaux</option>
                    {% for key, niveau in listeNiveauModification %}
                        <option value="{{ key }}"
                                {% if params['niveauModification'] is defined and params['niveauModification'] == key %}selected{% endif %}
                        >{{ niveau }}</option>
                    {% endfor %}
                </select>
            </th>
            <th class="px-4 py-3">
                <label for="filter-etatValidation" class="sr-only">Etat</label>
                <select
                        {{ stimulus_action('crud', 'filter', 'change', {
                            'field': 'etatValidation'
                        }) }}
                        id="filter-etatValidation"
                        {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}
                        class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100"
                >
                    <option value="">Choisir l'etat</option>
                    {% for value, type in listeEtatValidation %}
                        <option value="{{ value }}"
                                {% if params['etatValidation'] is defined and params['etatValidation'] == value %}selected{% endif %}>{{ type.label|trans({}, 'process') }}</option>
                    {% endfor %}
                </select>
            </th>
            <th class="px-4 py-3 text-right">
                <twig:Button
                        label="Effacer les filtres"
                        variant="danger"
                        size="sm"
                        :outline="true"
                        dataAction="click->crud#effaceFiltre"
                />
            </th>
        </tr>
        </thead>

        <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
        {% for demande in demandes %}
            <tr class="align-top hover:bg-slate-50/70 dark:hover:bg-slate-800/40">
                {% if is_admin %}
                    <td rowspan="2"
                        class="px-4 py-3 font-medium text-slate-800 dark:text-slate-100">{{ demande.formation.composantePorteuse.libelle }}</td>
                {% endif %}
                <td rowspan="2"
                    class="px-4 py-3 font-medium text-slate-800 dark:text-slate-100">{{ demande.formation.displayLong(false) }}</td>
                <td rowspan="2" class="px-4 py-3">
                    {% if demande.niveauDemande == 'F' %}
                        <span class="inline-flex rounded-full border border-cyan-300 bg-cyan-50 px-2 py-0.5 text-xs font-semibold text-cyan-700 dark:border-cyan-700 dark:bg-cyan-950/30 dark:text-cyan-300">Mention</span>
                    {% else %}
                        {{ demande.parcours != null ? demande.parcours.libelle : '' }}
                    {% endif %}
                </td>
                <td class="px-4 py-3">{{ demande.dateDemande|date('d/m/Y') }}</td>
                <td class="px-4 py-3">{{ demande.niveauModification|badgeEnum }}</td>
                <td class="px-4 py-3">
                    {% if demande.niveauDemande == 'P' %}
                        {{ demande.etatValidation|badgeEnum }}
                    {% else %}
                        <span class="text-slate-300 dark:text-slate-600">-</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3 text-right">
                    {% if demande.niveauDemande == 'F' %}
                        <twig:Button
                                href="{{ path('formation_v2_voir', {'slug': demande.formation.slug}) }}"
                                target="_blank"
                                rel="noopener noreferrer"
                                variant="info"
                                size="sm"
                                icon="icon:info"
                                label="Voir la formation"
                                tooltip="Voir la formation"
                                :centered="false"
                        />
                    {% else %}
                        <twig:Button
                                href="{{ path('parcours_v2_voir', {parcours: demande.parcours.id}) }}"
                                target="_blank"
                                rel="noopener noreferrer"
                                variant="info"
                                size="sm"
                                icon="icon:info"
                                label="Voir le parcours"
                                tooltip="Voir le parcours"
                                :centered="false"
                        />
                    {% endif %}
                </td>
            </tr>
            <tr class="align-top hover:bg-slate-50/70 dark:hover:bg-slate-800/40">
                <td class="px-4 py-3 text-slate-600 dark:text-slate-300">{{ demande.auteur != null ? demande.auteur.display : '-' }}</td>
                <td colspan="2"
                    class="px-4 py-3 text-slate-600 dark:text-slate-300">{{ demande.argumentaireDemande }}</td>
                <td class="px-4 py-3 text-right">
                    <div class="flex flex-wrap justify-end gap-2">
                        <twig:Button
                                href="{{ path('app_demande_dpe_edit', {'id': demande.id}) }}"
                                variant="warning"
                                size="sm"
                                icon="icon:edit"
                                label="Modifier"
                                tooltip="Modifier l'argumentaire de la demande DPE"
                                dataAction="click->modalTurbo#openModal"
                        />
                        {% if is_granted('ROLE_ADMIN') %}
                            <twig:Button
                                    variant="danger"
                                    size="sm"
                                    icon="icon:delete"
                                    label="Supprimer"
                                    tooltip="Supprimer la demande DPE"
                                    dataAction="click->crud#delete"
                                    data-crud-url-param="{{ path('app_demande_dpe_delete', {'id': demande.id}) }}"
                                    data-crud-csrf-param="{{ csrf_token('delete' ~ demande.id) }}"
                            />
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="{{ is_admin ? 7 : 6 }}"
                    class="px-4 py-8 text-center text-sm font-medium text-amber-700 dark:text-amber-300">
                    Aucune demande en attente
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
