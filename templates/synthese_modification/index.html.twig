{% extends 'base.html.twig' %}

{% set header_title %}
    Synthèse des modifications CFVU
{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        {
            title: 'Conseils'
        },
        {
            title: 'Synthèse des modifications CFVU'
        }
    ]}) }}
{% endblock %}

{% block bouton_header %}
    <twig:Button
            href="{{ path('app_synthese_modification_export_all') }}"
            variant="info"
            size="sm"
            icon="icon:download"
            label="Récupérer toutes les modifications"
            tooltip="Télécharger toutes les modifications"
            extraClass="font-semibold"
    />
{% endblock %}

{% block content %}
    <section
            class="space-y-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900 sm:p-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div class="space-y-1">
                <h2 class="text-sm font-black uppercase tracking-widest text-slate-500 dark:text-slate-400">
                    Synthèse des modifications CFVU
                </h2>
                <p class="max-w-3xl text-sm text-slate-600 dark:text-slate-300">
                    ...texte d'aide de la page...
                </p>
            </div>

            <div class="inline-flex items-center rounded-full border border-cyan-200 bg-cyan-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-cyan-800 dark:border-cyan-800 dark:bg-cyan-950/30 dark:text-cyan-200">
                {{ user_data.campagneCollecte.libelle }}
            </div>
        </div>

        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900 space-y-4">
            <div class="overflow-x-auto">
                <table class="min-w-full text-sm text-slate-700 dark:text-slate-200">
                    <thead class="bg-slate-50 text-left text-xs font-black uppercase tracking-wider text-slate-500 dark:bg-slate-800/70 dark:text-slate-300">
                <tr>
                    <th class="px-4 py-3">Composante</th>
                    <th class="px-4 py-3">Export</th>
                </tr>
                </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                {% for composante in composantes %}
                    <tr class="align-top hover:bg-slate-50/70 dark:hover:bg-slate-800/40">
                        <td class="px-4 py-3 font-medium text-slate-800 dark:text-slate-100">{{ composante.libelle }}</td>
                        <td class="px-4 py-3">
                            {% if comp[composante.id] is defined %}
                                <twig:Button
                                        href="{{ path('app_synthese_modification_export_composante', {composante: composante.id}) }}"
                                        variant="info"
                                        size="sm"
                                        icon="icon:download"
                                        label="Récupérer toutes les modifications de la composante ({{ comp[composante.id] }} parcours)"
                                        tooltip="Télécharger toutes les modifications de la composante {{ composante.libelle }}"
                                        extraClass="font-semibold"
                                />
                            {% else %}
                                <span class="text-xs text-slate-400 dark:text-slate-500">Aucune modification à exporter</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    </section>
{% endblock %}
