<div {{ stimulus_controller('register', {
    urlComposante: path('api_composante'),
    urlFormation: path('api_formation'),
    urlDroits: path('api_droits'),
}) }}
        data-action="register:refreshModale@window->base#refreshModale"
>
    {% if not is_granted('ROLE_ADMIN') %}
        <div class="alert alert-info mt-2 mb-2">
            La demande sera validée par l'administration du site. L'utilisateur recevra un mail de confirmation dès l'activation complète de son accès.
        </div>
    {% endif %}
    {% form_theme form 'communs/form_theme_v2.html.twig' %}
    {{ form_start(form, {
        attr: {
            id: 'modalForm',
        }}) }}
    <div class="row">
        <div class="col-12">
            {{ form_row(form.email) }}
        </div>
    </div>
    {{ form_end(form) }}
</div>
