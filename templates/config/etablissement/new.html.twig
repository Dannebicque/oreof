{% extends 'base.html.twig' %}

{% block content %}
    <section
            class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900 sm:p-6">
        {{ include('communs/_form.html.twig') }}
    </section>
{% endblock %}

{% set header_title %}
    {{ titre }}
{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        { title: 'Administration' },
        { title: titre }
    ]}) }}
{% endblock %}

{% block bouton_header %}
    <twig:Button
            href="{{ path('app_etablissement_index') }}"
            variant="success"
            :outline="true"
            :soft="false"
            icon="icon:arrow-left"
            label="Retour à la liste"
            tooltip="Retour à la liste"
    />
{% endblock %}
