{% extends 'base.html.twig' %}

{% block content %}
    <div {{ stimulus_controller('profil--index', {
        profil: profilId,
        urlListe: path('app_administration_profils_liste'),
        urlChangeDroit: path('app_administration_profils_change_droit'),
    }) }}>
        <div class="mt-2 rounded-lg border border-gray-200 bg-white shadow-sm">
            <div class="p-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="profil" class="mb-1 block text-sm font-medium text-gray-700">
                            Profil <span class="text-red-500">*</span>
                        </label>
                        <select name="profil" id="profil"
                                class="block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
                                {{ stimulus_action('profil--index', 'changeProfil') }}
                                {{ stimulus_controller('symfony/ux-autocomplete/autocomplete') }}
                        >
                            <option value="">Choisir un profil</option>
                            {% for profil in profils %}
                                <option value="{{ profil.id }}"
                                        {% if profil.id == profilId %}selected{% endif %}
                                >{{ profil.libelle }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div></div>
                </div>
            </div>
        </div>

        <div {{ stimulus_target('profil--index', 'liste') }} class="mt-2"></div>
    </div>
{% endblock %}

{% set header_title %}
    Gestion des profils
{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        {
            href:'',
            title: 'Gestion des utilisateurs',
        },
        {
            href:'',
            title: 'Profils',
        }
    ]}) }}
{% endblock %}

{% block bouton_header %}
    <button
            {{ stimulus_controller('modal', {
                size: 'lg',
                modalTitle: 'Ajouter un profil',
                modalUrl: path('app_administration_profils_creer') }) }}
            data-action="click->modal#openModal"
            class="btn border border-emerald-300 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 hover:text-emerald-800"
            {{ stimulus_controller('tooltip', {
                placement: 'bottom',
                customClass: 'app-tooltip',
                title: 'Ajouter un rôle'
            }) }}
    >
        <twig:UX:Icon name="icon:add" class="h-4 w-4"/>
        <span> Créer un profil</span>
    </button>
{% endblock %}
