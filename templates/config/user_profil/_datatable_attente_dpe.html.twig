{% if item.composanteDemande is not null %}
    {% if item.isValidDpe %}
        <twig:Badge label="Oui ({{ item.dateValideDpe|dateTimeFr }})" variant="success"/>
    {% else %}
        <twig:Badge label="Non ({{ item.composanteDemande.libelle }})" variant="warning"/>
    {% endif %}
{% else %}
    <twig:Badge label="Etablissement" variant="success"/>
{% endif %}

