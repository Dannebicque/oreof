{% extends 'base.html.twig' %}

{% block content %}
    {{ component('DataTable', { config: table }) }}

{% endblock %}

{% set header_title %}
    Gestion des rythmes de formations
{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        {
            href:'',
            title: 'Administration',
        }
    ]}) }}
{% endblock %}

{% block bouton_header %}
    <button
            {{ stimulus_controller('modal', {
                size: 'lg',
                modalTitle: 'Ajouter un rythme de formation',
                modalUrl: path('app_rythme_formation_new') }) }}
            data-action="click->modal#openModal"
            class="btn border border-emerald-300 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 hover:text-emerald-800"
            data-size="lg"
            data-bs-toggle="tooltip"
            data-bs-placement="bottom"
            title="Ajouter un rythme de formation"
    >
        <twig:UX:Icon name="icon:add" class="h-4 w-4"/>
        <span> Ajouter un rythme de formation</span>
    </button>
{% endblock %}
