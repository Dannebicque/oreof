{% extends 'base.html.twig' %}

{% block content %}
    {{ component('DataTable', { config: table }) }}
{% endblock %}

{% set header_title %}
    Gestion des types de diplôme
{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        {
            href:'',
            title: 'Administration',
        },
        {
            href:'',
            title: 'Gestion des types de diplôme',
        }
    ]}) }}
{% endblock %}

{% block bouton_header %}
    <a href="{{ path('app_type_diplome_new') }}"
       class="btn border border-emerald-300 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 hover:text-emerald-800"
            {{ stimulus_controller('tooltip', {
                placement: 'bottom',
                customClass: 'app-tooltip',
                title: "Ajouter un type de diplôme"
            }) }}
       title="Ajouter un type de diplôme">
        <twig:UX:Icon name="icon:add" class="h-4 w-4"/>
        <span>Ajouter un type de diplôme</span>
    </a>
{% endblock %}
