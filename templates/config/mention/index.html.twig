{% extends 'base.html.twig' %}

{% block content %}
    {{ component('DataTable', { config: table }) }}
{% endblock %}

{% set header_title %}
    {{ 'header.mention.index'|trans({}, 'header') }}
{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        {
            href:'',
            title: 'Administration',
        }
    ]}) }}
{% endblock %}

{% block bouton_header %}
    {% if is_granted('ROLE_ADMIN') %}
{#        <a href="{{ path('app_mention_codification') }}"#}
{#           class="btn btn-sm btn-outline-danger btn-icon btn-icon-end w-100 w-sm-auto mx-2"#}
{#        >#}
{#            <i class="fal fa-wrench"></i>#}
{#            <span> Générer Codification</span>#}
{#        </a>#}
        <button
                {{ stimulus_controller('modal', {
                    size: 'lg',
                    modalTitle: 'Générer Codification',
                    modalUrl: path('app_mention_codification_modal') }) }}
                data-action="click->modal#openModal"
                class="btn border border-amber-300 bg-amber-50 text-amber-700 hover:bg-amber-100 hover:text-amber-800"
                data-size="lg"
                data-bs-toggle="tooltip"
                data-bs-placement="bottom"
                title="Générer Codification"
        >
            <twig:UX:Icon name="icon:wrench" class="h-4 w-4"/>
            <span> Générer Codification</span>
        </button>
    {% endif %}
    <button
            {{ stimulus_controller('modal', {
                size: 'lg',
                modalTitle: 'Ajouter une mention/spécialité',
                modalUrl: path('app_mention_new') }) }}
            data-action="click->modal#openModal"
            class="btn border border-emerald-300 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 hover:text-emerald-800"
            data-size="lg"
            data-bs-toggle="tooltip"
            data-bs-placement="bottom"
            title="Ajouter une mention/spécialité"
    >
        <twig:UX:Icon name="icon:add" class="h-4 w-4"/>
        <span> Ajouter une mention/spécialité</span>
    </button>
{% endblock %}
