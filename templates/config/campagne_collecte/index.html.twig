{% extends 'base.html.twig' %}

{% block content %}
    {{ component('DataTable', { config: table }) }}
{% endblock %}

{% set header_title %}
    Gestion des campagnes de collecte
{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        {
            href:'',
            title: 'Administration',
        },
        {
            href:'',
            title: 'Gestion des campagnes de collecte'
        }
    ]}) }}
{% endblock %}

{% block bouton_header %}
    <a
            data-action="click->modalturbo#open"
            data-turbo="true"
            href="{{ path('app_campagne_collecte_new') }}"
            class="btn border border-emerald-300 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 hover:text-emerald-800"
            {{ stimulus_controller('tooltip', {
                placement: 'bottom',
                customClass: 'app-tooltip',
                title: "Ajouter une campagne de collecte"
            }) }}
    >
        <twig:UX:Icon name="icon:add" class="h-4 w-4"/>
        <span> Ajouter une campagne de collecte</span>
    </a>
{% endblock %}
