{% extends 'base.html.twig' %}
{# todo: proto de mise en page, à voir #}

{% set header_title %}Impersonation Admin - ORéOF{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        {title: 'Pilotage'},
        {title: 'Impersonation Admin'},
    ]}) }}
{% endblock %}

{% block content %}
    <div class="space-y-4">
        <section
                class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900 sm:p-6">
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                <div class="space-y-1">
                    <h1 class="text-lg font-black uppercase tracking-widest text-slate-600 dark:text-slate-300">
                        Impersonation utilisateur</h1>
                    <p class="text-sm text-slate-500 dark:text-slate-400">Sélectionnez un utilisateur pour voir
                        l'application comme lui.</p>
                </div>

                {% if is_granted('IS_IMPERSONATOR') %}
                    <div class="inline-flex flex-col gap-2 rounded-xl border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-900 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-200">
                        <span><strong>Impersonation active</strong> - Utilisateur : {{ app.user.display }}</span>
                        <a href="{{ path('app_homepage', {'_switch_user': '_exit'}) }}"
                           class="inline-flex items-center justify-center rounded-md border border-amber-400 bg-amber-100 px-3 py-1.5 text-xs font-semibold text-amber-900 transition hover:bg-amber-200 dark:border-amber-600 dark:bg-amber-900/40 dark:text-amber-100 dark:hover:bg-amber-900/60">
                            Arrêter l'impersonation
                        </a>
                    </div>
                {% endif %}
            </div>
        </section>

        <section
                class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900 sm:p-6">
            <div class="space-y-2">
                <div class="flex items-center justify-between">
                    <label for="userSearch" class="text-sm font-medium text-slate-700 dark:text-slate-300">Rechercher un
                        utilisateur</label>
                    <span class="text-xs text-slate-500 dark:text-slate-400">💡 Tapez au moins 2 caractères ou utilisez ↑↓ + Entrée</span>
                </div>
                <div class="relative">
                    <form method="get" class="flex flex-col gap-2 sm:flex-row sm:items-center">
                        <input type="text"
                               class="block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-700 shadow-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-200 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 dark:focus:border-cyan-400 dark:focus:ring-cyan-900"
                               name="search"
                               placeholder="Nom, prénom, email ou login..."
                               value="{{ search }}"
                               id="userSearch"
                               aria-label="Recherche utilisateur"
                               aria-expanded="false"
                               aria-controls="searchResults">
                        <button type="submit"
                                class="inline-flex items-center justify-center rounded-lg border border-cyan-300 bg-cyan-50 px-4 py-2 text-sm font-semibold text-cyan-700 transition hover:bg-cyan-100 dark:border-cyan-700 dark:bg-cyan-900/30 dark:text-cyan-200 dark:hover:bg-cyan-900/50">
                            Rechercher
                        </button>
                    </form>

                    <div id="searchResults" class="absolute inset-x-0 top-full z-20 hidden mt-1" role="listbox">
                        <div id="resultsList"
                             class="max-h-96 overflow-y-auto rounded-lg border border-slate-200 bg-white shadow-lg dark:border-slate-700 dark:bg-slate-900"></div>
                    </div>
                </div>
            </div>
        </section>

        <section
                class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
            <div class="overflow-x-auto">
                <table class="min-w-full text-left text-sm text-slate-700 dark:text-slate-200">
                    <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-wide text-slate-500 dark:bg-slate-800/70 dark:text-slate-300">
                    <tr>
                        <th class="px-4 py-3">Login</th>
                        <th class="px-4 py-3">Nom</th>
                        <th class="px-4 py-3">Prénom</th>
                        <th class="px-4 py-3">Email</th>
                        <th class="px-4 py-3">Rôles</th>
                        <th class="px-4 py-3 text-right">Action</th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                    {% for user in users %}
                        <tr class="hover:bg-slate-50/70 dark:hover:bg-slate-800/40">
                            <td class="px-4 py-3"><code
                                        class="rounded bg-slate-100 px-1.5 py-0.5 text-xs dark:bg-slate-800">{{ user.username }}</code>
                            </td>
                            <td class="px-4 py-3">{{ user.nom }}</td>
                            <td class="px-4 py-3">{{ user.prenom }}</td>
                            <td class="px-4 py-3">{{ user.email }}</td>
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1.5">
                                    {% for role in user.roles %}
                                        <span class="inline-flex rounded-full border border-cyan-200 bg-cyan-50 px-2 py-0.5 text-xs font-semibold text-cyan-700 dark:border-cyan-700 dark:bg-cyan-950/30 dark:text-cyan-200">{{ role }}</span>
                                    {% endfor %}
                                </div>
                            </td>
                            <td class="px-4 py-3 text-right">
                                <a href="{{ path('app_homepage', {'_switch_user': user.username}) }}"
                                   class="inline-flex items-center gap-1 rounded-lg border border-indigo-300 bg-indigo-50 px-3 py-2 text-xs font-semibold text-indigo-700 shadow-sm transition hover:bg-indigo-100 hover:shadow-md dark:border-indigo-700 dark:bg-indigo-950/30 dark:text-indigo-200 dark:hover:bg-indigo-900/50"
                                   title="{% trans %}Impersonner{% endtrans %} {{ user.display }}">
                                    <span>🔑</span> Impersonner
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-4 py-6 text-center text-sm text-slate-500 dark:text-slate-400">
                                Aucun utilisateur trouvé
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        {% if totalPages > 1 %}
            <nav aria-label="Pagination" class="space-y-3">
                <div class="flex items-center justify-between rounded-lg bg-slate-50 px-4 py-3 text-sm dark:bg-slate-800/50">
                    <span class="text-slate-600 dark:text-slate-300">
                        <span class="font-semibold">Page {{ page }}</span> sur <span
                                class="font-semibold">{{ totalPages }}</span>
                        <span class="text-slate-500 dark:text-slate-400">({{ total }} utilisateur{{ total > 1 ? 's' : '' }})</span>
                    </span>
                    <div class="flex items-center gap-1">
                        <span class="text-xs text-slate-500 dark:text-slate-400">{{ '%d-%d'|format((page-1)*20 + 1, page*20 < total ? page*20 : total) }} résultats affichés</span>
                    </div>
                </div>

                <div class="flex flex-wrap items-center justify-center gap-2">
                    {% if page > 1 %}
                        <a class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
                           href="{{ path('app_impersonation_list', {page: 1, search: search}) }}"
                           title="Première page">⬅️ Première</a>
                        <a class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
                           href="{{ path('app_impersonation_list', {page: page - 1, search: search}) }}"
                           title="Page précédente">← Précédente</a>
                    {% endif %}

                    {% for p in 1..totalPages %}
                        {% if p == page %}
                            <span class="inline-flex items-center rounded-lg border border-cyan-600 bg-cyan-600 px-3 py-1.5 text-xs font-semibold text-white"
                                  aria-current="page">{{ p }}</span>
                        {% elseif (p >= page - 2 and p <= page + 2) or p == 1 or p == totalPages %}
                            <a class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
                               href="{{ path('app_impersonation_list', {page: p, search: search}) }}"
                               title="Aller à la page {{ p }}">{{ p }}</a>
                        {% elseif p == page - 3 or p == page + 3 %}
                            <span class="inline-flex items-center px-2 text-slate-400">…</span>
                        {% endif %}
                    {% endfor %}

                    {% if page < totalPages %}
                        <a class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
                           href="{{ path('app_impersonation_list', {page: page + 1, search: search}) }}"
                           title="Page suivante">Suivante →</a>
                        <a class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
                           href="{{ path('app_impersonation_list', {page: totalPages, search: search}) }}"
                           title="Dernière page">Dernière ➡️</a>
                    {% endif %}
                </div>
            </nav>
        {% endif %}
    </div>

    <script>
      // Auto-search functionality with keyboard navigation
      const searchInput = document.getElementById('userSearch')
      const searchResults = document.getElementById('searchResults')
      const resultsList = document.getElementById('resultsList')
      const homepageUrl = `{{ path('app_homepage') }}`
      let impersonationUsers = []
      let selectedIndex = -1

      // Handle input event for search
      searchInput.addEventListener('input', async function () {
        const query = this.value.trim()
        selectedIndex = -1

        if (query.length < 2) {
          searchResults.classList.add('hidden')
          searchInput.setAttribute('aria-expanded', 'false')
          return
        }

        try {
          const response = await fetch(`{{ path('app_impersonation_api_search') }}?q=${encodeURIComponent(query)}`)
          const users = await response.json()
          impersonationUsers = users

          if (users.length === 0) {
            searchResults.classList.add('hidden')
            searchInput.setAttribute('aria-expanded', 'false')
            return
          }

          renderResults(users)
          searchResults.classList.remove('hidden')
          searchInput.setAttribute('aria-expanded', 'true')
        } catch (error) {
          console.error('Search error:', error)
          searchResults.classList.add('hidden')
          searchInput.setAttribute('aria-expanded', 'false')
        }
      })

      // Handle keyboard navigation
      searchInput.addEventListener('keydown', function (event) {
        if (!impersonationUsers.length) return

        const items = resultsList.querySelectorAll('[role="option"]')
        const maxIndex = items.length - 1

        switch (event.key) {
          case 'ArrowDown':
            event.preventDefault()
            selectedIndex = Math.min(selectedIndex + 1, maxIndex)
            updateFocus(items)
            break
          case 'ArrowUp':
            event.preventDefault()
            selectedIndex = Math.max(selectedIndex - 1, -1)
            if (selectedIndex === -1) {
              searchInput.focus()
            } else {
              updateFocus(items)
            }
            break
          case 'Enter':
            event.preventDefault()
            if (selectedIndex >= 0 && selectedIndex < impersonationUsers.length) {
              selectUser(selectedIndex)
            }
            break
          case 'Escape':
            event.preventDefault()
            searchResults.classList.add('hidden')
            searchInput.setAttribute('aria-expanded', 'false')
            selectedIndex = -1
            break
        }
      })

      function updateFocus (items) {
        items.forEach((item, idx) => {
          if (idx === selectedIndex) {
            item.classList.add('bg-cyan-100', 'dark:bg-cyan-900/40')
            item.setAttribute('aria-selected', 'true')
            item.focus()
          } else {
            item.classList.remove('bg-cyan-100', 'dark:bg-cyan-900/40')
            item.setAttribute('aria-selected', 'false')
          }
        })
      }

      function renderResults (users) {
        resultsList.innerHTML = users.map((user, index) => `
          <button type="button"
                  class="block w-full border-b border-slate-100 px-4 py-3 text-left transition hover:bg-slate-50 last:border-b-0 dark:border-slate-700 dark:hover:bg-slate-800/60"
                  role="option"
                  aria-selected="false"
                  data-index="${index}"
                  onclick="selectUser(${index})">
            <div class="font-semibold text-slate-800 dark:text-slate-100">${escapeHtml(user.display)}</div>
            <small class="text-slate-500 dark:text-slate-400">${escapeHtml(user.username)} • ${escapeHtml(user.email)}</small>
            <br>
            <small class="text-slate-500 dark:text-slate-400">${escapeHtml(user.roles)}</small>
          </button>
        `).join('')
      }

      // Hide results when clicking outside
      document.addEventListener('click', function (event) {
        if (!event.target.closest('#userSearch') && !event.target.closest('#searchResults')) {
          searchResults.classList.add('hidden')
          searchInput.setAttribute('aria-expanded', 'false')
          selectedIndex = -1
        }
      })

      function selectUser (index) {
        const user = impersonationUsers[index]
        if (!user || !user.username) {
          return
        }

        window.location.href = `${homepageUrl}?_switch_user=${encodeURIComponent(user.username)}`
      }

      function escapeHtml (text) {
        const map = {
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          '\'': '&#039;'
        }
        return text.replace(/[&<>"']/g, m => map[m])
      }
    </script>

{% endblock %}

