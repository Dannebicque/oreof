<div class="row">
    <div class="col-sm-12">
        <dl>
            <dt class="text-[10px] font-black text-indigo-400 uppercase mt-3">Modalités d'enseignement</dt>
            <dd>
                {% if parcours.modalitesEnseignement != null %}
                    <span class="px-2 py-1 bg-indigo-50 rounded-lg text-xs font-bold text-indigo-600 mt-1">
                    {{ parcours.modalitesEnseignement.libelle }}
                </span>
                {% else %}
                    <span class="px-2 py-1 bg-orange-50 rounded-lg text-xs font-bold text-orange-600 mt-1">
                    Non précisé
                </span>
                {% endif %}
            </dd>

            {% if typeDiplome.hasStage or parcours.hasStage == true %}
                <dt class="text-[10px] font-black text-indigo-400 uppercase mt-3">Stage(s)</dt>
                <dd>
                    {% if stringDifferencesParcours.modaliteEnseignementParcours is defined %}
                        {{ include('communs/_comparaison_versioning_no_button.html.twig',
                            {
                                textDifferences: stringDifferencesParcours.modaliteEnseignementParcours,
                                idCollapse: 'diffGlobalParcours'
                            }
                        )
                        }}
                    {% endif %}
                    {% if stringDifferencesParcoursCampagne.modaliteEnseignementParcours is defined %}
                        {{ include('communs/_comparaison_versioning_no_button.html.twig',
                            {
                                textDifferences: stringDifferencesParcoursCampagne.modaliteEnseignementParcours,
                                idCollapse: 'diffGlobalParcoursCampagne'
                            }
                        )
                        }}
                    {% endif %}
                    {% if parcours.hasStage == true %}
                        <span class="px-2 py-1 bg-indigo-50 rounded-lg text-xs font-bold text-indigo-600 mt-1">Oui ({{ parcours.nbHeuresStages }} heures).</span>
                        <br> <p class="mt-1">{{ parcours.stageText|printTexte }}</p>
                        {% if stringDifferencesParcours.stageTextParcours is defined %}
                            {{ include('communs/_comparaison_versioning_no_button.html.twig', {
                                    textDifferences: stringDifferencesParcours.stageTextParcours,
                                    idCollapse: 'diffGlobalParcours'
                            })
                            }}
                        {% endif %}
                        {% if stringDifferencesParcoursCampagne.stageTextParcours is defined %}
                            {{ include('communs/_comparaison_versioning_no_button.html.twig',
                                    {
                                        textDifferences: stringDifferencesParcoursCampagne.stageTextParcours,
                                        idCollapse: 'diffGlobalParcoursCampagne'
                                    }
                                )
                            }}
                        {% endif %}
                        {% if stringDifferencesParcours.parcoursHasStage is defined %}
                            {{ include('communs/_comparaison_versioning_no_button.html.twig',
                                {
                                    textDifferences: stringDifferencesParcours.parcoursHasStage,
                                    idCollapse: 'diffGlobalParcours'
                                }
                            )
                            }}
                        {% endif %}
                        {% if stringDifferencesParcoursCampagne.parcoursHasStage is defined %}
                            {{ include('communs/_comparaison_versioning_no_button.html.twig',
                                {
                                    textDifferences: stringDifferencesParcoursCampagne.parcoursHasStage,
                                    idCollapse: 'diffGlobalParcoursCampagne'
                                }
                            )
                            }}
                        {% endif %}
                    {% else %}
                        <span class="px-2 py-1 bg-orange-50 rounded-lg text-xs font-bold text-orange-600 mt-1">Non</span>
                    {% endif %}
                </dd>
            {% endif %}
            {% if typeDiplome.hasProjet or parcours.hasProjet == true %}
                <dt class="text-[10px] font-black text-indigo-400 uppercase mt-3">Projet(s) tutoré(s)</dt>
                <dd>
                    {% if parcours.hasProjet == true %}
                        <span class="px-2 py-1 bg-indigo-50 rounded-lg text-xs font-bold text-indigo-600 mt-1">Oui ({{ parcours.nbHeuresProjet }} heures).</span>
                        <br> <p class="mt-1"> {{ parcours.projetText|printTexte }}</p>
                    {% else %}
                        <span class="px-2 py-1 bg-orange-50 rounded-lg text-xs font-bold text-orange-600 mt-1">Non</span>
                    {% endif %}
                </dd>
                {% if stringDifferencesParcours.parcoursHasProjet is defined %}
                    {{ include('communs/_comparaison_versioning_no_button.html.twig',
                            {
                                textDifferences: stringDifferencesParcours.parcoursHasProjet,
                                idCollapse: 'diffGlobalParcours'
                            }
                        )
                    }}
                {% endif %}
                {% if stringDifferencesParcoursCampagne.parcoursHasProjet is defined %}
                    {{ include('communs/_comparaison_versioning_no_button.html.twig',
                            {
                                textDifferences: stringDifferencesParcoursCampagne.parcoursHasProjet,
                                idCollapse: 'diffGlobalParcoursCampagne'
                            }
                        )
                    }}
                {% endif %}
                {% if stringDifferencesParcours.projetTexteParcours is defined %}
                    {{ include('communs/_comparaison_versioning_no_button.html.twig',
                            {
                                textDifferences: stringDifferencesParcours.projetTexteParcours,
                                idCollapse: 'diffGlobalParcours'
                            }
                        )
                    }}
                {% endif %}
                {% if stringDifferencesParcoursCampagne.projetTexteParcours is defined %}
                    {{ include('communs/_comparaison_versioning_no_button.html.twig',
                            {
                                textDifferences: stringDifferencesParcoursCampagne.projetTexteParcours,
                                idCollapse: 'diffGlobalParcoursCampagne'
                            }
                        )
                    }}
                {% endif %}
            {% endif %}
            {% if typeDiplome.hasMemoire or parcours.hasMemoire == true %}
                <dt class="text-[10px] font-black text-indigo-400 uppercase mt-3">TER/Mémoire</dt>
                <dd>
                    {% if parcours.hasMemoire == true %}
                        <span class="px-2 py-1 bg-indigo-50 rounded-lg text-xs font-bold text-indigo-600 mt-1">Oui.</span>
                        <br> <p class="mt-1"> {{ parcours.memoireText|printTexte }}</p>
                        {% if stringDifferencesParcours.memoireTextParcours is defined %}
                            {{ include('communs/_comparaison_versioning_no_button.html.twig', {
                                    textDifferences: stringDifferencesParcours.memoireTextParcours,
                                    idCollapse: 'diffGlobalParcours'
                            })
                            }}
                        {% endif %}
                        {% if stringDifferencesParcoursCampagne.memoireTextParcours is defined %}
                            {{ include('communs/_comparaison_versioning_no_button.html.twig',
                                    {
                                        textDifferences: stringDifferencesParcoursCampagne.memoireTextParcours,
                                        idCollapse: 'diffGlobalParcoursCampagne'
                                    }
                                )
                            }}
                        {% endif %}

                        {% if stringDifferencesParcours.hasMemoireParcours is defined %}
                            {{ include('communs/_comparaison_versioning_no_button.html.twig',
                                {
                                    textDifferences: stringDifferencesParcours.hasMemoireParcours,
                                    idCollapse: 'diffGlobalParcours'
                                }
                            )
                            }}
                        {% endif %}
                        {% if stringDifferencesParcoursCampagne.hasMemoireParcours is defined %}
                            {{ include('communs/_comparaison_versioning_no_button.html.twig',
                                {
                                    textDifferences: stringDifferencesParcoursCampagne.hasMemoireParcours,
                                    idCollapse: 'diffGlobalParcoursCampagne'
                                }
                            )
                            }}
                        {% endif %}
                    {% else %}
                        <span class="px-2 py-1 bg-orange-50 rounded-lg text-xs font-bold text-orange-600 mt-1">Non</span>
                    {% endif %}
                </dd>
            {% endif %}
            {% if typeDiplome.hasSituationPro  or parcours.hasSituationPro == true %}
                <dt class="text-[10px] font-black text-indigo-400 uppercase mt-3">Situation professionnelle</dt>
                <dd>
                    {% if parcours.hasSituationPro == true %}
                        <span class="px-2 py-1 bg-indigo-50 rounded-lg text-xs font-bold text-indigo-600 mt-1"> Oui ({{ parcours.nbHeuresSituationPro }} heures).</span>
                    {% else %}
                        <span class="px-2 py-1 bg-orange-50 rounded-lg text-xs font-bold text-orange-600 mt-1">Non</span>
                    {% endif %}
                </dd>
                {% if stringDifferencesParcours.hasSituationProHeures is defined %}
                    {{ include('communs/_comparaison_versioning_no_button.html.twig',
                            {
                                textDifferences: stringDifferencesParcours.hasSituationProHeures,
                                idCollapse: 'diffGlobalParcours'
                            }
                        )
                    }}
                {% endif %}
                {% if stringDifferencesParcoursCampagne.hasSituationProHeures is defined %}
                    {{ include('communs/_comparaison_versioning_no_button.html.twig',
                            {
                                textDifferences: stringDifferencesParcoursCampagne.hasSituationProHeures,
                                idCollapse: 'diffGlobalParcoursCampagne'
                            }
                        )
                    }}
                {% endif %}
            {% endif %}
        </dl>
    </div>
</div>
