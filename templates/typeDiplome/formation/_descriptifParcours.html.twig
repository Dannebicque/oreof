<div class="row">
    <div class="col-sm-12">
        <dl>
            <dt>Modalités d'enseignement</dt>
            <dd>{{ parcours.modalitesEnseignement != null ? parcours.modalitesEnseignement.libelle : 'Erreur' }}</dd>

            {% if stringDifferencesParcours.modaliteEnseignementParcours is defined %}
                {{ include('communs/_comparaison_versioning_no_button.html.twig', 
                        {
                            textDifferences: stringDifferencesParcours.modaliteEnseignementParcours,
                            idCollapse: 'diffGlobalParcours'
                        }
                    )
                }}
            {% endif %}
            {% if stringDifferencesParcoursCampagne.modaliteEnseignementParcours is defined %}
                {{ include('communs/_comparaison_versioning_no_button.html.twig', 
                        {
                            textDifferences: stringDifferencesParcoursCampagne.modaliteEnseignementParcours,
                            idCollapse: 'diffGlobalParcoursCampagne'
                        }
                    )
                }}
            {% endif %}


            {% if typeDiplome.hasStage %}
                <dt>Stage(s)</dt>
                <dd>
                    {% if parcours.hasStage == true %}
                        Oui ({{ parcours.nbHeuresStages }} heures). {{ parcours.stageText|printTexte }}
                    {% else %}
                        Non
                    {% endif %}
                    {% if stringDifferencesParcours.parcoursHasStage is defined %}
                        {{ include('communs/_comparaison_versioning_no_button.html.twig',
                                {
                                    textDifferences: stringDifferencesParcours.parcoursHasStage,
                                    idCollapse: 'diffGlobalParcours'
                                }
                            ) 
                        }}
                    {% endif %}
                    {% if stringDifferencesParcoursCampagne.parcoursHasStage is defined %}
                        {{ include('communs/_comparaison_versioning_no_button.html.twig',
                                {
                                    textDifferences: stringDifferencesParcoursCampagne.parcoursHasStage,
                                    idCollapse: 'diffGlobalParcoursCampagne'        
                                }
                            ) 
                        }}
                    {% endif %}
                    {% if stringDifferencesParcours.stageTextParcours is defined %}
                        {{ include('communs/_comparaison_versioning_no_button.html.twig', {
                                textDifferences: stringDifferencesParcours.stageTextParcours,
                                idCollapse: 'diffGlobalParcours'
                            }) 
                        }}
                    {% endif %}
                    {% if stringDifferencesParcoursCampagne.stageTextParcours is defined %}
                        {{ include('communs/_comparaison_versioning_no_button.html.twig',
                                {
                                    textDifferences: stringDifferencesParcoursCampagne.stageTextParcours,
                                    idCollapse: 'diffGlobalParcoursCampagne'
                                }
                            )
                        }}
                    {% endif %}
                </dd>
            {% endif %}
            {% if typeDiplome.hasProjet %}
                <dt>Projet(s) tutoré(s)</dt>
                <dd>
                    {% if parcours.hasProjet == true %}
                        Oui ({{ parcours.nbHeuresProjet }} heures). {{ parcours.projetText|printTexte }}
                    {% else %}
                        Non
                    {% endif %}
                </dd>
                {% if stringDifferencesParcours.parcoursHasProjet is defined %}
                    {{ include('communs/_comparaison_versioning_no_button.html.twig',
                            {
                                textDifferences: stringDifferencesParcours.parcoursHasProjet,
                                idCollapse: 'diffGlobalParcours'
                            }
                        ) 
                    }}
                {% endif %}
                {% if stringDifferencesParcoursCampagne.parcoursHasProjet is defined %}
                    {{ include('communs/_comparaison_versioning_no_button.html.twig',
                            {
                                textDifferences: stringDifferencesParcoursCampagne.parcoursHasProjet,
                                idCollapse: 'diffGlobalParcoursCampagne'
                            }
                        ) 
                    }}
                {% endif %}
                {% if stringDifferencesParcours.projetTexteParcours is defined %}
                    {{ include('communs/_comparaison_versioning_no_button.html.twig',
                            {
                                textDifferences: stringDifferencesParcours.projetTexteParcours,
                                idCollapse: 'diffGlobalParcours'
                            }
                        ) 
                    }}
                {% endif %}
                {% if stringDifferencesParcoursCampagne.projetTexteParcours is defined %}
                    {{ include('communs/_comparaison_versioning_no_button.html.twig',
                            {
                                textDifferences: stringDifferencesParcoursCampagne.projetTexteParcours,
                                idCollapse: 'diffGlobalParcoursCampagne'
                            }
                        ) 
                    }}
                {% endif %}
            {% endif %}
            {% if typeDiplome.hasMemoire %}
                <dt>TER/Mémoire</dt>
                <dd>
                    {% if parcours.hasMemoire == true %}
                        Oui. {{ parcours.memoireText|printTexte }}
                    {% else %}
                        Non
                    {% endif %}

                    {% if stringDifferencesParcours.hasMemoireParcours is defined %}
                        {{ include('communs/_comparaison_versioning_no_button.html.twig', 
                                {
                                    textDifferences: stringDifferencesParcours.hasMemoireParcours,
                                    idCollapse: 'diffGlobalParcours'
                                }
                            )
                        }}
                    {% endif %}
                    {% if stringDifferencesParcoursCampagne.hasMemoireParcours is defined %}
                        {{ include('communs/_comparaison_versioning_no_button.html.twig', 
                                {
                                    textDifferences: stringDifferencesParcoursCampagne.hasMemoireParcours,
                                    idCollapse: 'diffGlobalParcoursCampagne'
                                }
                            )
                        }}
                    {% endif %}

                    {% if stringDifferencesParcours.memoireTextParcours is defined %}
                        {{ include('communs/_comparaison_versioning_no_button.html.twig', {
                                textDifferences: stringDifferencesParcours.memoireTextParcours,
                                idCollapse: 'diffGlobalParcours'
                            }) 
                        }}
                    {% endif %}
                    {% if stringDifferencesParcoursCampagne.memoireTextParcours is defined %}
                        {{ include('communs/_comparaison_versioning_no_button.html.twig',
                                {
                                    textDifferences: stringDifferencesParcoursCampagne.memoireTextParcours,
                                    idCollapse: 'diffGlobalParcoursCampagne'
                                }
                            )
                        }}
                    {% endif %}
                </dd>
            {% endif %}
            {% if typeDiplome.hasSituationPro %}
                <dt>Situation professionnelle</dt>
                <dd>
                    {% if parcours.hasSituationPro == true %}
                        Oui ({{ parcours.nbHeuresSituationPro }} heures).
                    {% else %}
                        Non
                    {% endif %}
                </dd>
            {% endif %}
        </dl>
    </div>
</div>
