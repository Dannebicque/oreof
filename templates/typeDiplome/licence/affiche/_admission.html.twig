{% set dtClass = 'text-[11px] font-black uppercase tracking-wide text-indigo-500' %}
{% set ddClass = 'mt-2 text-sm leading-relaxed text-slate-700' %}
{% set blockClass = 'rounded-xl border border-slate-200 bg-slate-50 p-4' %}

<div class="space-y-4">
    <dl class="space-y-4">
        <div class="{{ blockClass }}">
            <dt class="{{ dtClass }}">Niveau de français requis</dt>
            <dd class="{{ ddClass }}">{{ parcours.niveauFrancais != null ? parcours.niveauFrancais.libelle : 'Non précisé' }}</dd>
        </div>

        <div class="{{ blockClass }}">
            <dt class="{{ dtClass }}">Prérequis recommandés</dt>
            <dd class="{{ ddClass }}">{{ parcours.prerequis|raw }}</dd>
        </div>

        {% if stringDifferencesParcours.prerequisRecommandesParcours is defined %}
            {{ include('communs/_comparaison_versioning_no_button.html.twig', {
                textDifferences: stringDifferencesParcours.prerequisRecommandesParcours,
                idCollapse: 'diffGlobalParcours'
            }) }}
        {% endif %}
    </dl>
</div>
