<div class="space-y-6">
    <dl class="space-y-4">
        {% if formation.isHasParcours == false and formation.parcours|length == 1 %}
            <div>
                <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Responsable de formation
                </dt>
                <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">{{ parcours.formation.responsableMention != null ? parcours.formation.responsableMention.display : 'Non concerne' }}</dd>
            </div>
            <div>
                <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Co-responsable de
                    formation
                </dt>
                <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">{{ parcours.formation.coResponsable != null ? parcours.formation.coResponsable.display : 'Non concerne' }}</dd>
            </div>
        {% else %}
            <div>
                <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Responsable du parcours
                </dt>
                <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">
                    {{ parcours.respParcours != null ? parcours.respParcours.display : 'Non concerne' }}<br>
                    <a href="mailto:{{ parcours.respParcours != null ? parcours.respParcours.email : 'Non concerne' }}"
                       class="text-xs text-indigo-500 hover:underline">
                        {{ parcours.respParcours != null ? parcours.respParcours.email : 'Non concerne' }}
                    </a>
                </dd>
            </div>
            {% if stringDifferencesParcours.contactsParcoursResponsableParcours is defined %}
                {{ include('communs/_comparaison_versioning_no_button.html.twig',
                    {
                        textDifferences: stringDifferencesParcours.contactsParcoursResponsableParcours,
                        idCollapse: 'diffGlobalParcours'
                    }
                ) }}
            {% endif %}

            {% if parcours.coResponsable != null %}
                <div>
                    <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Co-responsable du
                        parcours
                    </dt>
                    <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">
                        {{ parcours.coResponsable != null ? parcours.coResponsable.display : 'Non concerne' }}<br>
                        <a href="mailto:{{ parcours.coResponsable != null ? parcours.coResponsable.email : 'Non concerne' }}"
                           class="text-xs text-indigo-500 hover:underline">
                            {{ parcours.coResponsable != null ? parcours.coResponsable.email : 'Non concerne' }}
                        </a>
                    </dd>
                </div>
                {% if stringDifferencesParcours.contactsParcoursCoResponsableDuParcours is defined %}
                    {{ include('communs/_comparaison_versioning_no_button.html.twig',
                        {
                            textDifferences: stringDifferencesParcours.contactsParcoursCoResponsableDuParcours,
                            idCollapse: 'diffGlobalParcours'
                        }
                    ) }}
                {% endif %}
            {% endif %}
        {% endif %}
    </dl>

    <div>
        <p class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Coordonnees secretariat</p>
        <div class="mt-3 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
            {% for contact in parcours.contacts %}
                <article
                        class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900">
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-500 dark:text-slate-300">{{ contact.denomination }}</p>
                    <p class="mt-2 text-sm font-medium text-slate-700 dark:text-slate-200">{{ contact.display }}</p>
                    <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{{ contact.telephone|tel_format }}</p>
                    <p class="mt-1 text-sm text-indigo-600 dark:text-indigo-300">{{ contact.email|mailto }}</p>
                    <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{{ contact.adresse != null ? contact.adresse.display|raw : 'Pas d\'adresse' }}</p>
                </article>
            {% else %}
                <p class="text-sm text-slate-500 dark:text-slate-400">Aucun contact de secretariat renseigne.</p>
            {% endfor %}
        </div>
    </div>
</div>
