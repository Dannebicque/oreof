{% set dtClass = 'text-[11px] font-black uppercase tracking-wide text-indigo-500' %}
{% set ddClass = 'mt-2 text-sm leading-relaxed text-slate-700' %}
{% set blockClass = 'rounded-xl border border-slate-200 bg-slate-50 p-4' %}

<div class="space-y-6">
    <dl class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {% if formation.isHasParcours == false and formation.parcours|length == 1 %}
            <div class="{{ blockClass }}">
                <dt class="{{ dtClass }}">Responsable de formation</dt>
                <dd class="{{ ddClass }}">{{ parcours.formation.responsableMention != null ? parcours.formation.responsableMention.display : 'Non concerné' }}</dd>
            </div>
            <div class="{{ blockClass }}">
                <dt class="{{ dtClass }}">Co-responsable de formation</dt>
                <dd class="{{ ddClass }}">{{ parcours.formation.coResponsable != null ? parcours.formation.coResponsable.display : 'Non concerné' }}</dd>
            </div>
        {% else %}
            <div class="{{ blockClass }}">
                <dt class="{{ dtClass }}">Responsable du parcours</dt>
                <dd class="{{ ddClass }}">
                    {{ parcours.respParcours != null ? parcours.respParcours.display : 'Non concerné' }}<br>
                    <a href="mailto:{{ parcours.respParcours != null ? parcours.respParcours.email : 'Non concerné' }}"
                       class="text-xs text-indigo-500 hover:underline">
                        {{ parcours.respParcours != null ? parcours.respParcours.email : 'Non concerné' }}
                    </a>
                </dd>
            </div>
            {% if stringDifferencesParcours.contactsParcoursResponsableParcours is defined %}
                {{ include('communs/_comparaison_versioning_no_button.html.twig',
                    {
                        textDifferences: stringDifferencesParcours.contactsParcoursResponsableParcours,
                        idCollapse: 'diffGlobalParcours'
                    }
                ) }}
            {% endif %}

            {% if parcours.coResponsable != null %}
                <div class="{{ blockClass }}">
                    <dt class="{{ dtClass }}">Co-responsable du parcours</dt>
                    <dd class="{{ ddClass }}">
                        {{ parcours.coResponsable != null ? parcours.coResponsable.display : 'Non concerné' }}<br>
                        <a href="mailto:{{ parcours.coResponsable != null ? parcours.coResponsable.email : 'Non concerné' }}"
                           class="text-xs text-indigo-500 hover:underline">
                            {{ parcours.coResponsable != null ? parcours.coResponsable.email : 'Non concerné' }}
                        </a>
                    </dd>
                </div>
                {% if stringDifferencesParcours.contactsParcoursCoResponsableDuParcours is defined %}
                    {{ include('communs/_comparaison_versioning_no_button.html.twig',
                        {
                            textDifferences: stringDifferencesParcours.contactsParcoursCoResponsableDuParcours,
                            idCollapse: 'diffGlobalParcours'
                        }
                    ) }}
                {% endif %}
            {% endif %}
        {% endif %}
    </dl>

    <div>
        <p class="{{ dtClass }}">Coordonnées secrétariat</p>
        <div class="mt-3 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
            {% for contact in parcours.contacts %}
                <article
                        class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-500">{{ contact.denomination }}</p>
                    <p class="mt-2 text-sm font-medium text-slate-700">{{ contact.display }}</p>
                    <p class="mt-2 text-sm text-slate-600">{{ contact.telephone|tel_format }}</p>
                    <p class="mt-1 text-sm text-indigo-600">{{ contact.email|mailto }}</p>
                    <p class="mt-2 text-sm text-slate-600">{{ contact.adresse != null ? contact.adresse.display|raw : 'Pas d\'adresse' }}</p>
                </article>
            {% else %}
                <p class="text-sm text-slate-500">Aucun contact de secrétariat renseigné.</p>
            {% endfor %}
        </div>
    </div>
</div>
