<div class="space-y-4">
    <dl class="space-y-4">
        <div>
            <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Organisation de la formation
            </dt>
            <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">{{ parcours.contenuFormation|printTexte }}</dd>
        </div>
            {% if stringDifferencesParcours.presentationParcoursContenuFormation is defined %}
                {{ include('communs/_comparaison_versioning_no_button.html.twig',
                    {
                        textDifferences: stringDifferencesParcours.presentationParcoursContenuFormation,
                        idCollapse: 'diffGlobalParcours'
                    }
                ) }}
            {% endif %}

        <div>
            <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Objectifs du parcours</dt>
            <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">{{ parcours.objectifsParcours|printTexte }}</dd>
        </div>
        <div>
            <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Mots cles du parcours</dt>
            <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">{{ parcours.motsCles|printTexte }}</dd>
        </div>
            {% if stringDifferencesParcours.presentationParcoursObjectifsParcours is defined %}
                {{ include('communs/_comparaison_versioning_no_button.html.twig',
                    {
                        textDifferences: stringDifferencesParcours.presentationParcoursObjectifsParcours,
                        idCollapse: 'diffGlobalParcours'
                    }
                ) }}
            {% endif %}

        <div>
            <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Resultats attendus du
                parcours
            </dt>
            <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">{{ parcours.resultatsAttendus|printTexte }}</dd>
        </div>
            {% if stringDifferencesParcours.presentationParcoursResultatsAttendus is defined %}
                {{ include('communs/_comparaison_versioning_no_button.html.twig',
                    {
                        textDifferences: stringDifferencesParcours.presentationParcoursResultatsAttendus,
                        idCollapse: 'diffGlobalParcours'
                    }
                ) }}
            {% endif %}

        <div>
            <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Rythme de formation</dt>
            <dd class="mt-1">
                {% if parcours.rythmeFormation != null %}
                    <span class="px-2 py-1 bg-indigo-50 rounded-lg text-xs font-bold text-indigo-600">
                    {{ parcours.rythmeFormation.libelle }}
                </span>
                {% else %}
                    <span class="px-2 py-1 bg-orange-50 rounded-lg text-xs font-bold text-orange-600">
                    Non precise
                </span>
                {% endif %}
            </dd>
        </div>
            {% if stringDifferencesParcours.rythmeFormationParcours is defined %}
                {{ include('communs/_comparaison_versioning_no_button.html.twig', {
                    textDifferences: stringDifferencesParcours.rythmeFormationParcours,
                    idCollapse: 'diffGlobalParcours'
                }) }}
            {% endif %}

        <div>
            <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Precisions sur le rythme de
                formation
            </dt>
            <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">
                {% if parcours.rythmeFormationTexte != null and parcours.rythmeFormationTexte != '' %}
                    {{ parcours.rythmeFormationTexte|printTexte }}
                {% else %}
                    <span class="px-2 py-1 bg-orange-50 rounded-lg text-xs font-bold text-orange-600">
                    Non precise
                </span>
                {% endif %}
            </dd>
        </div>
    </dl>
</div>
