{% set dtClass = 'text-[11px] font-black uppercase tracking-wide text-indigo-500' %}
{% set ddClass = 'mt-2 text-sm leading-relaxed text-slate-700' %}
{% set blockClass = 'rounded-xl border border-slate-200 bg-slate-50 p-4' %}

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div>
        <dl class="space-y-4">
            <div class="{{ blockClass }}">
                <dt class="{{ dtClass }}">Localisation(s) de la mention/spécialité</dt>
                <dd class="{{ ddClass }}">{% for ville in formation.localisationMention %}{{ ville.libelle }}{% if not loop.last %}, {% endif %}{% endfor %}</dd>
            </div>
            {% if stringDifferencesFormation.localisationMention is defined %}
                {{ include('communs/_comparaison_versioning_no_button.html.twig',
                    {
                        textDifferences: stringDifferencesFormation.localisationMention,
                        idCollapse: 'diffGlobalParcours'
                    }
                ) }}
            {% endif %}
            <div class="{{ blockClass }}">
                <dt class="{{ dtClass }}">Régime(s) d'inscription</dt>
                <dd class="{{ ddClass }}">
                    <ul class="list-disc pl-5">
                        {% for regime in formation.regimeInscription %}
                            <li>{{ regime.value }}</li>
                        {% endfor %}
                    </ul>
                    {{ formation.regimeInscriptionTexte }}
                    {% if stringDifferencesFormation.regimeInscriptionFormation is defined %}
                        {{ include('communs/_comparaison_versioning_no_button.html.twig', {
                            textDifferences: stringDifferencesFormation.regimeInscriptionFormation,
                            idCollapse: 'diffGlobalParcours'
                        }) }}
                    {% endif %}
                </dd>
            </div>
            <div class="{{ blockClass }}">
                <dt class="{{ dtClass }}">Modalités de l'alternance</dt>
                <dd class="{{ ddClass }}">{{ formation.modalitesAlternance|raw }}</dd>
            </div>
        </dl>
    </div>

    <div>
        <p class="{{ dtClass }}">Composante(s) d'inscription</p>
        {% if stringDifferencesFormation.composanteInscriptionFormation is defined %}
            {{ include("communs/_comparaison_versioning_no_button.html.twig", {
                textDifferences: stringDifferencesFormation.composanteInscriptionFormation,
                idCollapse: 'diffGlobalParcours'
            }) }}
        {% endif %}
        <div class="mt-3 space-y-4">
            {% for composante in formation.composantesInscription %}
                <article
                        class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                    <p class="text-sm font-semibold text-slate-800">{{ composante.libelle }}</p>
                    <div class="mt-2 space-y-1 text-sm text-slate-600">
                        <p>{{ composante.adresse != null ? composante.adresse.display|raw : 'Erreur' }}</p>
                        <p>{{ composante.telStandard|tel_format }} {% if composante.telComplementaire != null %}ou {{ composante.telComplementaire|tel_format }}{% endif %}</p>
                        <p>{{ composante.mailContact|mailto }}</p>
                        <p>{{ composante.urlSite|open_url }}</p>
                    </div>
                </article>
            {% else %}
                <p class="text-sm text-slate-500">Aucune composante d'inscription renseignée.</p>
            {% endfor %}
        </div>
    </div>
</div>
