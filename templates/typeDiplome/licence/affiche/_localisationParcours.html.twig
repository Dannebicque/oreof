<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div>
        <dl class="space-y-4">
            <div>
                <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Localisation du parcours
                </dt>
                <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">{{ parcours != null and parcours.localisation != null ? parcours.localisation.libelle : 'Erreur' }}</dd>
            </div>

            <div>
                <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Regime(s) d'inscription
                </dt>
                <dd class="mt-1">
                    {% if parcours != null and parcours.regimeInscription != null %}
                        <div class="flex flex-wrap gap-2">
                            {% for regime in parcours.regimeInscription %}
                                <span class="rounded-lg bg-indigo-50 px-2 py-1 text-xs font-bold text-indigo-600">{{ regime.value }}</span>
                            {% endfor %}
                        </div>
                    {% endif %}
                </dd>
            </div>

            {% if stringDifferencesParcours.regimeInscriptionParcours is defined %}
                {{ include("communs/_comparaison_versioning_no_button.html.twig", {
                    textDifferences: stringDifferencesParcours.regimeInscriptionParcours,
                    idCollapse: 'diffGlobalParcours'
                }) }}
            {% endif %}

            <div>
                <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Modalites de l'alternance
                </dt>
                <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">{{ parcours.modalitesAlternance|raw }}</dd>
            </div>
        </dl>
    </div>

    <div>
        {% if parcours.composanteInscription != null %}
            <div>
                <p class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Composante d'inscription</p>
                <article
                        class="mt-2 rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900">
                    <p class="text-sm font-semibold text-slate-800 dark:text-slate-100">{{ parcours.composanteInscription.libelle }}</p>
                    <div class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-300">
                        <p>{{ parcours.composanteInscription.adresse != null ? parcours.composanteInscription.adresse.display|raw : 'Erreur' }}</p>
                        <p>{{ parcours.composanteInscription.telStandard|tel_format }} {% if parcours.composanteInscription.telComplementaire != null %}ou {{ parcours.composanteInscription.telComplementaire|tel_format }}{% endif %}</p>
                        <p>{{ parcours.composanteInscription.mailContact|mailto }}</p>
                        <p>{{ parcours.composanteInscription.urlSite|open_url }}</p>
                    </div>
                </article>
            </div>
        {% else %}
            <p class="text-sm text-slate-500 dark:text-slate-400">Non precise</p>
        {% endif %}
    </div>
</div>
