{% set dtClass = 'text-[11px] font-black uppercase tracking-wide text-indigo-500' %}
{% set ddClass = 'mt-2 text-sm leading-relaxed text-slate-700' %}
{% set blockClass = 'rounded-xl border border-slate-200 bg-slate-50 p-4' %}

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div>
        <dl class="space-y-4">
            <div class="{{ blockClass }}">
                <dt class="{{ dtClass }}">Localisation du parcours</dt>
                <dd class="{{ ddClass }}">{{ parcours != null and parcours.localisation != null ? parcours.localisation.libelle : 'Erreur' }}</dd>
            </div>

            <div class="{{ blockClass }}">
                <dt class="{{ dtClass }}">Régime(s) d'inscription</dt>
                <dd class="mt-1">
                    {% if parcours != null and parcours.regimeInscription != null %}
                        <div class="flex flex-wrap gap-2">
                            {% for regime in parcours.regimeInscription %}
                                <span class="inline-flex items-center rounded-full bg-indigo-100 px-2.5 py-1 text-xs font-bold text-indigo-700">{{ regime.value }}</span>
                            {% endfor %}
                        </div>
                    {% endif %}
                </dd>
            </div>

            {% if stringDifferencesParcours.regimeInscriptionParcours is defined %}
                {{ include("communs/_comparaison_versioning_no_button.html.twig", {
                    textDifferences: stringDifferencesParcours.regimeInscriptionParcours,
                    idCollapse: 'diffGlobalParcours'
                }) }}
            {% endif %}

            <div class="{{ blockClass }}">
                <dt class="{{ dtClass }}">Modalités de l'alternance</dt>
                <dd class="{{ ddClass }}">{{ parcours.modalitesAlternance|raw }}</dd>
            </div>
        </dl>
    </div>

    <div>
        {% if parcours.composanteInscription != null %}
            <div>
                <p class="{{ dtClass }}">Composante d'inscription</p>
                <article
                        class="mt-2 rounded-xl border border-slate-200 bg-slate-50 p-4">
                    <p class="text-sm font-semibold text-slate-800">{{ parcours.composanteInscription.libelle }}</p>
                    <div class="mt-2 space-y-1 text-sm text-slate-600">
                        <p>{{ parcours.composanteInscription.adresse != null ? parcours.composanteInscription.adresse.display|raw : 'Erreur' }}</p>
                        <p>{{ parcours.composanteInscription.telStandard|tel_format }} {% if parcours.composanteInscription.telComplementaire != null %}ou {{ parcours.composanteInscription.telComplementaire|tel_format }}{% endif %}</p>
                        <p>{{ parcours.composanteInscription.mailContact|mailto }}</p>
                        <p>{{ parcours.composanteInscription.urlSite|open_url }}</p>
                    </div>
                </article>
            </div>
        {% else %}
            <p class="text-sm text-slate-500">Non précisé</p>
        {% endif %}
    </div>
</div>
