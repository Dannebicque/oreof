<div class="space-y-4">
    <dl class="space-y-4">
        <div>
            <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Poursuites d'etudes
                envisageables
            </dt>
            <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">{{ parcours.poursuitesEtudes|raw }}</dd>
        </div>
        {% if stringDifferencesParcours.poursuiteEtudesParcours is defined %}
            {{ include('communs/_comparaison_versioning_no_button.html.twig', {
                textDifferences: stringDifferencesParcours.poursuiteEtudesParcours,
                idCollapse: 'diffGlobalParcours'
            }) }}
        {% endif %}

        <div>
            <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Debouches</dt>
            <dd class="mt-1 text-sm text-slate-700 dark:text-slate-200">{{ parcours.debouches|raw }}</dd>
        </div>
        {% if stringDifferencesParcours.debouchesTextParcours is defined %}
            {{ include('communs/_comparaison_versioning_no_button.html.twig', {
                textDifferences: stringDifferencesParcours.debouchesTextParcours,
                idCollapse: 'diffGlobalParcours'
            }) }}
        {% endif %}

        <div>
            <dt class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Code ROME</dt>
            <dd class="mt-1 flex flex-wrap gap-2">
                {% for code in parcours.codesRome %}
                    <span class="rounded-lg bg-indigo-50 px-2 py-1 text-xs font-bold text-indigo-600">{{ code.code }}</span>
                {% else %}
                    <span class="text-sm text-slate-500 dark:text-slate-400">Aucun code ROME.</span>
                {% endfor %}
            </dd>
        </div>
    </dl>
</div>
