{% block stylesheets %}
    <style>
        {{ cssDiff ?? "" }}
        {{ include('communs/versioning_view_style.html.twig') }}
    </style>
{% endblock %}

{% set dtClass = 'text-[11px] font-black uppercase tracking-wide text-indigo-500' %}
{% set textBoxClass = 'mt-2 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm leading-relaxed text-slate-700' %}

<div class="space-y-4">
    <div class="rounded-xl border border-slate-200 bg-white/70 p-4">
        <dl>
            <dt class="{{ dtClass }}">Description de l’enseignement</dt>
            <dd class="{{ textBoxClass }}">
                {{ ficheMatiere.description|raw }}
            </dd>
            {% if
                is_granted('ROLE_ADMIN')
                and stringDifferences.descriptionEnseignement is defined
                and stringDifferences.descriptionEnseignement|length > 0 %}
                {{ include("communs/_comparaison_versioning_big.html.twig", {
                    textDifferences: stringDifferences.descriptionEnseignement,
                    idCollapse: "diffDescriptionFicheMatiere"
                }) }}
            {% endif %}
        </dl>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
            <dl>
                <dt class="{{ dtClass }}">Enseignement dispensé en</dt>
                <dd class="mt-2 text-sm text-slate-700">
                    <ul class="list-disc space-y-1 pl-5">
                    {% for langue in ficheMatiere.langueDispense %}
                        <li>{{ langue.libelle }}</li>
                    {% else %}
                        <li>Non renseigné</li>
                    {% endfor %}
                </ul>
                </dd>
            {% if is_granted('ROLE_ADMIN')
                and stringDifferences.languesEnseignement is defined
                and stringDifferences.languesEnseignement|length > 0 %}
                {{ include("communs/_comparaison_versioning_big.html.twig", {
                    textDifferences: stringDifferences.languesEnseignement,
                    idCollapse: "diffLanguesDispense"
                }) }}
            {% endif %}
        </dl>
        </div>

        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
            <dl>
                <dt class="{{ dtClass }}">Support de cours en</dt>
                <dd class="mt-2 text-sm text-slate-700">
                    <ul class="list-disc space-y-1 pl-5">
                    {% for langue in ficheMatiere.langueSupport %}
                        <li>{{ langue.libelle }}</li>
                    {% else %}
                        <li>Non renseigné</li>
                    {% endfor %}
                </ul>
                </dd>
            {% if is_granted('ROLE_ADMIN')
                and stringDifferences.supportDeCoursEn is defined
                and stringDifferences.supportDeCoursEn|length > 0 %}
                {{ include("communs/_comparaison_versioning_big.html.twig", {
                    textDifferences: stringDifferences.supportDeCoursEn,
                    idCollapse: "diffSupportDeCoursEn"
                }) }}
            {% endif %}
        </dl>
        </div>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white/70 p-4">
        <dl>
            <dt class="{{ dtClass }}">Objectifs de l'enseignement</dt>
            <dd class="{{ textBoxClass }}">
                {{ ficheMatiere.objectifs|raw }}
            </dd>
            {% if is_granted('ROLE_ADMIN')
                and stringDifferences.objectifsEnseignement is defined
                and stringDifferences.objectifsEnseignement|length > 0 %}
                {{ include("communs/_comparaison_versioning_big.html.twig", {
                    textDifferences: stringDifferences.objectifsEnseignement,
                    idCollapse: "diffObjectifsEnseignement"
                }) }}
            {% endif %}
        </dl>
    </div>
</div>
