{% if ue.ue.ueRaccrochee == true %}
    {% set raccrocheUe = true or isSemestreRaccroche %}
{% else %}
    {% set raccrocheUe = false or isSemestreRaccroche %}
{% endif %}

{% set editableCfvu = isAccessible(dpeParcours, 'cfvu') %}

<tr>
    <th colspan="7"
        class="px-4 py-2 text-left text-sm font-bold bg-slate-100 border-y border-slate-200 text-slate-800">{{ ue.ue.display(parcours) }} {% if raccrocheUe == true %}
            <i
                class="fa fa-link"></i>{% endif %}

        {% if ue.ue.natureUeEc is defined and ue.ue.natureUeEc != null and ue.ue.natureUeEc.libre == true %}
            <span class="inline-flex items-center rounded-full bg-slate-200 px-2 py-0.5 text-xs font-semibold text-slate-700">
            UE à choix libre</span>
        {% endif %}
        {% if ue.ue.natureUeEc is defined and ue.ue.natureUeEc != null and ue.ue.natureUeEc.choix == true %}<span
                class="inline-flex items-center rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-semibold text-indigo-700">
            UE à choix restreint : {{ ue.uesEnfants|length }} choix possibles</span>
        {% endif %}
    </th>
</tr>
<tr>
    <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 border-b border-slate-200">
        EC
    </th>
    <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 border-b border-slate-200">
        Fiche
    </th>
    <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 border-b border-slate-200">
        Type EC
    </th>
    <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 border-b border-slate-200">
        ECTS
    </th>
    <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 border-b border-slate-200">
        BCC
    </th>
    <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 border-b border-slate-200">
        Vol. Horaire
    </th>
    <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 border-b border-slate-200">
        MCCC
    </th>
</tr>
{% for ec in ue.elementConstitutifs %}
    {{ include('typeDiplome/licence/liste-ec/_ec.html.twig', {ec:ec, enfant:false}) }}
    {% for ece in ec.elementsConstitutifsEnfants %}
        {{ include('typeDiplome/licence/liste-ec/_ec.html.twig', {ec:ece, enfant:true}) }}
    {% endfor %}
{% endfor %}
