<div class="space-y-6" {{ stimulus_controller('structure--affichage') }}>
	{% set presentiel = parcours.modalitesEnseignement != null and (parcours.modalitesEnseignement.value == 0 or parcours.modalitesEnseignement.value == 1) %}
	{% set distanciel = parcours.modalitesEnseignement != null and (parcours.modalitesEnseignement.value == 2 or parcours.modalitesEnseignement.value == 1) %}

	{% if (print is not defined or print == false) and diffStructure is defined and diffStructure != null %}
		<div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900">
			<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
				<div class="space-y-1 text-xs">
					<p class="show_current text-slate-600 dark:text-slate-300">
						Mode d'affichage: <span
								class="font-semibold text-slate-900 dark:text-slate-100">Saisie courante</span>
					</p>
					<p class="show_versioning d-none text-slate-600 dark:text-slate-300">
						Mode d'affichage: <span class="font-semibold text-indigo-700 dark:text-indigo-300">Comparaison versionning</span>
					</p>
				</div>

				<twig:Button
						label="Afficher/masquer la comparaison"
						variant="info"
						size="sm"
						:outline="true"
						icon="icon:eye"
						dataAction="click->structure--affichage#toggleVersioning"
				/>
			</div>
		</div>
	{% endif %}

	{% for annee in dto.annees %}
		{{ include('typeDiplome/licence/structure/v2/_structure_annee.html.twig', {annee:annee}) }}
	{% endfor %}

	{# todo:  bilan formation #}
</div>
