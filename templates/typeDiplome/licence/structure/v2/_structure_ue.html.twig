<div class="flex items-start justify-between gap-4 border-b border-slate-200 bg-slate-50 px-4 py-3 text-[10px] font-bold uppercase tracking-tight text-slate-400 {% if enfant is defined and enfant %}border-l-4 border-l-amber-300 bg-amber-50/40{% endif %}">

    <div class="flex items-center gap-4">
        <div class="flex h-12 min-w-12 items-center justify-center rounded-md {% if enfant is defined and enfant %}bg-amber-600 shadow-amber-100{% else %}bg-indigo-600 shadow-indigo-100{% endif %} text-white font-black shadow-lg">
            <span>{{ ue.display }}</span>
        </div>

        <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-2">
                <span class="text-sm font-semibold normal-case tracking-normal text-slate-800">
                    {{ ue.ue.libelle }}
                </span>
                {% if ue.raccroche == true %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-amber-100 px-2 py-1 text-[10px] font-black text-amber-700">
                        <i class="fal fa-link"></i> Raccrochée
                    </span>
                {% endif %}
                {% if ue.ue.ueMutualisables|length >0 %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-sky-100 px-2 py-1 text-[10px] font-black text-sky-700"
                          data-controller="tooltip"
                          data-tooltip-placement-value="bottom"
                          title="UE mutualisée">
                        <i class="fal fa-share-nodes"></i> Mutualisée
                    </span>
                {% endif %}
                {% if is_granted('ROLE_ADMIN') %}
                    <span class="rounded-full bg-slate-200 px-2 py-1 text-[10px] font-semibold text-slate-500 normal-case">#{{ ue.ue.id }}</span>
                {% endif %}
            </div>

            {% if isVersioning is not defined or isVersioning == false %}
                <p class="mt-1 text-xs font-medium normal-case text-slate-500">Code Apogée : {{ ue.codeApogee() }}</p>
            {% endif %}
        </div>
    </div>

    <span class="flex flex-wrap items-center justify-end gap-2 text-indigo-600 font-black whitespace-nowrap">
        {% if ue.ue.natureUeEc is defined and ue.ue.natureUeEc != null and ue.ue.natureUeEc.libre == true %}
            <twig:Badge label="UE a choix libre" variant="secondary"/>
        {% endif %}
        {% if ue.uesEnfants|length > 0 %}
            <twig:Badge label="UE a choix restreint : {{ ue.uesEnfants|length }} choix possibles" variant="info"/>
        {% endif %}
    </span>
</div>

{% if ue.ue.natureUeEc is defined and ue.ue.natureUeEc != null and ue.ue.natureUeEc.libre == true %}

    {# ---- Cas 1 : UE à choix libre ---- #}
    {% if presentiel %}{% set colspan = 4 %}{% elseif distanciel %}{% set colspan = 8 %}{% else %}{% set colspan = 0 %}{% endif %}
    <table class="w-full text-xs">
        <tbody>
        <tr class="ec">
            <td colspan="{{ colspan + 5 }}"
                class="px-4 py-4 text-sm leading-relaxed text-slate-700 bg-slate-50/60">{{ ue.ue.descriptionUeLibre }}</td>
        </tr>
        </tbody>
        <tfoot class="text-[10px] font-black uppercase tracking-tighter text-slate-600 bg-slate-50/30 border-b border-slate-100 text-center">
        {% include 'typeDiplome/licence/structure/v2/_structure_ue_tfoot.html.twig' %}
        </tfoot>
    </table>

{% elseif ue.uesEnfants|length > 0 %}

    {# ---- Cas 2 : UE à choix restreint — les sous-UEs sont des blocs autonomes ---- #}
    {% for ueE in ue.uesEnfants %}
        {{ include('typeDiplome/licence/structure/v2/_structure_ue.html.twig', {ue: ueE, enfant: true, diffUe: diffUe.uesEnfants[loop.index0] ?? null}) }}
    {% endfor %}

    {# Total de l'UE parente dans son propre tableau (hors des sous-tables) #}
    <table class="w-full text-xs">
        <tfoot class="text-[10px] font-black uppercase tracking-tighter text-slate-600 bg-slate-50/30 border-b border-slate-100 text-center">
        {% include 'typeDiplome/licence/structure/v2/_structure_ue_tfoot.html.twig' %}
        </tfoot>
    </table>

{% else %}

    {# ---- Cas 3 : UE normale avec ECs ---- #}
    <table class="w-full text-xs bg-white">
        <thead class="text-[10px] font-black uppercase tracking-tighter text-slate-400 bg-slate-50/50 border-b border-slate-100 text-center">
        <tr class="ec">
            <th class="px-5 py-3 text-left w-2/5 font-bold">Fiche EC/Matière</th>
            <th class="py-3">MCCC</th>
            <th class="py-3">ECTS</th>
            {% if presentiel %}
                <th class="w-14 py-3 bg-blue-50/30 text-blue-500">CM</th>
                <th class="w-14 py-3 bg-blue-50/30 text-blue-500">TD</th>
                <th class="w-14 py-3 bg-blue-50/30 text-blue-500">TP</th>
                <th class="w-14 py-3 bg-blue-50/30 text-blue-500">Total Prés.</th>
                <th class="w-14 py-3 bg-blue-50/30 text-blue-500 border-r border-slate-100">TE</th>
            {% endif %}
            {% if distanciel %}
                <th class="w-14 py-3 bg-orange-50/30 text-orange-400">CM</th>
                <th class="w-14 py-3 bg-orange-50/30 text-orange-400">TD</th>
                <th class="w-14 py-3 bg-orange-50/30 text-orange-400">TP</th>
                <th class="w-14 py-3 bg-orange-50/30 text-orange-400 border-r border-slate-100">Total Dis.</th>
            {% endif %}
            {% if parcours.modalitesEnseignement != null and parcours.modalitesEnseignement.value == 1 %}
                <th class="px-5 py-3 text-right text-slate-900">Total</th>
            {% endif %}
        </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
        {% for ordEc, ec in ue.elementConstitutifs %}
            {% set indexEc = loop.index0 %}
            {{ include('typeDiplome/licence/structure/v2/_structure_ec.html.twig', {
                ec: ec,
                semestreOrdre: semestreOrdre,
                ecEnfant: false,
                diffEc: diffUe.elementConstitutifs[ordEc] ?? null,
                indexEc: indexEc,
                indexEcEnfant: -1,
                UeDisplay: ue.display
            }) }}
            {% for ordEce, ece in ec.elementsConstitutifsEnfants %}
                {% set indexEcEnfant = loop.index0 %}
                {{ include('typeDiplome/licence/structure/v2/_structure_ec.html.twig', {
                    ec: ece,
                    semestreOrdre: semestreOrdre,
                    ecEnfant: true,
                    diffEc: diffUe.elementConstitutifs[ordEc].ecEnfants[ordEce] ?? null,
                    indexEc: indexEc,
                    indexEcEnfant: indexEcEnfant,
                    UeDisplay: ue.display
                }) }}
            {% endfor %}
        {% endfor %}
        </tbody>
        <tfoot class="text-[10px] font-black uppercase tracking-tighter text-slate-600 bg-slate-50/30 border-b border-slate-100 text-center">
        {% include 'typeDiplome/licence/structure/v2/_structure_ue_tfoot.html.twig' %}
        </tfoot>
    </table>

{% endif %}

