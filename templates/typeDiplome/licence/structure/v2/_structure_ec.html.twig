{% set cellClass = 'px-3 py-3 align-top' %}
{% set metricCellClass = 'px-3 py-3 align-top text-center tabular-nums font-semibold text-slate-700' %}
{% set metricPresClass = metricCellClass ~ ' bg-blue-50/20' %}
{% set metricDistClass = metricCellClass ~ ' bg-orange-50/20 text-orange-700' %}
{% set metricTotalClass = metricCellClass ~ ' font-black text-slate-900' %}
{% set rowClass = ecEnfant ? 'bg-indigo-50/40 hover:bg-indigo-50/70' : 'hover:bg-slate-50/70' %}

<tr class="ec border-b border-slate-100 transition-colors {{ rowClass }}">
    <td class="{{ cellClass }} border-l-4 border-indigo-500">
        <div class="flex flex-col gap-2">
            <div class="flex items-start gap-3">
                {% if ecEnfant %}
                    <span class="mt-1 inline-flex shrink-0 items-center gap-2 rounded-full border border-indigo-200 bg-white/90 px-2 py-1 text-[10px] font-black uppercase tracking-wide text-indigo-600 shadow-sm">
                        <span class="inline-flex h-2 w-2 rounded-full bg-indigo-500"></span>
                        {{ ec.elementConstitutif.code }}
                    </span>
                {% endif %}

                <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-2">
                        {% if not ecEnfant %}
                            {% if (isBut is defined and isBut == false) or isBut is not defined %}
                                <span class="mt-1 inline-flex shrink-0 items-center gap-2 rounded-full border border-indigo-200 px-2 py-1 text-[10px] font-black uppercase tracking-wide text-indigo-600 shadow-sm bg-slate-100">
                            {{ ec.elementConstitutif.code }}</span>
                            {% endif %}
                        {% endif %}

                        {% if ec.elementConstitutif.ficheMatiere != null %}
                            <a href="{{ url('fiche_matiere_v2_voir', {slug: ec.elementConstitutif.ficheMatiere.slug}) }}"
                               target="_blank"
                               class="min-w-0 text-sm font-semibold leading-relaxed text-slate-800 hover:text-indigo-700 hover:underline">
                                {% if isBut is defined and isBut == true %}
                                    <span class="font-black">{{ ec.elementConstitutif.ficheMatiere.sigle }}</span>
                                    {{ ec.elementConstitutif.ficheMatiere.libelle }}
                                {% else %}
                                    <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.libelle|displayDiff : '' }}</span>
                                    <span class="show_current">{{ ec.elementConstitutif.ficheMatiere.display }}</span>
                                {% endif %}
                            </a>
                        {% else %}
                            <span class="text-sm font-semibold leading-relaxed text-slate-800">
                                <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.libelle|displayDiff : '' }}</span>
                                <span class="show_current">{{ ec.elementConstitutif.libelle }}</span>
                            </span>
                        {% endif %}
                    </div>

                    {% if isVersioning is not defined or isVersioning == false %}
                        <p class="mt-1 text-xs font-medium {% if ecEnfant %}text-indigo-500/80{% else %}text-slate-500{% endif %}">
                            Code Apogée : {{ ec.elementConstitutif.displayCodeApogee }}</p>
                    {% endif %}

                    <div class="mt-2 flex flex-wrap items-center gap-2 text-xs">
                        {% if source is defined and source != 'codification' and ec.elementConstitutif.ficheMatiere != null %}
                            {{ ec.elementConstitutif.ficheMatiere.etatFiche|badgeFiche }}
                        {% endif %}

                        {% if ec.elementConstitutif.natureUeEc is defined
                            and ec.elementConstitutif.natureUeEc != null
                            and ec.elementConstitutif.natureUeEc.isLibre == true %}
                            <twig:Badge label="EC a choix libre" variant="success"/>
                        {% endif %}

                        {% if ec.elementsConstitutifsEnfants|length > 0 %}
                            <twig:Badge
                                    label="EC a choix restreint : {{ ec.elementsConstitutifsEnfants|length }} choix possibles"
                                    variant="info"/>
                        {% endif %}

                        {% if is_granted('ROLE_ADMIN') %}
                            <span class="rounded-full bg-slate-100 px-2 py-1 text-[11px] font-semibold text-slate-500">#{{ ec.elementConstitutif.id }}</span>
                        {% endif %}
                    </div>
                </div>

                {% if ec.elementConstitutif.ficheMatiere != null and app.user != null and
                    is_granted('CAN_PARCOURS_EDIT_MY', ec.elementConstitutif.ficheMatiere) and
                    workflow_can(ec.elementConstitutif.ficheMatiere, 'valider_fiche_compo') %}
                    <a href="{{ url('fiche_matiere_v2_modifier', {slug: ec.elementConstitutif.ficheMatiere.slug}) }}"
                       target="_blank"
                       class="inline-flex shrink-0 items-center rounded-md border border-amber-200 px-2 py-1 text-xs font-semibold text-amber-700 hover:bg-amber-50 dark:border-amber-700 dark:text-amber-300 dark:hover:bg-amber-950/20">
                        {{ ux_icon('icon:edit', {class: 'h-3.5 w-3.5'}) }}
                    </a>
                {% endif %}
            </div>
        </div>
    </td>
    <td class="{{ cellClass }} min-w-[11rem]">
        {% set parcoursVersioning = isVersioning is defined and isVersioning == true ? parcoursVersioning ?? null : null %}
        {{ component('badge_mccc', {
            elementConstitutif: ec.elementConstitutif,
            parcours: parcours,
            deplacer: false,
            editable: false,
            ue: ue.ue,
            isVersioning: isVersioning ?? false,
            indexEc: indexEc,
            indexEcEnfant: indexEcEnfant,
            UeDisplay: UeDisplay,
            parcoursVersioning: parcoursVersioning
        }) }}
    </td>
    <td class="{{ metricTotalClass }} whitespace-nowrap text-indigo-700">
        <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.heuresEctsEc.ects|displayDiff : '' }} ECTS</span>
        <span class="show_current">{{ ec.heuresEctsEc.ects }} ECTS</span>
    </td>

    {% if presentiel %}
        {% if ec.elementsConstitutifsEnfants|length > 0 %}
            <td colspan="5" class="bg-blue-50/10"></td>
        {% else %}
            <td class="{{ metricPresClass }}">
                <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.heuresEctsEc.cmPres|displayDiff : '' }}</span>
                <span class="show_current">{{ ec.heuresEctsEc.cmPres|filtreHeures }}</span>
            </td>
            <td class="{{ metricPresClass }}">
                <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.heuresEctsEc.tdPres|displayDiff : '' }}</span>
                <span class="show_current">{{ ec.heuresEctsEc.tdPres|filtreHeures }}</span>
            </td>
            <td class="{{ metricPresClass }}">
                <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.heuresEctsEc.tpPres|displayDiff : '' }}</span>
                <span class="show_current">{{ ec.heuresEctsEc.tpPres|filtreHeures }}</span>
            </td>

            <td class="{{ metricPresClass }} font-black text-blue-700">
                <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.heuresEctsEc.sommeEcTotalPres|displayDiff : '' }}</span>
                <span class="show_current">{{ ec.heuresEctsEc.sommeEcTotalPres|filtreHeures }}</span>
            </td>
            <td class="{{ metricPresClass }} border-r border-slate-100 text-slate-600">
                <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.heuresEctsEc.tePres|displayDiff : '' }}</span>
                <span class="show_current">{{ ec.heuresEctsEc.tePres|filtreHeures }}</span>
            </td>
        {% endif %}
    {% endif %}

    {% if distanciel %}
        {% if ec.elementsConstitutifsEnfants|length > 0 %}
            <td colspan="4" class="bg-orange-50/10"></td>
        {% else %}
            <td class="{{ metricDistClass }}">
                <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.heuresEctsEc.cmDist|displayDiff : '' }}</span>
                <span class="show_current">{{ ec.heuresEctsEc.cmDist|filtreHeures }}</span>
            </td>
            <td class="{{ metricDistClass }}">
                <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.heuresEctsEc.tdDist|displayDiff : '' }}</span>
                <span class="show_current">{{ ec.heuresEctsEc.tdDist|filtreHeures }}</span>
            </td>
            <td class="{{ metricDistClass }}">
                <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.heuresEctsEc.tpDist|displayDiff : '' }}</span>
                <span class="show_current">{{ ec.heuresEctsEc.tpDist|filtreHeures }}</span>
            </td>
            <td class="{{ metricDistClass }} border-r border-slate-100 font-black">
                <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.heuresEctsEc.sommeEcTotalDist|displayDiff : '' }}</span>
                <span class="show_current">{{ ec.heuresEctsEc.sommeEcTotalDist|filtreHeures }}</span>
            </td>
        {% endif %}
    {% endif %}

    {% if parcours.modalitesEnseignement != null and (parcours.modalitesEnseignement.value == 1) %}
        <td class="px-5 py-3 align-top text-right font-black tabular-nums text-slate-900">
            <span class="show_versioning d-none d-print-none">{{ diffEc ? diffEc.heuresEctsEc.sommeEcTotalPresDist|displayDiff : '' }}</span>
            <span class="show_current">{{ ec.heuresEctsEc.sommeEcTotalPresDist|filtreHeures }}</span>
        </td>
    {% endif %}
</tr>


