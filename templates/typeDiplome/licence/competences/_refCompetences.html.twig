<div
        id="bloc-competences"
        class="space-y-3" {{ stimulus_controller('sortable-competences') }}>
    {% for blocCompetence in competences %}
        {{ include('typeDiplome/licence/competences/_blocCompetences.html.twig', {blocCompetence: blocCompetence, parcours: parcours}) }}

        {# Ajouter un bloc après chaque bloc existant #}
        {% if not loop.last %}
            <div class="flex items-center justify-center py-2">
                <div class="flex-1 border-t border-gray-200"></div>
                <twig:Button
                        variant="primary"
                        size="sm"
                        :outline="true"
                        icon="icon:add"
                        label="Ajouter un bloc"
                        href="{{ path('app_bloc_competence_new_parcours', {
                            parcours: parcours is defined ? parcours.id : null,
                            ordre: blocCompetence.ordre + 1
                        }) }}"
                        dataAction="click->modalturbo#open"
                        class="px-3 mx-2"
                />

                {#                {{ stimulus_controller('modal', { #}
                {#                    size: 'lg', #}
                {#                    modalTitle: 'Ajouter un bloc de compétences', #}
                {#                    modalUrl: path('app_bloc_competence_new_parcours', { #}
                {#                        parcours: parcours is defined ? parcours.id : null, #}
                {#                        ordre: blocCompetence.ordre + 1 #}
                {#                    }) }) }} #}
                <div class="flex-1 border-t border-gray-200"></div>
            </div>
        {% endif %}
    {% else %}
        <div class="rounded-lg border-2 border-dashed border-gray-300 p-8 text-center">
            <i class="fal fa-inbox text-gray-300 text-4xl mb-2 block"></i>
            <p class="text-gray-500 mb-4">Aucun bloc de compétences</p>
            <twig:Button
                    variant="primary"
                    icon="icon:add"
                    label="Créer le premier bloc"
                    href="{{ path('app_bloc_competence_new_parcours', {
                        parcours: parcours is defined ? parcours.id : null
                    }) }}"
                    dataAction="click->modalturbo#open"
            />
        </div>
    {% endfor %}
</div>

{# Initialiser le drag-and-drop via Stimulus #}
{% if competences|length > 0 %}
    {# À implémenter: créer un contrôleur Stimulus 'sortable' qui utilisera SortableJS #}
    {# Pour le moment, utiliser les boutons de déplacement haut/bas existants #}
{% endif %}
