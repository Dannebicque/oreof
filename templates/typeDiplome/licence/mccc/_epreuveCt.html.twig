{% import 'typeDiplome/licence/mccc/_form_fields.html.twig' as fields %}

<div class="epreuve_ct grid grid-cols-1 gap-3 rounded-lg border border-slate-200 bg-white p-4 md:grid-cols-12">
    <div class="md:col-span-4">
        <strong class="text-slate-800">Contrôle terminal N°{{ index }}</strong>
    </div>
    <div class="md:col-span-4">
        {{ fields.label('pourcentage_s1_ct' ~ index, 'Pourcentage') }}
        {{ fields.input_with_suffix(
            'pourcentage_s1_ct' ~ index,
            'pourcentage_s1_ct' ~ index,
            mcccs[1]['et'][index] is defined ? mcccs[1]['et'][index].pourcentage : ''
        ) }}
        {{ fields.help('mccc_licence.helps.cc_ct.pourcentage_s1_et.help') }}
    </div>
    {% set hasJustification = 'not_set' %}
    {% for typeE in typeEpreuves %}
        {% if mcccs[1]['et'][index].typeEpreuve[0] is defined %}
            {% if mcccs[1]['et'][index].typeEpreuve[0] == typeE.id %}
                {% set hasJustification = typeE.hasJustification ? 'true' : 'false' %}
            {% endif %}
        {% endif %}
    {% endfor %}
    <div class="md:col-span-4"
        {{ stimulus_controller('mccc-with-justification', {
            'templateName': 'justificationSaisieMccc',
            'textAreaFormName': 'justification_s1_ct' ~ index,
            'minlength': 15,
            'hasJustification': hasJustification,
            'justificationText': mcccs[1]['et'][index].justificationText ?? ''
        }) }}
    >
        {{ fields.label('typeEpreuve_s1_ct' ~ index, "Type d'épreuve") }}
        {{ fields.type_epreuve_select(
            'typeEpreuve_s1_ct' ~ index,
            'typeEpreuve_s1_ct' ~ index,
            typeEpreuves,
            mcccs[1]['et'][index] is defined and mcccs[1]['et'][index].typeEpreuve[0] is defined ? mcccs[1]['et'][index].typeEpreuve[0] : null,
            stimulus_action('mccc--licence', 'changeTypeEpreuveCt', 'change')|stimulus_action('mccc-with-justification', 'updateJustification', 'change'),
            'typeEpreuveSelectCt synchro-mccc block w-full appearance-none rounded-sm border border-slate-200 bg-slate-50 p-4 font-semibold text-slate-700'
        ) }}
        {{ fields.help('mccc_licence.helps.cc_ct.typeEpreuve_s1_et.help') }}
        <div class="md:col-span-12 {{ hasJustification == 'true' ? '' : 'd-none' }}"
            {{ stimulus_target('mccc-with-justification', 'displayDiv') }}
        >
        </div>
    </div>
    <div class="hidden md:col-span-8 md:block"></div>
    <div class="md:col-span-4">
        {{ fields.label('duree_s1_ct' ~ index, "Durée de l'épreuve") }}
        {{ fields.input(
            'duree_s1_ct' ~ index,
            'duree_s1_ct' ~ index,
            mcccs[1]['et'][index] is defined and mcccs[1]['et'][index].duree != null ? mcccs[1]['et'][index].duree|date('H:i') : '',
            'time'
        ) }}
        {{ fields.help('mccc_licence.helps.ct.duree_s1_et.help') }}
    </div>
    {% if index > 1 %}
        <div class="hidden md:col-span-8 md:block"></div>
        <div class="md:col-span-4 md:pt-2">
            <twig:Button
                    variant="danger"
                    :soft="false"
                    icon="icon:delete"
                    tooltip="Supprimer"
                    extraClass="synchro-mccc h-9 w-9 px-0"
                    dataAction="click->mccc--licence#removeEpreuveCtS1"
            />
        </div>
    {% endif %}
</div>
