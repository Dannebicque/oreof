{% import 'typeDiplome/licence/mccc/_form_fields.html.twig' as fields %}

<h3 class="mb-3 text-lg font-semibold text-slate-900">1ᵉ Session</h3>
<div>
    <div id="epreuve_cci" class="space-y-3">
        <div class="epreuve grid grid-cols-1 gap-3 rounded-lg border border-slate-200 bg-white p-4 md:grid-cols-12">
            <div class="md:col-span-4">
                <strong class="text-slate-800">Epreuve N°1</strong>
            </div>
            <div class="md:col-span-8">
                {{ fields.label('pourcentage_s1_cc', 'Pourcentage') }}
                {{ fields.input_with_suffix(
                    'pourcentage_s1_cc',
                    'pourcentage[1]',
                    mcccs[1].pourcentage ?? '',
                    '%',
                    'text',
                    false,
                    stimulus_action('mccc--licence', 'saveDataCci', 'change'),
                    'pourcentage synchro-mccc block w-full rounded-l-sm border-0 bg-slate-50 p-2 font-bold text-slate-700'
                ) }}
                {{ fields.help('mccc_licence.helps.cc.pourcentage_s1_et.help') }}
            </div>
        </div>

        <div class="epreuve grid grid-cols-1 gap-3 rounded-lg border border-slate-200 bg-white p-4 md:grid-cols-12">
            <div class="md:col-span-4">
                <strong class="text-slate-800">Epreuve N°2</strong>
            </div>
            <div class="md:col-span-8">
                {{ fields.label('pourcentage_s2_cc', 'Pourcentage') }}
                {{ fields.input_with_suffix(
                    'pourcentage_s2_cc',
                    'pourcentage[2]',
                    mcccs[2].pourcentage ?? '',
                    '%',
                    'text',
                    false,
                    stimulus_action('mccc--licence', 'saveDataCci', 'change'),
                    'pourcentage synchro-mccc block w-full rounded-l-sm border-0 bg-slate-50 p-2 font-bold text-slate-700'
                ) }}
                {{ fields.help('mccc_licence.helps.cc.pourcentage_s1_et.help') }}
            </div>
        </div>

        <div class="epreuve grid grid-cols-1 gap-3 rounded-lg border border-slate-200 bg-white p-4 md:grid-cols-12">
            <div class="md:col-span-4">
                <strong class="text-slate-800">Epreuve N°3</strong>
            </div>
            <div class="md:col-span-8">
                {{ fields.label('pourcentage_s3_cc', 'Pourcentage') }}
                {{ fields.input_with_suffix(
                    'pourcentage_s3_cc',
                    'pourcentage[3]',
                    mcccs[3].pourcentage ?? '',
                    '%',
                    'text',
                    false,
                    stimulus_action('mccc--licence', 'saveDataCci', 'change'),
                    'pourcentage synchro-mccc block w-full rounded-l-sm border-0 bg-slate-50 p-2 font-bold text-slate-700'
                ) }}
                {{ fields.help('mccc_licence.helps.cc.pourcentage_s1_et.help') }}
            </div>
        </div>

        {% if mcccs|length > 3 %}
            {% for i in 4..mcccs|length %}
                <div class="epreuve grid grid-cols-1 gap-3 rounded-lg border border-slate-200 bg-white p-4 md:grid-cols-12">
                    <div class="md:col-span-4">
                        <strong class="text-slate-800">Epreuve N°{{ i }}</strong>
                    </div>
                    <div class="md:col-span-6">
                        {{ fields.label('pourcentage_s' ~ i ~ '_cc', 'Pourcentage') }}
                        {{ fields.input_with_suffix(
                            'pourcentage_s' ~ i ~ '_cc',
                            'pourcentage[' ~ i ~ ']',
                            mcccs[i].pourcentage ?? '',
                            '%',
                            'text',
                            false,
                            stimulus_action('mccc--licence', 'saveDataCci', 'change'),
                            'pourcentage synchro-mccc block w-full rounded-l-sm border-0 bg-slate-50 p-2 font-bold text-slate-700'
                        ) }}
                        {{ fields.help('mccc_licence.helps.cc.pourcentage_s1_et.help') }}
                    </div>
                    <div class="md:col-span-2 md:pt-6">
                        <twig:Button
                                variant="danger"
                                :soft="false"
                                icon="icon:delete"
                                tooltip="Supprimer"
                                dataAction="click->mccc--licence#removeEpreuveCci"
                                extraClass="h-9 w-9 px-0"
                        />
                    </div>
                </div>
            {% endfor %}
        {% endif %}

    </div>

    <twig:Button
            variant="info"
            :soft="false"
            icon="icon:add"
            label="Ajouter une épreuve"
            extraClass="synchro-mccc mb-3 mt-3"
            dataAction="click->mccc--licence#addEpreuveCci"
    />

    <div class="hidden mt-2 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700" {{ stimulus_target('mccc--licence', 'zoneErreur') }}>

    </div>
</div>
