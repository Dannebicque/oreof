{% set sectionClass = 'scroll-mt-32 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm' %}

<div class="space-y-4">
    <section
            data-scroll-spy-target="section"
            class="{{ sectionClass }}"
            id="identite_enseignement">
        {{ include('communs/_header_show.html.twig', {
            title: 'Identité de la fiche matière',
            icon: 'ph:identification-badge',
            color: 'indigo',
            print:true
        }) }}
        <div class="mt-4">
            {{ include('typeDiplome/licence/ec/_identiteEc.html.twig') }}
        </div>
    </section>

    <section
            data-scroll-spy-target="section"
            class="{{ sectionClass }}"
            id="presentation">
        {{ include('communs/_header_show.html.twig', {
            title: 'Présentation de la fiche matière',
            icon: 'ph:book-open',
            color: 'indigo',
            print:true
        }) }}
        <div class="mt-4">
            {{ include('typeDiplome/licence/ec/_presentation.html.twig') }}
        </div>
    </section>

    <section
            data-scroll-spy-target="section"
            class="{{ sectionClass }}"
            id="volumes_horaires">
        {{ include('communs/_header_show.html.twig', {
            title: 'Volumes horaires de la fiche matière',
            icon: 'ph:clock',
            color: 'indigo',
            print:true
        }) }}
        <div class="mt-4 space-y-4">
            <twig:alerte type="info"
                         message="Les volumes horaires sont donnés à titre indicatif et peuvent varier en fonction des parcours dans lesquels cette fiche matière est utilisée."
                         class="mt-2"></twig:alerte>

            {{ include('typeDiplome/licence/ec/_structure.html.twig') }}
        </div>
    </section>

    <section
            data-scroll-spy-target="section"
            class="{{ sectionClass }}"
            id="mccc">
        {{ include('communs/_header_show.html.twig', {
            title: 'MCCC',
            icon: 'ph:graduation-cap',
            color: 'indigo',
            print:true
        }) }}
        <div class="mt-4 space-y-4">
            <twig:alerte type="info"
                         message="Les MCCC et ECTS sont donnés à titre indicatif et peuvent varier en fonction des parcours dans lesquels cette fiche matière est utilisée."
                         class="mt-2"></twig:alerte>

            {{ include('typeDiplome/licence/ec/_mccc.html.twig', {}) }}
        </div>
    </section>


    <section
            data-scroll-spy-target="section"
            class="{{ sectionClass }}"
            id="bcc">
        {{ include('communs/_header_show.html.twig', {
            title: 'Compétences associées à la fiche matière',
            icon: 'ph:target',
            color: 'indigo',
            print:true
        }) }}
        <div class="mt-4">
            {{ include('typeDiplome/formation/_objectifs.html.twig') }}
        </div>
    </section>

    {% if ficheMatiere.enseignementMutualise == true or ecParcours|length > 0 %}
        <section
                data-scroll-spy-target="section"
                class="{{ sectionClass }}"
                id="mutualisation">
            {{ include('communs/_header_show.html.twig', {
                title: 'Mutualisations de la fiche matière',
                icon: 'ph:users-three',
                color: 'indigo',
                print:true
            }) }}
            <div class="mt-4">
                <ul class="space-y-3">
                    {% for ec in ecParcours %}
                        {% if ec.parcours != null %}
                            <li>
                                {% if ec.parcours.isParcoursDefaut == true %}
                                    <a href="{{ path('formation_v2_voir', {slug:ec.parcours.formation.slug}) }}"
                                       target="_blank"
                                       class="group flex items-start gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700">
                                        <i class="fas fa-eye mt-0.5 text-slate-400 transition group-hover:text-indigo-500"></i>
                                        <span class="space-y-1">
                                            <span class="block font-semibold text-slate-900">Formation sans parcours</span>
                                            <span class="block">{{ ec.ue.display(ec.parcours) }}</span>
                                            <span class="block text-xs text-slate-500">{{ ec.code }} · {{ ec.parcours.formation.displayLong }} · {{ ec.parcours.formation.composantePorteuse.libelle }}</span>
                                        </span>
                                    </a>
                                {% else %}
                                    {% if ec.parcours != null and ec.parcours.formation != null %}
                                        <a href="{{ path('parcours_v2_voir', {parcours:ec.parcours.id}) }}"
                                           target="_blank"
                                           class="group flex items-start gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700">
                                            <i class="fas fa-eye mt-0.5 text-slate-400 transition group-hover:text-indigo-500"></i>
                                            <span class="space-y-1">
                                                <span class="block font-semibold text-slate-900">{{ ec.parcours.libelle }} {% if ec.parcours.typeparcours != null and ec.parcours.typeparcours.value != 'classique' %} {{ ec.parcours.typeparcours|badgeTypeParcours }}{% endif %}</span>
                                                <span class="block">{{ ec.ue.display(ec.parcours) }}</span>
                                                <span class="block text-xs text-slate-500">{{ ec.code }} · {{ ec.parcours.formation.displayLong }} · {{ ec.parcours.formation.composantePorteuse.libelle }}</span>
                                            </span>
                                        </a>
                                    {% endif %}
                                {% endif %}
                            </li>
                        {% endif %}
                    {% endfor %}
                </ul>
            </div>
        </section>
    {% endif %}


    <section
            data-scroll-spy-target="section"
            class="{{ sectionClass }}"
            id="infos">
        {{ include('communs/_header_show.html.twig', {
            title: 'Infos pratiques',
            icon: 'ph:info',
            color: 'indigo',
            print:true
        }) }}
        <div class="mt-4">
            {{ include('typeDiplome/licence/ec/_infos.html.twig') }}
        </div>
    </section>
</div>
