{% extends 'base.html.twig' %}

{% block header %}{{ faq.id ? 'Modifier' : 'Créer' }} une question FAQ{% endblock %}

{% block content %}
    <div class="container-fluid py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="fal fa-circle-question"></i> {{ faq.id ? 'Modifier la question' : 'Nouvelle question' }}</h1>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                {{ component('faq_editor', { initialFormData: faq }) }}
                    {# Composant de gestion des images (modal) partagé avec l'aide #}
                    {{ component('help_image_manager', { showModal: true, editorTextarea: 'textarea[name="faq[reponse]"]' }) }}
            </div>
        </div>
    </div>

    <script src="/js/editor_helpers.js"></script>
{% endblock %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        {
            href:path('app_faq_index'),
            title: 'FAQ',
        },
        {
            href:'',
            title: faq.id ? 'Modifier' : 'Créer',
        }
    ]}) }}
{% endblock %}
