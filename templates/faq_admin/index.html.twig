{% extends 'base.html.twig' %}

{% block header %}Gestion de la FAQ{% endblock %}

{% block content %}
    <style>
        .faq-drag-handle {
            width: 30px;
            height: 30px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            cursor: grab;
            user-select: none;
        }

        .faq-drag-handle:hover {
            background-color: rgba(0, 0, 0, 0.06);
        }

        .faq-drag-handle:active {
            cursor: grabbing;
        }
    </style>

    <div id="faq-reorder-feedback" class="alert d-none position-fixed top-0 end-0 m-3 shadow" style="z-index: 1080; min-width: 320px;" role="alert"></div>

    <div class="container-fluid py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="fal fa-circle-question"></i> Gestion de la FAQ</h1>

            <div class="d-flex gap-2">
                <button type="button"
                        class="btn btn-sm btn-outline-secondary"
                        data-bs-toggle="modal"
                        data-bs-target="#helpImagesModal"
                        onclick="loadImages()"
                        title="Gérer la galerie d'images pour la FAQ">
                    <i class="fal fa-images"></i> <span>Galerie d'images</span>
                </button>
                <a href="{{ path('app_faq_new') }}"
                   class="btn btn-sm btn-outline-primary"
                   data-bs-toggle="tooltip" data-bs-placement="bottom" title="Créer une nouvelle question FAQ">
                    <i class="fal fa-plus"></i> <span>Ajouter une question</span>
                </a>
            </div>
        </div>

        {% if faqs|length == 0 %}
            <div class="alert alert-info" role="alert">
                <i class="fal fa-info-circle"></i> Aucune question FAQ pour le moment. 
                <a href="{{ path('app_faq_new') }}">Créez la première !</a>
            </div>
        {% else %}
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                        <tr>
                            <th class="ps-3" style="width: 34px;"></th>
                            <th class="ps-4" style="width: 30px;">Statut</th>
                            <th style="width: 40%;">Question</th>
                            <th style="width: 20%;">Centres</th>
                            <th style="width: 80px;">Ordre</th>
                            <th class="text-end pe-4" style="width: 150px;">Actions</th>
                        </tr>
                        </thead>
                        <tbody id="faq-sortable-body">
                        {% for faq in faqs %}
                            <tr data-faq-id="{{ faq.id }}">
                                <td class="ps-3 align-middle text-muted">
                                    <span class="faq-drag-handle" title="Glisser pour réordonner">
                                        <i class="fal fa-grip-vertical"></i>
                                    </span>
                                </td>
                                <td class="ps-4">
                                    {% if faq.isActive %}
                                        <span class="badge bg-success">Actif</span>
                                    {% else %}
                                        <span class="badge bg-danger">Inactif</span>
                                    {% endif %}
                                </td>
                                <td class="align-middle"><strong>{{ faq.question }}</strong></td>
                                <td class="align-middle">
                                    {% if faq.centresShow|length > 0 %}
                                        {% for centre in faq.centresShow %}
                                            {% if centre == 'cg_composante' %}
                                                <span class="badge bg-quaternary me-1 text-wrap">Composante</span>
                                            {% elseif centre == 'cg_etablissement' %}
                                                <span class="badge bg-info me-1 text-wrap">Établissement</span>
                                            {% elseif centre == 'cg_formation' %}
                                                <span class="badge bg-success me-1 text-wrap">Formation</span>
                                            {% elseif centre == 'cg_parcours' %}
                                                <span class="badge bg-secondary me-1 text-wrap">Parcours</span>
                                            {% endif %}
                                        {% endfor %}
                                    {% else %}
                                        <span class="text-muted"><em>Tous les centres</em></span>
                                    {% endif %}
                                </td>
                                <td class="align-middle">{{ faq.ordre }}</td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="{{ path('app_faq_edit', {'id': faq.id}) }}"
                                           class="btn btn-sm btn-outline-info"
                                           data-bs-toggle="tooltip" data-bs-placement="bottom" title="Modifier">
                                            <i class="fal fa-edit"></i>
                                        </a>

                                        <form method="post" action="{{ path('app_faq_delete', {'id': faq.id}) }}" style="display: inline;" onsubmit="return confirm('Vraiment supprimer cette question FAQ ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ faq.id) }}">
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger"
                                                    data-bs-toggle="tooltip" data-bs-placement="bottom" title="Supprimer">
                                                <i class="fal fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}

    </div>

    <!-- Modal pour la galerie d'images -->
    <div class="modal fade" id="helpImagesModal" tabindex="-1" aria-labelledby="helpImagesModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="helpImagesModalLabel"><i class="fal fa-images"></i> Galerie d'images</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    {{ component('help_image_manager', { showModal: false, editorTextarea: '' }) }}
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <script>
        (function () {
            const tbody = document.getElementById('faq-sortable-body');
            const feedback = document.getElementById('faq-reorder-feedback');
            if (!tbody || typeof Sortable === 'undefined') {
                return;
            }

            let feedbackTimer = null;

            function showFeedback(type, message) {
                if (!feedback) {
                    return;
                }

                feedback.className = 'alert position-fixed top-0 end-0 m-3 shadow';
                feedback.classList.add(type === 'success' ? 'alert-success' : 'alert-danger');
                feedback.textContent = message;
                feedback.classList.remove('d-none');

                if (feedbackTimer) {
                    clearTimeout(feedbackTimer);
                }

                feedbackTimer = setTimeout(() => {
                    feedback.classList.add('d-none');
                }, 2500);
            }

            new Sortable(tbody, {
                handle: '.faq-drag-handle',
                animation: 150,
                onEnd: function () {
                    const ids = Array.from(tbody.querySelectorAll('tr[data-faq-id]')).map((row) => row.getAttribute('data-faq-id'));

                    const body = new URLSearchParams();
                    ids.forEach((id) => body.append('ids[]', id));
                    body.append('_token', '{{ csrf_token('faq_reorder') }}');

                    fetch('{{ path('app_faq_reorder') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                        },
                        body: body.toString()
                    }).then((response) => {
                        if (!response.ok) {
                            throw new Error('Erreur de sauvegarde du nouvel ordre');
                        }
                        return response.json();
                    }).then((data) => {
                        if (!data.success) {
                            throw new Error(data.message || 'Erreur de sauvegarde du nouvel ordre');
                        }

                        Array.from(tbody.querySelectorAll('tr[data-faq-id]')).forEach((row, index) => {
                            const ordreCell = row.children[4];
                            if (ordreCell) {
                                ordreCell.textContent = String(index + 1);
                            }
                        });

                        showFeedback('success', 'Ordre des questions sauvegardé.');
                    }).catch((error) => {
                        console.error(error);
                        showFeedback('error', 'Erreur lors de la sauvegarde de l\'ordre. Rechargement...');
                        setTimeout(() => window.location.reload(), 900);
                    });
                }
            });
        })();
    </script>
{% endblock %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        {
            href:'',
            title: 'Administration',
        }
    ]}) }}
{% endblock %}
