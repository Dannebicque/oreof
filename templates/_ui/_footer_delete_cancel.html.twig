<div class="app-modal-footer-actions">
    <button type="button"
            class="app-modal-footer-btn app-modal-footer-btn--secondary"
            data-action="modalturbo#close">
        Annuler
    </button>

    {# Soumet le premier form présent dans le body #}
    <form action="{{ url }}" method="post" id="modal_form">
        <input type="hidden" name="csrf_token" value="{{ csrf_token(csrf_token) }}">
        <input type="hidden" name="_method" value="delete">
        <button type="submit"
                class="app-modal-footer-btn app-modal-footer-btn--danger"
                form="modal_form">
            {{ submitLabel ?? 'Confirmer suppression' }}
        </button>
    </form>
</div>
