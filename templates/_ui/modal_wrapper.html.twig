<div
        id="modal"
        class="fixed inset-0 z-50 hidden"
        data-modalturbo-target="wrapper"
        data-action="keydown.esc@window->modalturbo#close"
>
    <div id="modal_control"></div>

    <!-- overlay -->
    <div class="absolute inset-0 bg-black/50" data-action="click->modalturbo#close"></div>

    <div class="absolute inset-0 flex items-center justify-center p-4">
        <div class="app-modal-shell app-modal-content">
            <div class="app-modal-header">
                <turbo-frame id="modal_title" class="app-modal-title-wrap">
                    <div class="app-modal-title">Titre</div>
                </turbo-frame>

                <button type="button"
                        class="app-modal-footer-btn app-modal-footer-btn--secondary !px-2.5 !py-2 shadow-none"
                        data-action="modalturbo#close"
                        aria-label="Fermer">
                    <twig:UX:Icon name="icon:close" class="h-4 w-4"/>
                </button>
            </div>

            <div class="app-modal-body">
                <turbo-frame id="modal_body">
                    {# contenu #}
                </turbo-frame>
            </div>

            <div class="app-modal-footer">
                <turbo-frame id="modal_footer">
                    {# boutons #}
                </turbo-frame>
            </div>
        </div>
    </div>
</div>
