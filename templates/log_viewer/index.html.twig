{% extends 'base.html.twig' %}

{% set header_title %}Visualiseur de logs{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens: [
        {title: 'Pilotage'},
        {title: 'Visualiseur de logs'}
    ]}) }}
{% endblock %}

{% block content %}
    <div class="grid grid-cols-1 gap-4 xl:grid-cols-4">

        <aside class="min-w-0 xl:col-span-1">
            <section
                    class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900">
                <h2 class="mb-3 inline-flex items-center gap-2 text-sm font-black uppercase tracking-widest text-slate-500 dark:text-slate-400">
                    <i class="fas fa-folder-open text-cyan-600"></i>
                    Fichiers disponibles
                </h2>

                {% if files is empty %}
                    <p class="text-sm text-slate-500 dark:text-slate-400">Aucun fichier de log trouvé.</p>
                {% else %}
                    {% set dates = [] %}
                    {% for file in files %}
                        {% if file.date not in dates %}
                            {% set dates = dates|merge([file.date]) %}
                        {% endif %}
                    {% endfor %}

                    <div class="space-y-4">
                        {% for date in dates %}
                            <div>
                                <p class="mb-1 text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500">
                                    {{ date|date('d/m/Y', timezone='Europe/Paris') }}
                                </p>
                                <div class="space-y-1">
                                    {% for key, file in files %}
                                        {% if file.date == date %}
                                            <a href="{{ path('app_log_viewer_index', {file: key, level: levelFilter}) }}"
                                               class="flex items-center gap-2 rounded-lg px-2.5 py-2 text-sm transition
                                               {% if selectedFile == key %}
                                                   bg-cyan-600 text-white
                                               {% else %}
                                                   border border-slate-200 bg-white text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800/60
                                               {% endif %}">
                                                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-semibold
                                                    {% if selectedFile == key %}
                                                        bg-white/20 text-white
                                                    {% elseif file.level == 'ERROR' %}
                                                        border border-amber-200 bg-amber-50 text-amber-700 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-200
                                                    {% else %}
                                                        border border-rose-200 bg-rose-50 text-rose-700 dark:border-rose-700 dark:bg-rose-950/30 dark:text-rose-200
                                                    {% endif %}">
                                                    {{ file.level }}
                                                </span>
                                                <span class="min-w-0 flex-1 truncate">{{ file.filename }}</span>
                                                <span class="text-xs opacity-75">{{ (file.size / 1024)|round(1) }} Ko</span>
                                            </a>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </section>
        </aside>

        <section class="min-w-0 xl:col-span-3">
            {% if selectedFile is null %}
                <div class="rounded-2xl border border-slate-200 bg-white px-6 py-10 text-center shadow-sm dark:border-slate-700 dark:bg-slate-900">
                    <i class="fas fa-file-alt mb-3 text-4xl text-slate-300 dark:text-slate-600"></i>
                    <p class="text-sm text-slate-500 dark:text-slate-400">Sélectionnez un fichier dans la liste pour
                        afficher son contenu.</p>
                </div>
            {% else %}
                <div class="mb-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900">
                    <div class="flex flex-wrap items-center gap-3">
                        <div>
                            <h3 class="text-base font-semibold text-slate-800 dark:text-slate-100">
                                <i class="fas fa-file-code mr-1"></i>
                                {{ selectedFileInfo.filename }}
                            </h3>
                            <p class="text-xs text-slate-500 dark:text-slate-400">{{ selectedFileInfo.date }}</p>
                        </div>

                        <div class="ml-auto flex flex-wrap gap-2">
                            <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-700 dark:border-slate-700 dark:bg-slate-950/30 dark:text-slate-200">
                                <i class="fas fa-list mr-1"></i>{{ stats.total }} entrée{{ stats.total > 1 ? 's' : '' }}
                            </span>
                            <span class="inline-flex items-center rounded-full border border-amber-200 bg-amber-50 px-2.5 py-1 text-xs font-semibold text-amber-700 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-200">
                                <i class="fas fa-exclamation-triangle mr-1"></i>{{ stats.error }} ERROR
                            </span>
                            <span class="inline-flex items-center rounded-full border border-rose-200 bg-rose-50 px-2.5 py-1 text-xs font-semibold text-rose-700 dark:border-rose-700 dark:bg-rose-950/30 dark:text-rose-200">
                                <i class="fas fa-skull-crossbones mr-1"></i>{{ stats.critical }} CRITICAL
                            </span>
                        </div>

                        <div class="flex flex-wrap gap-2">
                            <a href="{{ path('app_log_viewer_index', {file: selectedFile, level: 'all'}) }}"
                               class="inline-flex items-center rounded-lg border px-3 py-1.5 text-xs font-semibold transition {{ levelFilter == 'all' ? 'border-cyan-600 bg-cyan-600 text-white' : 'border-slate-300 bg-white text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800' }}">
                                Tous
                            </a>
                            <a href="{{ path('app_log_viewer_index', {file: selectedFile, level: 'error'}) }}"
                               class="inline-flex items-center rounded-lg border px-3 py-1.5 text-xs font-semibold transition {{ levelFilter == 'error' ? 'border-amber-500 bg-amber-500 text-amber-950' : 'border-amber-300 bg-white text-amber-700 hover:bg-amber-50 dark:border-amber-700 dark:bg-slate-900 dark:text-amber-300 dark:hover:bg-amber-950/20' }}">
                                <i class="fas fa-exclamation-triangle mr-1"></i>ERROR
                            </a>
                            <a href="{{ path('app_log_viewer_index', {file: selectedFile, level: 'critical'}) }}"
                               class="inline-flex items-center rounded-lg border px-3 py-1.5 text-xs font-semibold transition {{ levelFilter == 'critical' ? 'border-rose-600 bg-rose-600 text-white' : 'border-rose-300 bg-white text-rose-700 hover:bg-rose-50 dark:border-rose-700 dark:bg-slate-900 dark:text-rose-300 dark:hover:bg-rose-950/20' }}">
                                <i class="fas fa-skull-crossbones mr-1"></i>CRITICAL
                            </a>
                        </div>
                    </div>
                </div>

                {% if entries is empty %}
                    <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-6 py-8 text-center text-sm text-emerald-800 shadow-sm dark:border-emerald-800 dark:bg-emerald-950/30 dark:text-emerald-200">
                        <i class="fas fa-check-circle mb-2 text-2xl"></i>
                        <p>Aucune entrée pour ce filtre.</p>
                    </div>
                {% else %}
                    <div class="max-h-[70vh] space-y-2 overflow-y-auto pr-1">
                        {% for entry in entries %}
                            {% set entryTone = entry.level == 'CRITICAL'
                                ? 'border-rose-300 bg-rose-50/70 dark:border-rose-800 dark:bg-rose-950/20'
                                : (entry.level == 'ERROR'
                                ? 'border-amber-300 bg-amber-50/70 dark:border-amber-800 dark:bg-amber-950/20'
                                : 'border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-900') %}
                            <div class="rounded-xl border shadow-sm {{ entryTone }}">
                                <div class="flex items-start gap-2 p-3">
                                    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-semibold
                                        {% if entry.level == 'CRITICAL' %}border border-rose-300 bg-rose-100 text-rose-800 dark:border-rose-700 dark:bg-rose-900/40 dark:text-rose-200
                                        {% elseif entry.level == 'ERROR' %}border border-amber-300 bg-amber-100 text-amber-800 dark:border-amber-700 dark:bg-amber-900/40 dark:text-amber-200
                                        {% else %}border border-slate-300 bg-slate-100 text-slate-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200{% endif %}">
                                        {{ entry.level }}
                                    </span>

                                    {% if entry.channel %}
                                        <span class="inline-flex rounded-full border border-slate-300 bg-white px-2 py-0.5 text-xs font-medium text-slate-600 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300">{{ entry.channel }}</span>
                                    {% endif %}

                                    {% if entry.timestamp %}
                                        <span class="inline-flex items-center text-xs text-slate-500 dark:text-slate-400">
                                            <i class="fas fa-clock mr-1"></i>
                                            {{ entry.timestamp|slice(0, 19)|replace({'T': ' '}) }}
                                        </span>
                                    {% endif %}

                                    <span class="min-w-0 flex-1 truncate font-mono text-xs text-slate-700 dark:text-slate-200"
                                          title="{{ entry.message|e('html_attr') }}">
                                        {{ entry.message|split("\n")|first|u.truncate(200, '...') }}
                                    </span>
                                </div>

                                {% if '\n' in entry.message or entry.context %}
                                    <details class="group border-t border-slate-200 px-3 py-2 dark:border-slate-700">
                                        <summary
                                                class="flex cursor-pointer list-none items-center justify-between text-xs font-semibold text-slate-600 dark:text-slate-300">
                                            Voir le détail
                                            <i class="fas fa-chevron-down transition-transform group-open:rotate-180"></i>
                                        </summary>
                                        <div class="mt-2 space-y-2">
                                            <pre class="max-h-80 overflow-y-auto rounded-md bg-slate-100 p-2 text-xs text-slate-800 dark:bg-slate-950/60 dark:text-slate-100"><code>{{ entry.message }}</code></pre>
                                            {% if entry.context %}
                                                <div>
                                                    <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500">
                                                        Contexte</p>
                                                    <pre class="max-h-80 overflow-y-auto rounded-md bg-slate-50 p-2 text-xs text-slate-600 dark:bg-slate-900/70 dark:text-slate-300"><code>{{ entry.context }}</code></pre>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </details>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            {% endif %}
        </section>
    </div>
{% endblock %}

