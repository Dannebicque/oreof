<turbo-frame id="tab-content">
    {{ include('parcours_v2/tabs/_header.html.twig', {tabKey: 'et_apres'}) }}

    <div class="flex-1 overflow-y-auto mt-4 custom-scrollbar">
        {% form_theme form 'communs/form_theme_v2.html.twig' %}
        {{ form_start(form, {
            attr: {
                id: 'tab_form_et_apres',
                'data-controller': 'autosave',
                'data-autosave-url-value': path('parcours_v2_tab_autosave', { id: parcours.id, tabKey: 'et_apres' }),
                'data-action': 'input->autosave#queue'

            }
        }) }}

        {{ form_errors(form) }}
        {{ form_widget(form) }}

        {% set romeCodes = [] %}
        {% for rome in parcours.codesRome|default([]) %}
            {% if rome.code is defined %}
                {% set romeCodes = romeCodes|merge([rome.code|upper]) %}
            {% endif %}
        {% endfor %}

        <div class="space-y-2 group mb-4"
                {{ stimulus_controller('parcours--rome', {
                    initialCodes: romeCodes
                }) }}>
            <div class="flex justify-between items-center mb-1">
                <label class="text-[12px] font-black text-slate-500 uppercase">
                    {{ 'parcours_step6.labels.codeRome'|trans({}, 'form') }}
                </label>
                <span class="text-[10px] font-bold text-red-300 uppercase">Champs Requis</span>
            </div>

            {# Champ texte unique (CSV) persiste par autosave comme les autres champs #}
            <input type="hidden"
                   name="parcours_step6[codesRome]"
                    {{ stimulus_target('parcours--rome', 'codesText') }}>

            <div class="flex items-start gap-2">
                <label class="sr-only" for="parcours_step6_codesRome_input">Code ROME</label>
                <input id="parcours_step6_codesRome_input"
                       type="text"
                       maxlength="5"
                       placeholder="Ex: M1805"
                       class="w-full p-2 bg-slate-50 border border-slate-200 rounded-sm font-bold"
                        {{ stimulus_target('parcours--rome', 'codeInput') }}
                        {{ stimulus_action('parcours--rome', 'addCodeFromEnter', 'keydown') }}>
                <button type="button"
                        class="inline-flex items-center rounded-sm bg-emerald-600 px-3 py-2 text-sm font-semibold text-white hover:bg-emerald-700"
                        {{ stimulus_action('parcours--rome', 'addCode', 'click') }}>
                    Ajouter
                </button>
            </div>

            <div {{ stimulus_target('parcours--rome', 'listeCodes') }}></div>

            <p class="text-[11px] text-slate-400 italic mt-1 pl-1 flex items-start gap-2">
                <span class="flex-shrink-0 w-5 h-5 bg-slate-200 text-slate-500 flex items-center justify-center text-[10px] rounded-full">
                    <i class="fa-sharp fa-solid fa-circle-info"></i>
                </span>
                <span>{{ 'parcours_step6.helps.codeRome.help'|trans({}, 'help')|raw }}</span>
            </p>
        </div>


        {{ form_end(form) }}
    </div>

</turbo-frame>
