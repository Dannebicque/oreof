<nav aria-label="Fil d'Ariane" class="pt-0">
    <ol class="flex flex-wrap items-center gap-1.5 text-sm">
        <li>
            <a href="{{ path('app_homepage') }}"
               class="inline-flex items-center gap-1 rounded-md px-2 py-1 text-slate-500 transition hover:bg-slate-100 hover:text-slate-700 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-200">
                <twig:UX:Icon name="icon:home" class="h-4 w-4"/>
                <span>Accueil</span>
            </a>
        </li>

        {% for lien in liens %}
            <li class="inline-flex items-center gap-1.5">
                <twig:UX:Icon name="icon:chevron-right" class="h-3.5 w-3.5 text-slate-500 dark:text-slate-400"/>

                {% if loop.last or lien.href is empty %}
                    <span aria-current="page"
                          class="rounded-md bg-slate-100 px-2 py-1 font-semibold text-slate-700 dark:bg-slate-800 dark:text-slate-200">
                        {{ lien.title }}
                    </span>
                {% else %}
                    <a href="{{ lien.href }}"
                       class="rounded-md px-2 py-1 text-slate-500 transition hover:bg-slate-100 hover:text-slate-700 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-slate-200">
                        {{ lien.title }}
                    </a>
                {% endif %}
            </li>
        {% endfor %}
    </ol>
</nav>
