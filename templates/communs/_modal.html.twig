{% set campagneColorKey = user_data.campagneCollecte.couleur ?? 'info' %}
{% set campagneColorClasses = {
    'info': 'bg-cyan-100 text-cyan-800 dark:bg-cyan-400/20 dark:text-cyan-200',
    'success': 'bg-emerald-100 text-emerald-800 dark:bg-emerald-400/20 dark:text-emerald-200',
    'warning': 'bg-amber-100 text-amber-800 dark:bg-amber-400/20 dark:text-amber-200',
    'danger': 'bg-red-100 text-red-800 dark:bg-red-400/20 dark:text-red-200',
    'primary': 'bg-blue-100 text-blue-800 dark:bg-blue-400/20 dark:text-blue-200',
    'secondary': 'bg-slate-100 text-slate-800 dark:bg-slate-400/20 dark:text-slate-200',
    'dark': 'bg-slate-800 text-white',
    'light': 'bg-slate-200 text-slate-800'
} %}
{% set campagneBadgeClasses = campagneColorClasses[campagneColorKey] ?? campagneColorClasses['info'] %}

<div class="modal fade" tabindex="-1" data-base-target="modal">
    <div class="modal-dialog modal-dialog-centered modal-lg" id="stimulus_modal">
        <div class="modal-content overflow-hidden border-0 bg-white shadow-2xl dark:bg-slate-900">
            <div class="flex items-start justify-between gap-4 border-b border-slate-200 bg-slate-50/90 px-5 py-4 dark:border-slate-700 dark:bg-slate-800/85">
                <div class="min-w-0 flex-1">
                    <h5 class="mb-0 truncate text-lg font-bold tracking-tight text-slate-900 dark:text-slate-100"
                        data-base-target="modalTitle">... Chargement ...</h5>
                </div>
                <div class="flex items-center gap-2">
                    <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold {{ campagneBadgeClasses }}">{{ user_data.campagneCollecte.anneeUniversitaire.libelle }}</span>
                    <button type="button"
                            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 shadow-sm transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-700 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-300 dark:hover:border-slate-500 dark:hover:bg-slate-800"
                            data-bs-dismiss="modal"
                            data-action="base#modalClose"
                            aria-label="Close">
                        <twig:UX:Icon name="icon:close" class="h-4 w-4"/>
                    </button>
                </div>
            </div>
            <div class="max-h-[70vh] overflow-auto px-5 py-4 text-slate-700 dark:text-slate-200"
                 data-base-target="modalBody">
                Chargement...
            </div>
            <div class="flex items-center justify-end gap-2 border-t border-slate-200 bg-slate-50/80 px-5 py-4 dark:border-slate-700 dark:bg-slate-800/85">
                <button type="button"
                        class="app-btn app-btn-secondary"
                        data-action="base#modalClose"
                        data-bs-dismiss="modal"
                        data-base-target="btnClose">
                    Fermer sans sauvegarder
                </button>
            </div>
        </div>
    </div>
</div>
