{% extends 'base.html.twig' %}

{% set header_title %}
    Liste des LHEO invalides
{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        {title: 'Pilotage'},
        {title: 'Liste des LHEO invalides'},
    ]}) }}
{% endblock %}

{% block content %}
    <section class="space-y-4">
        <div class="rounded-2xl border border-cyan-200 bg-cyan-50 px-4 py-3 text-sm text-cyan-900 shadow-sm dark:border-cyan-800 dark:bg-cyan-950/30 dark:text-cyan-100">
            {% set nbErreurs = errorArray|length %}
            <strong>{{ nbErreurs }}</strong> parcours invalide{{ nbErreurs > 1 ? 's' : '' }}
            détecté{{ nbErreurs > 1 ? 's' : '' }}.
        </div>

        <div class="space-y-3">
            {% for e in errorArray %}
                <article
                        class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:hover:border-slate-600">
                    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                        <div class="space-y-2">
                            <div class="flex flex-wrap items-center gap-2">
                                <a href="{{ path('parcours_v2_voir', {parcours: e.id}) }}"
                                   class="text-base font-semibold text-slate-800 hover:text-cyan-700 dark:text-slate-100 dark:hover:text-cyan-300">
                                    {{ e.type_formation_libelle }} - {{ e.formation_libelle }}
                                    : {{ e.parcours_libelle }}
                                </a>
                                <span class="inline-flex rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600 dark:border-slate-700 dark:bg-slate-950/30 dark:text-slate-300">
                                    ID {{ e.id }}
                                </span>
                                <span class="inline-flex rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600 dark:border-slate-700 dark:bg-slate-950/30 dark:text-slate-300">
                                    {{ e.etatParcours|badgeDpe }}
                                </span>
                            </div>

                            {% if e.xml_errors|length > 0 %}
                                <div class="rounded-xl border border-rose-200 bg-rose-50/70 p-3 text-sm text-rose-800 dark:border-rose-800 dark:bg-rose-950/30 dark:text-rose-200">
                                    <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-rose-600 dark:text-rose-300">
                                        Erreurs XML</p>
                                    <ul class="list-disc space-y-1 pl-5">
                                        {% for xmlErrorMessage in e.xml_errors %}
                                            <li>{{ xmlErrorMessage }}</li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            {% endif %}
                        </div>

                        <div class="flex flex-wrap gap-2 lg:justify-end">
                            <twig:Button
                                    label="Voir"
                                    variant="info"
                                    size="sm"
                                    icon="icon:info"
                                    href="{{ path('parcours_v2_voir', {parcours: e.id}) }}"
                                    tooltip="Voir le parcours"
                            />

                            <twig:Button
                                    label="Modifier"
                                    variant="warning"
                                    size="sm"
                                    icon="icon:edit"
                                    href="{{ path('parcours_v2_modifier', {parcours: e.id}) }}"
                                    tooltip="Modifier la fiche d'identite du parcours"
                            />
                        </div>
                    </div>
                </article>
            {% else %}
                <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 shadow-sm dark:border-emerald-800 dark:bg-emerald-950/30 dark:text-emerald-200">
                    Tous les parcours sont valides !
                </div>
            {% endfor %}
        </div>
    </section>
{% endblock %}
