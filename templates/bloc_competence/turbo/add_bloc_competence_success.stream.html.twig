<turbo-stream action="replace" target="bloc-competences">
    <template>
        {{ include('typeDiplome/licence/competences/_refCompetences.html.twig', {competences: competences, parcours: parcours}) }}

        <script data-turbo-eval="true">
          (function () {
            const el = document.getElementById('bcc-{{ newEcId }}')
            if (!el) return
            el.scrollIntoView({ behavior: 'smooth', block: 'center' })
            el.classList.add('ring-4', 'ring-green-300', 'bg-green-50')
            setTimeout(() => el.classList.remove('ring-4', 'ring-green-300', 'bg-green-50'), 3500)
          })()
        </script>
    </template>
</turbo-stream>


