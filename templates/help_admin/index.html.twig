{% extends 'base.html.twig' %}

{% set header_description %}
    Créez et gérez les aides contextuelles pour chaque page de l'application.
{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        {
            href:'',
            title: 'Administration',
        }
    ]}) }}
{% endblock %}

{% block header %}
    Gestion des Aides contextuelles
{% endblock %}

{% block bouton_header %}
    <twig:Button
            label="Galerie d'images"
            variant="secondary"
            icon="mdi:image-multiple-outline"
            size="sm"
            onclick="toggleHelpImagesModal()"
            tooltip="Gérer la galerie d'images pour les aides"
            class="mx-2"
    />
    <twig:Button
            label="Ajouter une aide"
            variant="success"
            icon="icon:add"
            size="sm"
            href="{{ path('app_help_new') }}"
            tooltip="Créer une nouvelle aide pour une page"
            class="mx-2"
    />
{% endblock %}

{% block content %}
    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                <tr class="border-b border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800">
                    <th class="px-4 py-3 text-left font-semibold text-slate-900 dark:text-slate-50">Statut</th>
                    <th class="px-4 py-3 text-left font-semibold text-slate-900 dark:text-slate-50">Page (Route)</th>
                    <th class="px-4 py-3 text-left font-semibold text-slate-900 dark:text-slate-50">Titre</th>
                    <th class="px-4 py-3 text-left font-semibold text-slate-900 dark:text-slate-50">Centres</th>
                    <th class="px-4 py-3 text-right font-semibold text-slate-900 dark:text-slate-50">Actions</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                {% for help in helps %}
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800 transition">
                        <td class="px-4 py-3">
                            {% if help.isActive %}
                                <twig:Badge label="Actif" variant="success" icon="icon:check" size="sm" />
                            {% else %}
                                <twig:Badge label="Inactif" variant="danger" icon="icon:close" size="sm" />
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 align-middle">
                            <code class="px-2.5 py-1 rounded bg-slate-100 text-slate-900 font-mono text-xs dark:bg-slate-800 dark:text-slate-100">{{ help.routeSlug }}</code>
                        </td>
                        <td class="px-4 py-3 align-middle font-semibold text-slate-900 dark:text-slate-50">{{ help.title }}</td>
                        <td class="px-4 py-3 align-middle">
                            {% if help.centresShow|length > 0 %}
                                <div class="flex flex-wrap gap-1">
                                    {% for centre in help.centresShow %}
                                        {% if centre == 'cg_composante' %}
                                            <twig:Badge label="Composante" variant="info" size="sm" />
                                        {% elseif centre == 'cg_etablissement' %}
                                            <twig:Badge label="Établissement" variant="info" size="sm" />
                                        {% elseif centre == 'cg_formation' %}
                                            <twig:Badge label="Formation" variant="success" size="sm" />
                                        {% elseif centre == 'cg_parcours' %}
                                            <twig:Badge label="Parcours" variant="secondary" size="sm" />
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            {% else %}
                                <span class="text-slate-500 dark:text-slate-400 italic">Tous les centres</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 align-middle">
                            <div class="flex justify-end gap-2">
                                {% set previewUrl = previewUrls[help.id] ?? null %}
                                {% if previewUrl %}
                                    <twig:Button
                                            icon="wordpress:external"
                                            variant="info"
                                            size="md"
                                            href="{{ previewUrl }}"
                                            tooltip="Voir la page"
                                    />
                                {% else %}
                                    <button type="button"
                                            class="inline-flex items-center justify-center h-9 w-9 rounded-md border border-slate-300 bg-slate-200 text-slate-400 cursor-not-allowed dark:border-slate-600 dark:bg-slate-700 dark:text-slate-500 disabled:opacity-50"
                                            title="Route avec paramètres obligatoires : aperçu direct indisponible"
                                            disabled
                                            aria-label="Aperçu indisponible">
                                        <twig:UX:Icon name="wordpress:external" class="h-4 w-4" />
                                    </button>
                                {% endif %}

                                <twig:Button
                                        icon="icon:edit"
                                        variant="warning"
                                        size="md"
                                        href="{{ path('app_help_edit', {'id': help.id}) }}"
                                        tooltip="Modifier cette aide"
                                />

                                <form method="post"
                                      action="{{ path('app_help_delete', {'id': help.id}) }}"
                                      onsubmit="return confirm('Vraiment supprimer cette aide ?');"
                                      class="inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ help.id) }}">
                                    <twig:Button
                                            type="submit"
                                            icon="ph:trash-light"
                                            variant="danger"
                                            size="md"
                                            tooltip="Supprimer cette aide"
                                    />
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="px-4 py-8 text-center text-slate-500 dark:text-slate-400">
                            Aucune aide configurée pour le moment.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal pour la galerie d'images -->
    <div id="helpImagesModal" class="hidden fixed inset-0 z-50 overflow-y-auto">
        <div class="flex items-center justify-center min-h-screen px-4">
            <!-- Backdrop -->
            <div class="fixed inset-0 bg-black/50 transition-opacity" onclick="closeHelpImagesModal()"></div>

            <!-- Modal content -->
            <div class="relative bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-4xl max-h-[90vh] overflow-y-auto">
                <!-- Modal header -->
                <div class="sticky top-0 flex justify-between items-center px-6 py-4 border-b border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900">
                    <h2 class="text-xl font-bold text-slate-900 dark:text-slate-50 flex items-center gap-3">
                        <twig:UX:Icon name="mdi:image-multiple-outline" class="h-6 w-6" />
                        Galerie d'images des aides
                    </h2>
                    <button type="button"
                            class="text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-300 focus:outline-none"
                            onclick="closeHelpImagesModal()"
                            aria-label="Fermer">
                        <twig:UX:Icon name="basil:cross-solid" class="h-6 w-6" />
                    </button>
                </div>

                <!-- Modal body -->
                <div class="px-6 py-4">
                    {{ component('help_image_manager', { showModal: false, editorTextarea: '' }) }}
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleHelpImagesModal() {
            const modal = document.getElementById('helpImagesModal');
            modal.classList.toggle('hidden');
            if (!modal.classList.contains('hidden')) {
                loadImages();
            }
        }

        function closeHelpImagesModal() {
            const modal = document.getElementById('helpImagesModal');
            modal.classList.add('hidden');
        }

        // Close modal on Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeHelpImagesModal();
            }
        });
    </script>
{% endblock %}