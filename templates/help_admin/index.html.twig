{% extends 'base.html.twig' %}

{# CACHE INVALIDATION: 2026-05-07 11:34:00 - FIXED ROUTE GENERATION #}

{% block header %}Gestion des Aides{% endblock %}

{% block content %}
    <div class="container-fluid py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="fal fa-regular fa-circle-question"></i> Gestion des Aides contextuelles</h1>

            <div class="d-flex gap-2">
                <button type="button"
                        class="btn btn-sm btn-outline-secondary"
                        data-bs-toggle="modal"
                        data-bs-target="#helpImagesModal"
                        onclick="loadImages()"
                        title="Gérer la galerie d'images pour les aides">
                    <i class="fal fa-images"></i> <span>Galerie d'images</span>
                </button>
                <a href="{{ path('app_help_new') }}"
                   class="btn btn-sm btn-outline-primary"
                   data-bs-toggle="tooltip" data-bs-placement="bottom" title="Créer une nouvelle aide pour une page">
                    <i class="fal fa-plus"></i> <span>Ajouter une aide</span>
                </a>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Statut</th>
                        <th>Page (Route)</th>
                        <th>Titre</th>
                        <th>Centres</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for help in helps %}
                        <tr>
                            <td class="ps-4">
                                {% if help.isActive %}
                                    <span class="badge bg-success">Actif</span>
                                {% else %}
                                    <span class="badge bg-danger">Inactif</span>
                                {% endif %}
                            </td>
                            <td class="align-middle"><code>{{ help.routeSlug }}</code></td>
                            <td class="align-middle"><strong>{{ help.title }}</strong></td>
                            <td class="align-middle">
                                {% if help.centresShow|length > 0 %}
                                    {% for centre in help.centresShow %}
                                        {% if centre == 'cg_composante' %}
                                            <span class="badge bg-quaternary me-1 text-wrap">Composante</span>
                                        {% elseif centre == 'cg_etablissement' %}
                                            <span class="badge bg-info me-1 text-wrap">Etablissement</span>
                                        {% elseif centre == 'cg_formation' %}
                                            <span class="badge bg-success me-1 text-wrap">Formation</span>
                                        {% elseif centre == 'cg_parcours' %}
                                            <span class="badge bg-secondary me-1 text-wrap">Parcours</span>
                                        {% endif %}
                                    {% endfor %}
                                {% else %}
                                    <span class="text-muted"><em>Tous les centres</em></span>
                                {% endif %}
                            </td>
                            <td class="text-end pe-4">
                                {# Les boutons d'action avec le style ORéOF #}
                                <div class="d-flex justify-content-end gap-2">
                                    {% set previewUrl = previewUrls[help.id] ?? null %}
                                    {% if previewUrl %}
                                        <a href="{{ previewUrl }}"
                                           class="btn btn-sm btn-outline-secondary"
                                           data-bs-toggle="tooltip" data-bs-placement="bottom" title="Voir la page">
                                            <i class="fal fa-arrow-up-right-from-square"></i>
                                        </a>
                                    {% else %}
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary"
                                                data-bs-toggle="tooltip" data-bs-placement="bottom" title="Route avec paramètres obligatoires : aperçu direct indisponible"
                                                disabled>
                                            <i class="fal fa-arrow-up-right-from-square"></i>
                                        </button>
                                    {% endif %}

                                    <a href="{{ path('app_help_edit', {'id': help.id}) }}"
                                       class="btn btn-sm btn-outline-info"
                                       data-bs-toggle="tooltip" data-bs-placement="bottom" title="Modifier le contenu de cette aide">
                                        <i class="fal fa-edit"></i>
                                    </a>

                                    <form method="post" action="{{ path('app_help_delete', {'id': help.id}) }}" onsubmit="return confirm('Vraiment supprimer cette aide ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ help.id) }}">
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger"
                                                data-bs-toggle="tooltip" data-bs-placement="bottom" title="Supprimer définitivement cette aide">
                                            <i class="fal fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Aucune aide configurée pour le moment.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal pour la galerie d'images -->
    <div class="modal fade" id="helpImagesModal" tabindex="-1" aria-labelledby="helpImagesModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="helpImagesModalLabel"><i class="fal fa-images"></i> Galerie d'images des aides</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    {# Composant de gestion des images #}
                    {{ component('help_image_manager', { showModal: false, editorTextarea: '' }) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
