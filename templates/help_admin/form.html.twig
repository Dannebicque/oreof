{% extends 'base.html.twig' %}

{% block header %}{{ help.id ? 'Modifier' : 'Créer' }} une aide{% endblock %}

{% block content %}
    <div class="container-fluid py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="fal fa-book-open"></i> {{ help.id ? 'Modifier l\'aide contextuelle' : 'Nouvelle aide contextuelle' }}</h1>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                {# Appel du composant Live #}
                {{ component('help_editor', { initialFormData: help }) }}
            </div>
        </div>
    </div>

    <script>
        function getEditor() {
            return document.querySelector('textarea[name="help[content]"]');
        }

        function insertMarkdown(prefix, suffix) {
            const textarea = getEditor();
            if (!textarea) return;

            const start = textarea.selectionStart;
            const end = textarea.selectionEnd;
            const selectedText = textarea.value.substring(start, end);

            let newText;
            let newCursorPos;

            if (selectedText.length > 0) {
                newText = prefix + selectedText + suffix;
                newCursorPos = start + newText.length;
            } else {
                newText = prefix + suffix;
                newCursorPos = start + prefix.length;
            }

            updateTextarea(textarea, start, end, newText, newCursorPos);
        }

        function insertLink() {
            const textarea = getEditor();
            if (!textarea) return;

            const url = prompt("Collez l'URL du lien (ex: https://...) :");
            if (!url) return;

            const start = textarea.selectionStart;
            const end = textarea.selectionEnd;
            const selectedText = textarea.value.substring(start, end) || "Texte du lien";

            const newText = `[${selectedText}](${url})`;
            updateTextarea(textarea, start, end, newText, start + newText.length);
        }

        function insertImage() {
            const textarea = getEditor();
            if (!textarea) return;

            const url = prompt("Collez l'URL de l'image (ex: https://.../image.png) :");
            if (!url) return;

            const start = textarea.selectionStart;
            const end = textarea.selectionEnd;

            const newText = `![Description de l'image](${url})`;
            updateTextarea(textarea, start, end, newText, start + newText.length);
        }

        function insertVideo() {
            const textarea = getEditor();
            if (!textarea) return;

            const url = prompt("Collez l'URL de la vidéo (ex: https://youtube.com/...) :");
            if (!url) return;

            const start = textarea.selectionStart;
            const end = textarea.selectionEnd;

            const newText = `[embed](${url})`;
            updateTextarea(textarea, start, end, newText, start + newText.length);
        }

        function insertAccordion() {
            const textarea = getEditor();
            if (!textarea) return;

            const title = prompt("Titre de la section déroulante :");
            if (!title) return;

            const start = textarea.selectionStart;
            const end = textarea.selectionEnd;
            const selectedText = textarea.value.substring(start, end) || "Contenu de la section ici...";

            // Important : Les sauts de ligne (\n\n) permettent au parseur Markdown de continuer d'interpréter le contenu à l'intérieur de la balise HTML.
            const newText = `\n<details>\n<summary><strong>${title}</strong></summary>\n\n${selectedText}\n\n</details>\n`;
            updateTextarea(textarea, start, end, newText, start + newText.length);
        }

        function updateTextarea(textarea, start, end, newText, newCursorPos) {
            textarea.focus();
            textarea.setRangeText(newText, start, end, 'end');
            textarea.selectionStart = newCursorPos;
            textarea.selectionEnd = newCursorPos;
            textarea.dispatchEvent(new Event('input', { bubbles: true }));
        }
    </script>
{% endblock %}