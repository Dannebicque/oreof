{% form_theme form 'communs/form_theme_v2.html.twig' %}

<div
        class="space-y-4"
        {{ stimulus_controller('semestre--mutualise', {
            url: path('structure_semestre_mutualise_add_ajax', {semestre: semestre.id})
        }) }}
>
    <div class="flex items-start gap-2 rounded-lg bg-indigo-50 border border-indigo-100 px-3 py-2">
        <i class="fal fa-question-circle text-indigo-600 mt-0.5" data-controller="tooltip"
           data-tooltip-placement-value="bottom"
           title="{{ 'semestre.mutualiser.helps'|trans({}, 'help') }}"></i>
        <p class="text-sm font-medium text-indigo-900">{{ 'semestre.mutualiser.label'|trans({}, 'form') }}</p>
    </div>

    <div {{ stimulus_target('semestre--mutualise', 'liste') }}></div>

    {{ form_start(form, {
        attr: {
            class: 'space-y-1',
            novalidate: 'novalidate'
        }
    }) }}
    <div class="grid grid-cols-1 gap-1">
        {{ form_row(form.composante) }}
        {{ form_row(form.formation) }}
        {{ form_row(form.parcours) }}
        </div>

    <div class="pt-2 flex items-center justify-between gap-3">
        <p class="text-xs text-slate-500">Vous pouvez mutualiser avec tous les parcours d'une mention.</p>
        <button type="button"
                class="inline-flex items-center gap-2 rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white hover:bg-emerald-700 transition-colors"
                data-action="semestre--mutualise#ajouter">
            <i class="far fa-plus"></i>
            Ajouter
        </button>
    </div>
    {{ form_end(form) }}
</div>
