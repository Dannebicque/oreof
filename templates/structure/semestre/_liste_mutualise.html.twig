<div class="rounded-lg border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
        <tr>
            <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Composante</th>
            <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                Mention/Spécialité
            </th>
            <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Parcours</th>
            <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Semestre
                utilisé ?
            </th>
            <th class="px-3 py-2"></th>
        </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
        {% for sem in semestres %}
            <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-3 py-2 text-slate-700">{{ sem.parcours != null and sem.parcours.formation != null ? sem.parcours.formation.composantePorteuse.libelle : 'Erreur formation' }}</td>
                <td class="px-3 py-2 text-slate-700">{{ sem.parcours != null and sem.parcours.formation != null ? sem.parcours.formation.display : 'Erreur formation' }}</td>
                <td class="px-3 py-2 text-slate-700">{{ sem.parcours != null ? sem.parcours.libelle : 'Erreur formation' }}</td>
                <td class="px-3 py-2 text-slate-400">-</td>
                <td class="px-3 py-2 text-right">
                    <button
                            {{ stimulus_action('semestre--mutualise', 'delete', 'click', {sem: sem.id}) }}
                            type="button"
                            class="inline-flex items-center gap-1 rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-600 hover:bg-red-50 transition-colors"
                    >
                        <twig:UX:icon name="icon:delete"/>
                        Supprimer
                    </button>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="px-3 py-4 text-center text-sm text-slate-500">Semestre mutualisé avec aucun
                    parcours/mention.
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
