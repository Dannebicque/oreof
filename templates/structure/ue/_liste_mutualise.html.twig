{% if ue.ueParent != null and ue.ueParent.ueMutualisables|length %}
    <div class="mb-3 rounded-lg border border-blue-200 bg-blue-50 p-3 text-sm text-blue-900">
        <p class="font-medium">Cette UE est mutualisee automatiquement via l'UE parente.</p>
        <p class="mt-1 text-blue-800">Parcours concernes :</p>
        <ul class="mt-1 list-disc pl-5 text-blue-800">
            {% for u in ue.ueParent.ueMutualisables %}
                <li>
                    {{ u.parcours != null and u.parcours.formation != null ? u.parcours.formation.display : 'Erreur formation' }}
                    - {{ u.parcours != null and u.parcours.formation != null ? u.parcours.libelle : 'Erreur formation' }}
                </li>
            {% endfor %}
        </ul>
    </div>
{% endif %}

<div class="rounded-lg border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
        <tr>
            <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Composante</th>
            <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                Mention/Spécialité
            </th>
            <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Parcours</th>
            <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">UE utilisée ?
            </th>
            <th class="px-3 py-2"></th>
        </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
        {% for u in ues %}
            <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-3 py-2 text-slate-700">{{ u.parcours != null and u.parcours.formation != null ? u.parcours.formation.composantePorteuse.libelle : 'Erreur formation' }}</td>
                <td class="px-3 py-2 text-slate-700">{{ u.parcours != null and u.parcours.formation != null ? u.parcours.formation.display : 'Erreur formation' }}</td>
                <td class="px-3 py-2 text-slate-700">{{ u.parcours != null and u.parcours.formation != null ? u.parcours.libelle : 'Erreur formation' }}</td>
                <td class="px-3 py-2">{{ u|isUeUtilisee|badgeBoolean }}</td>
                <td class="px-3 py-2 text-right">
                    <button
                            {{ stimulus_action('ue--mutualise', 'delete', 'click', {ue: u.id}) }}
                            type="button"
                            class="inline-flex items-center gap-1 rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-600 hover:bg-red-50 transition-colors"
                    >
                        <twig:UX:icon name="icon:delete"/>
                        Supprimer
                    </button>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="px-3 py-4 text-center text-sm text-slate-500">UE mutualisée avec aucun
                    parcours/mention.
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
