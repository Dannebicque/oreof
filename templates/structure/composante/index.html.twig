{% extends 'base.html.twig' %}

{% block content %}
    <div
            {{ stimulus_controller('crud', {
                url: path('structure_composante_liste'),
                storageKey: 'structure_composante_liste',
            }) }}
            {{ stimulus_target('crud', 'liste') }}>

    </div>
{% endblock %}

{% set header_title %}
    Consulter l'offre de formation
{% endset %}

{% block breadcrumb %}
    {{ include('communs/_breadcrumb.html.twig', {liens:[
        { title: 'Consulter l\'offre de formation' }
    ]}) }}
{% endblock %}

{% block bouton_header %}
    {% if is_granted('ROLE_ADMIN') %}

        <twig:Button
                href="{{ path('app_parcours_lheo_invalid_list') }}"
                variant="success"
                icon="icon:check"
                label="Vérifier Export LHÉO"
                tooltip="Vérifier Export LHÉO"
        />

        <twig:Button
                href="{{ path('ses_export_offre_formation_brut') }}"
                variant="info"
                icon="icon:download"
                label="Export brut"
                tooltip="Export brut"
        />

        <twig:Button
                href="{{ path('ses_export_offre_formation') }}"
                variant="info"
                icon="icon:download"
                label="Bilan de remplissage"
                tooltip="Bilan de remplissage"
        />

        <twig:Button
                href="{{ path('app_formation_new') }}"
                variant="success"
                icon="icon:add"
                label="Ajouter une formation"
                tooltip="Ajouter une formation"
        />

        {# todo: a reprendre #}
