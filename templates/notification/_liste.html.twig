<div {{ stimulus_controller('notification', { url: path('app_notification_lu') }) }} class="space-y-4">
<div {{ stimulus_target('notification', 'liste') }} class="space-y-3">
    {% for notif in notifications %}
        {% set payload = notif.payload ?? {} %}
        {% if notif.isRead == false %}
            {% set status = {
                'border': 'border-amber-200',
                'bg': 'bg-amber-100',
                'text': 'text-amber-700',
                'icon': 'fa-exclamation'
            } %}
        {% else %}
            {% set status = {
                'border': 'border-emerald-200',
                'bg': 'bg-emerald-100',
                'text': 'text-emerald-700',
                'icon': 'fa-check'
            } %}
        {% endif %}
        <button type="button"
                class="{{ notif.isRead == false ? 'non-lu' : '' }} w-full rounded-2xl border border-slate-200 bg-white p-4 text-left shadow-sm transition hover:border-indigo-200 hover:bg-indigo-50/50 dark:border-slate-700 dark:bg-slate-900 dark:hover:border-indigo-500/40 dark:hover:bg-slate-800/80"
                {{ stimulus_action('notification', 'lu', 'click', {id: notif.id}) }}>
            <div class="flex items-start gap-4">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl border {{ status.border }} {{ status.bg }} {{ status.text }}">
                    <i class="fas {{ status.icon }} text-lg"></i>
                </div>

                <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center justify-between gap-2">
                        <div class="text-sm font-semibold text-slate-900 dark:text-slate-100">
                            {{ notif.title|trans({},'notif') }}
                            {% if payload.mustAck is defined and payload.mustAck == true %}
                                <span class="ml-2 inline-flex items-center rounded-full bg-amber-100 px-2.5 py-0.5 text-[11px] font-semibold text-amber-800 dark:bg-amber-400/20 dark:text-amber-200">Validation obligatoire</span>
                            {% endif %}
                        </div>
                        <div class="text-xs font-medium text-slate-500 dark:text-slate-400">{{ notif.created|date('d/m/Y') }}</div>
                    </div>

                    {% if notif.body %}
                        <div class="mt-1 text-sm text-slate-600 dark:text-slate-300">{{ notif.body }}</div>
                    {% endif %}

                    {% if payload.changedFields is defined and payload.changedFields|length > 0 %}
                        <div class="mt-2 text-xs text-slate-500 dark:text-slate-400">Champs modifiés: {{ payload.changedFields|join(', ') }}</div>
                    {% endif %}
                    {% if payload.sourceUeLabel is defined and payload.sourceUeLabel %}
                        <div class="mt-1 text-xs text-slate-500 dark:text-slate-400">UE porteuse: {{ payload.sourceUeLabel }}</div>
                    {% endif %}
                    {% if payload.sourceSemestreLabel is defined and payload.sourceSemestreLabel %}
                        <div class="mt-1 text-xs text-slate-500 dark:text-slate-400">Semestre porteur: {{ payload.sourceSemestreLabel }}</div>
                    {% endif %}
                </div>
            </div>
        </button>
    {% else %}
        {{ component('alerte', {
            'type': 'info',
            'message': 'Aucune notification.'
        }) }}
    {% endfor %}
</div>
    <div class="mt-4 flex flex-col gap-2 border-t border-slate-100 pt-4 sm:flex-row dark:border-slate-700/80">
        <button class="app-btn app-btn-warning w-full justify-center sm:w-1/2"
                {{ stimulus_action('notification', 'toutLu', 'click', {url: path('app_notification_tout_lu')}) }}
        >Tout marquer comme lu</button>
        <button class="app-btn app-btn-danger w-full justify-center sm:w-1/2"
                {{ stimulus_action('notification', 'toutSupprimer', 'click', {url: path('app_notification_tout_suppr')}) }}
        >Tout supprimer</button>
    </div>
</div>
