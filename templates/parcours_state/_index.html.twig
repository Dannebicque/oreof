{% set sectionTitleClass = 'border-y border-slate-200 bg-slate-100/90 px-4 py-3.5 text-left text-sm font-extrabold tracking-wide text-slate-700 dark:border-slate-700 dark:bg-slate-800/80 dark:text-slate-100' %}
{% set dataRowClass = 'border-b border-slate-200 dark:border-slate-700' %}
{% set labelCellClass = 'px-4 py-4 align-top font-medium leading-relaxed text-slate-700 dark:text-slate-200' %}
{% set valueCellClass = 'px-4 py-4 align-top leading-relaxed text-slate-700 dark:text-slate-200' %}
{% set subLabelCellClass = 'px-4 py-3.5 pl-8 align-top leading-relaxed text-slate-600 dark:text-slate-300' %}
{% set deepSubLabelCellClass = 'px-4 py-3.5 pl-12 align-top leading-relaxed text-slate-600 dark:text-slate-300' %}
{% set choiceBadgeClass = 'ml-2 inline-flex items-center rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-medium text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-200' %}

<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
    <div class="overflow-x-auto">
        <table class="min-w-full text-sm text-slate-700 dark:text-slate-200">
            <tbody>
            <tr>
                <th colspan="2" class="{{ sectionTitleClass }}">Présentation du parcours</th>
            </tr>
            <tr class="{{ dataRowClass }}">
                <td class="{{ labelCellClass }}">Responsable du parcours</td>
                <td class="{{ valueCellClass }}">{{ valide.etat.respParcours|badgeValide }}</td>
            </tr>
            <tr class="{{ dataRowClass }}">
                <td class="{{ labelCellClass }}">Objectifs du parcours</td>
                <td class="{{ valueCellClass }}">{{ valide.etat.objectifsParcours|badgeValide }}</td>
            </tr>
            <tr class="{{ dataRowClass }}">
                <td class="{{ labelCellClass }}">Résultats attendus du parcours</td>
                <td class="{{ valueCellClass }}">{{ valide.etat.resultatsAttendus|badgeValide }}</td>
            </tr>
            <tr class="{{ dataRowClass }}">
                <td class="{{ labelCellClass }}">Contenu du parcours</td>
                <td class="{{ valueCellClass }}">{{ valide.etat.contenuParcours|badgeValide }}</td>
            </tr>
            <tr class="{{ dataRowClass }}">
                <td class="{{ labelCellClass }}">Mots clés du parcours</td>
                <td class="{{ valueCellClass }}">{{ valide.etat.motsCles|badgeValide }}</td>
            </tr>
            <tr class="{{ dataRowClass }}">
                <td class="{{ labelCellClass }}">Rythme de formation du parcours</td>
                <td class="{{ valueCellClass }}">{{ valide.etat.rythmeParcours|badgeValide }}</td>
            </tr>
            <tr class="{{ dataRowClass }}">
                <td class="{{ labelCellClass }}">Localisation du parcours</td>
                <td class="{{ valueCellClass }}">{{ valide.etat.localisation|badgeValide }}</td>
            </tr>

            {{ include('parcours_state/_commun.html.twig') }}
            </tbody>
        </table>
    </div>
</div>
